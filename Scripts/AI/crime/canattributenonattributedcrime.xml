									<LinkDataFilter tag="&apos;switch_corpse&apos;" condition="~$__link_switch_corpse.resolved" prune="true" negprune="unknown" Parent="" Child="" Data="" />
									<WUIDFilter WUID="$information.perceivedWuid" Source="Child" prune="true" negprune="unknown" Parent="" Child="" />
								</GraphSearch>
							</Invertor>
						</IfCondition>
						<Expression expressions="$canAttribute = false" />
					</Sequence>
				</SuppressFailure>
			</Behavior>
		</Root>
