													<Elements>
														<Response Role="FRANTA_KULDANU" ReferenceLength="4">
															<Text Text="Kam nás vlastně vezete?">
																<Localization Text="Kam nás vlastně vezete?" CreatedOn="2023-05-15T15:23:57.588006" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																<Localization Text="Where are you taking us?" CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																<Localization Text="Where are you taking us?" CreatedOn="2023-12-15T13:32:33.854596" UpdatedOn="2023-12-15T14:59:47.711423" Language="ENG" Translator="john.comer" />
															</Text>
															<Commands>
																<FacialMoodCommand FacialMood="arrogant2" />
																<FacialMoodCommand FacialMood="sad2" />
																<LookAtCommand Delay="0.02" LookAtRole="FRANTA_KULDANU" />
																<LookAtCommand Delay="0.04" LookAtRole="HENRY" />
																<CameraCommand />
															</Commands>
														</Response>
														<Response Role="FRANTA_KULDANU">
															<Text Text="A co bude s náma?">
																<Localization Text="A co bude s náma?" CreatedOn="2023-07-24T22:56:05.909821" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																<Localization Text="And what about us?" CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																<Localization Text="And what will happen to us?" CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
															</Text>
														</Response>
													</Elements>
													<Decision Name="dec5" Priority="SideQuestSubmission">
														<Sequences>
															<Sequence EndType="Decision" Name="seq7">
																<UiPrompt Text="Umřete">
																	<Localization Text="Umřete" CreatedOn="2024-04-03T11:06:09.498385" UpdatedOn="2024-04-08T09:25:50.967262" Language="WHS" Translator="ondrej.bittner" />
																	<Localization Text="You'll die" CreatedOn="2024-07-29T15:28:42.352669" UpdatedOn="2024-07-31T11:50:56.905051" Language="PDG" Translator="john.comer" />
																	<Localization Text="You'll die" CreatedOn="2024-07-31T13:29:28.381636" UpdatedOn="2024-07-31T14:02:39.285122" Language="ENG" />
																</UiPrompt>
																<Elements>
																	<Response Role="HENRY" ReferenceLength="15">
																		<Text Text="Co bys řekl? Jestli popravěj pána šlechtice, tak nad pacholkem nebo dvěma se rozmejšlet nebudou.">
																			<Localization Text="Co bys řekl? Jestli popravěj pána šlechtice, tak nad pacholkem nebo dvěma se rozmejšlet nebudou." CreatedOn="2023-07-24T22:56:05.909821" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																			<Localization Text="What do you think? If they'll execute a nobleman, they won't think twice about a hired hand or two." CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																			<Localization Text="What do you think? If they'll execute a nobleman, they won't think twice about a hired hand or two." CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																		</Text>
																		<Commands>
																			<FacialMoodCommand Role="FRANTA_KULDANU" FacialMood="sad2" />
																			<AnimationHeadCommand Role="FRANTA_KULDANU" Delay="4.13" FragmentId="ADLG_FA_Surprise" Guid="2ddba844-9de9-422d-b5e9-56ed97c1f433" Variant="2" />
																			<LookAtCommand Role="FRANTA_KULDANU" Delay="0.06" LookAtRole="HENRY" />
																			<LookAtCommand Role="FRANTA_KULDANU" Delay="0.02" LookAtRole="FRANTA_KULDANU" Offset="BottomCenter" />
																			<CameraCommand />
																		</Commands>
																	</Response>
																	<Response Role="FRANTA_KULDANU">
																		<Text Text="Je spravedlivej, ale jestli na tohle bude mít náladu to nevim.">
																			<Localization Text="Je spravedlivej, ale jestli na tohle bude mít náladu to nevim." CreatedOn="2023-07-25T00:45:58.984496" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																			<Localization Text="Semine may be just, but I'm not sure he's going to be in the mood for this." CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																			<Localization Text="Semine might be merciful, but whether he'll be in the mood for this, I can't say." CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																		</Text>
																		<Commands>
																			<CameraCommand />
																		</Commands>
																	</Response>
																</Elements>
																<Decision Name="dec6" Priority="SideQuestSubmission" Autoselect="true">
																	<Sequences>
																		<Sequence EndType="EndDialogue" Name="seq9">
																			<Elements>
																				<Response Role="FRANTA_KULDANU" ReferenceLength="8">
																					<Text Text="Já sem nevinej! Přísahám na duši svý mámy.">
																						<Localization Text="Já sem nevinej! Přísahám na duši svý mámy." CreatedOn="2023-10-02T15:39:20.934773" UpdatedOn="2023-10-02T15:51:45.809595" Language="WHS" Translator="ondrej.bittner" />
																						<Localization Text="I'm innocent! I swear on my Ma's soul." CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																						<Localization Text="I'm innocent! I swear on my Ma's soul." CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																					</Text>
																					<Commands>
																						<FacialMoodCommand FacialMood="nervous2" />
																						<LookAtCommand Delay="0.06" LookAtRole="HENRY" />
																						<LookAtCommand Delay="0.02" LookAtRole="FRANTA_KULDANU" />
																						<LookAtCommand Delay="0.04" LookAtRole="FRANTA_KULDANU" Offset="BottomCenter" />
																						<LookAtCommand Delay="0.06" LookAtRole="HENRY" />
																						<LookAtCommand Delay="2.02" LookAtRole="FRANTA_KULDANU" />
																						<CameraCommand />
																					</Commands>
																				</Response>
																				<Response Role="FRANTA_KULDANU" ReferenceLength="18">
																					<Parenthetical>
																						<Text Text="uraženě">
																							<Localization Text="uraženě" CreatedOn="2023-05-19T16:13:35.121179" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																							<Localization Text="offended" CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																							<Localization Text="offended" CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																						</Text>
																					</Parenthetical>
																					<Text Text="To mě má jako obměkčit? Pche ... každej všivák, kterýho sem vlekl na šibenici se zaklínal svoji mámou.">
																						<Localization Text="To mě má jako obměkčit? Pche ... každej všivák, kterýho sem vlekl na šibenici se zaklínal svoji mámou." CreatedOn="2023-07-24T22:56:05.973835" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																						<Localization Text="Is that supposed to soften my heart? Pah… Every good-for-nothing I've dragged to the gallows has invoked his mother." CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																						<Localization Text="Is that supposed to soften my heart? Pah! Every mangy cur I dragged to the gallows swore on his mother." CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																					</Text>
																					<Commands>
																						<LookAtCommand Delay="0.08" LookAtRole="FRANTA_KULDANU" />
																					</Commands>
																				</Response>
																				<Response Role="FRANTA_KULDANU" ReferenceLength="14">
																					<Text Text="Kdepak počestnej člověk by neriskoval nesmrtelnou duši svý máti ikdyby byl čistej jak lilie.">
																						<Localization Text="Kdepak počestnej člověk by neriskoval nesmrtelnou duši svý máti ikdyby byl čistej jak lilie." CreatedOn="2023-07-24T23:36:18.971799" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																						<Localization Text="Nobody with any decency would risk his mother's immortal soul, even if he was pure as the driven snow." CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																						<Localization Text="Nobody with any decency would risk his mother's immortal soul, even if he was as pure as the driven snow." CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																					</Text>
																					<Commands>
																						<LookAtCommand Delay="0.09" LookAtRole="FRANTA_KULDANU" />
																					</Commands>
																				</Response>
																				<Response Role="FRANTA_KULDANU" ReferenceLength="11">
																					<Text Text="Ale hajzl ten se její duší zakleje hned. Že se nestydíš.">
																						<Localization Text="Ale hajzl ten se její duší zakleje hned. Že se nestydíš." CreatedOn="2023-07-24T23:36:44.997967" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																						<Localization Text="But this toe-rag doesn't think twice about cursing her. You should be ashamed of yourself." CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																						<Localization Text="But this bastard doesn't think twice about her soul. You should be ashamed of yourself." CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																					</Text>
																					<Commands>
																						<LookAtCommand Delay="0.12" LookAtRole="FRANTA_KULDANU" />
																					</Commands>
																				</Response>
																				<Response Role="FRANTA_KULDANU" ReferenceLength="10">
																					<Text Text="Hejtman má pravdu. Na mámu přísahaj jen ty nejhorší lotři.">
																						<Localization Text="Hejtman má pravdu. Na mámu přísahaj jen ty nejhorší lotři." CreatedOn="2023-07-24T23:37:00.740281" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																						<Localization Text="The captain's right. Only the lowest of the low swear on their mother." CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																						<Localization Text="The captain's right. Only the lowest of the low swears on his mother." CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																					</Text>
																					<Commands>
																						<LookAtCommand Delay="0.12" LookAtRole="FRANTA_KULDANU" />
																					</Commands>
																				</Response>
																				<Response Role="FRANTA_KULDANU" ReferenceLength="14">
																					<Text Text="Přesně tak. Francku ty si byl dycky takovej šmejd ... tomu fakt neni rovno.">
																						<Localization Text="Přesně tak. Francku ty si byl dycky takovej šmejd ... tomu fakt neni rovno." CreatedOn="2023-07-25T00:48:42.932645" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																						<Localization Text="That's right. You always were a wanker, Franzi. It beggars belief…" CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																						<Localization Text="That's right. You always were a piece of shit, Franzi. No scruples." CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																					</Text>
																					<Commands>
																						<LookAtCommand Delay="0.01" LookAtRole="FRANTA_KULDANU" />
																					</Commands>
																				</Response>
																				<Response Role="FRANTA_KULDANU">
																					<Text Text="No ještě že ty seš tady abys nám to vysvětlil. A vůbec držte už všichni tři kušnu.">
																						<Localization Text="No ještě že ty seš tady abys nám to vysvětlil. A vůbec držte už všichni tři kušnu." CreatedOn="2023-07-24T23:40:00.805209" UpdatedOn="2023-07-25T00:54:35.282951" Language="WHS" Translator="ondrej.bittner" />
																						<Localization Text="Thank God you're here to explain it all to us. And now shut your gobs, the three of you." CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																						<Localization Text="Well, ain't it grand to have you here to explain everything?! And now shut your gobs, the three of you!" CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																					</Text>
																				</Response>
																				<Response Role="FRANTA_KULDANU">
																					<Text Text="Nerad bych aby ste lidem votravovali vzduch těma svejma kydama.">
																						<Localization Text="Nerad bych aby ste lidem votravovali vzduch těma svejma kydama." CreatedOn="2023-09-20T12:29:56.925182" UpdatedOn="2023-09-20T13:53:02.089146" Language="WHS" Translator="ondrej.bittner" />
																						<Localization Text="I don't want you poisoning the air with the shit you spout." CreatedOn="2023-11-30T10:25:14.467859" UpdatedOn="2023-12-02T12:26:00.886765" Language="PDG" />
																						<Localization Text="I don't want you poisoning the air with the shit you spout." CreatedOn="2023-12-18T10:31:32.957954" UpdatedOn="2023-12-18T10:58:48.533377" Language="ENG" Translator="john.comer" />
																					</Text>
																				</Response>
																			</Elements>
																		</Sequence>
