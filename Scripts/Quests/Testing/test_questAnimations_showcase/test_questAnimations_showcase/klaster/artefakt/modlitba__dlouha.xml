								<Response Role="HENRY">
									<Text StringName="modl_henry_odpust_nam_pro_Q7P6" Text="Odpusť nám prohřesky naše a uchraň nás od té strašlivé nemoci.">
										<Localization Text="Odpusť nám prohřesky naše a uchraň nás od té strašlivé nemoci." CreatedOn="2025-05-30T21:30:14.8922536+02:00" UpdatedOn="2025-05-30T21:30:14.8922536+02:00" LoadedOn="2025-05-30T21:30:14.8922536+02:00" Language="WHS" Translator="vit.blecha" />
