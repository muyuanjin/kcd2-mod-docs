										</Text>
									</Parenthetical>
									<Text StringName="modl_henry_chvala_tobe_pa_jmGN" Text="Chvála tobě Pane náš všemohoucí.">
										<Localization Text="Chvála tobě Pane náš všemohoucí." CreatedOn="2025-05-30T21:30:14.8922536+02:00" UpdatedOn="2025-05-30T21:30:14.8922536+02:00" LoadedOn="2025-05-30T21:30:14.8922536+02:00" Language="WHS" Translator="vit.blecha" />
