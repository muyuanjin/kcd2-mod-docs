								<Direction>
									<Text StringName="modl_tady_by_to_mohl_ofsc_ZYEt" Text="tady by to mohl ofscreen otevřít aby jemnoval krista už při pohledu na ten úlomek z jeho kříže">
										<Localization Text="tady by to mohl ofscreen otevřít aby jemnoval krista už při pohledu na ten úlomek z jeho kříže" CreatedOn="2025-05-30T21:30:14.8922536+02:00" UpdatedOn="2025-05-30T21:30:14.8922536+02:00" LoadedOn="2025-05-30T21:30:14.8922536+02:00" Language="WHS" Translator="vit.blecha" />
									</Text>
								</Direction>
								<Response Role="HENRY">
									<Text StringName="modl_henry_a_chvala_tobe__59vx" Text="A chválá tobě, milosrdný Kriste, který jsi pro nás na kříži trpěl.">
										<Localization Text="A chválá tobě, milosrdný Kriste, který jsi pro nás na kříži trpěl." CreatedOn="2025-05-30T21:30:14.8922536+02:00" UpdatedOn="2025-05-30T21:30:14.8922536+02:00" LoadedOn="2025-05-30T21:30:14.8922536+02:00" Language="WHS" Translator="vit.blecha" />
									</Text>
								</Response>
								<Response Role="HENRY">
									<Text StringName="modl_henry_dekuji_ze_na_n_r1kd" Text="Děkuji, že na nás hříšné pamatuješ v tomhle těžkym čase.">
										<Localization Text="Děkuji, že na nás hříšné pamatuješ v tomhle těžkym čase." CreatedOn="2025-05-30T21:30:14.8922536+02:00" UpdatedOn="2025-05-30T21:30:14.8922536+02:00" LoadedOn="2025-05-30T21:30:14.8922536+02:00" Language="WHS" Translator="vit.blecha" />
									</Text>
								</Response>
								<Response Role="HENRY">
									<Text StringName="modl_henry_a_ze_jsi_mi_do_cxii" Text="A že jsi mi dovolil najít tento poklad.">
										<Localization Text="A že jsi mi dovolil najít tento poklad." CreatedOn="2025-05-30T21:30:14.8922536+02:00" UpdatedOn="2025-05-30T21:30:14.8922536+02:00" LoadedOn="2025-05-30T21:30:14.8922536+02:00" Language="WHS" Translator="vit.blecha" />
