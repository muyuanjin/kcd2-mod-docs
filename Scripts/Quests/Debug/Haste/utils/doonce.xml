<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="doonce">
			<Ports>
				<Port Name="do" Direction="In" Type="trigger">
					<DesignName Text="Do" />
				</Port>
				<Port Name="reset" Direction="In" Type="trigger">
					<DesignName Text="Reset" />
				</Port>
				<Port Name="exec" Direction="Out" Type="trigger">
					<DesignName Text="Exec" />
				</Port>
			</Ports>
			<Nodes>
				<State Name="did" PositionY="-120" PositionX="-60" TypeT="bool">
					<Edge From="do" To="SetTrue" />
					<Edge From="reset" To="SetFalse" />
				</State>
				<Output Name="Output">
					<Edge From="did.OnTrue" To="exec" />
				</Output>
			</Nodes>
			<Text Text="DoOnce" />
		</Module>
	</Skald>
</Database>