			<QuestDescription StringName="qdesc_navsteva_lekare_GK7H" Text="Pan Písek mě pověřil, abych se zastavil za mistrem Albíkem z Uničova - významným lékařem, který teď žije v domě tarmarského apatykáře v Kutné hoře. Albík se chystá do kláštera na Sedleci a Písek hledá někoho, kdo na Albíka dohlédne." />
			<Objectives>
				<Objective TypeT="TalkToAlbich" Name="promluv_si_s_albikem_z_unicova">
					<LocalizedName StringName="navsteval_promluv_si_s_al_agZa" Text="Promluv si s Albíkem z Uničova." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="TalkToAlbichStart" Marker="albikHouseArea">
							<Log StringName="promluv_s_pan_pisek_me_po_AaxP" Text="Věhlasný mistr Albík potřebuje doprovod do Sedleckého kláštera." />
						</EnumLog>
						<EnumLog Type="Updated" Name="HenryKnowsAboutHouse" Marker="sickHousewifeHouseArea">
							<Log StringName="promluv_s_mistr_albik_ode_yDu8" Text="V domě, kde Albík přebývá jsem se dověděl, že ale odešel léčit nemocnou službu do domu sousedů, co bydlí ob dům směrem k náměstí." />
						</EnumLog>
						<EnumLog Type="Updated" Name="GetToPacientHouseUpdated" Marker="sickHousewifeHouseBackyardArea">
							<Log StringName="promluv_s_predni_dvere_do_RuXB" Text="V domě, kde Albík přebývá jsem se dověděl, že ale odešel léčit nemocnou službu do domu sousedů, co bydlí ob dům směrem k náměstí. U vstupních dveře se ale něco děje, jimi to teda nepůjde." />
						</EnumLog>
						<EnumLog Type="Updated" Name="TalkToAlbichUpdated" Marker="albik">
							<Log StringName="promluv_s_musim_si_promlu_SMFK" Text="Musím si promluvit s panem Albíkem." />
						</EnumLog>
						<EnumLog Type="Completed" Name="CompletedWithAngryPatient">
							<Log StringName="promluv_s_promluvil_jsem__r3Gn" Text="Promluvil jsem se s Albíkem, ale než jsme stihli cokoli vyřešit, vyrušil nás příchod naštvaných pacientů." />
						</EnumLog>
						<EnumLog Type="Completed" Name="CompletedWithoutAngryPatient">
							<Log StringName="promluv_s_promluvil_jsem__XMRr" Text="Promluvil jsem se s Albíkem o jeho doprovodu do Sedleckého kláštera." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="bran_se">
					<LocalizedName StringName="navsteval_bran_sebe_a_alb_sccw" Text="Braň se!" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active">
							<Log StringName="bran_se_zautocili_na_nas__nItQ" Text="Zaútočili na nás! Musím ochránit sebe a mistra Albíka před těmi naštvanými pacienty!" />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="bran_se_naucil_jsem_oba_c_ETUW" Text="Naučil jsem oba chlapy, jak se mají správně chovat." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="bran_se_od_nastvanych_pac_3bPB" Text="Rozčílení pacienti, kteří se dožadovali Albíkovy péče, nás nakonec napadli... No a já se jako nejlepší osobní ochránce zrovna nezachoval..." />
						</EnumLog>
					</Logs>
				</Objective>
