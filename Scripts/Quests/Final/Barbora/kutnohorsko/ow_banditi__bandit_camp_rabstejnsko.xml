<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="ow_banditi__bandit_camp_rabstejnsko" Purpose="CharacterControl">
			<Ports>
				<Port Name="s55__zakopany_zitrek_zacal" Direction="In" Type="trigger">
					<DesignName StringName="ow_bandit_s55__zakopany_z_WHL4" Text="S55 - Zakopaný zítřek začal" />
				</Port>
				<Port Name="s55__zakopany_zitrek_skoncil" Direction="In" Type="trigger">
					<DesignName StringName="ow_bandit_s55__zakopany_z_wASd" Text="S55 - Zakopaný zítřek skončil" />
				</Port>
				<Port Name="s55__zakopany_zitrek__progress" Direction="In" Type="wh::questmodule::QuestProgress">
					<DesignName StringName="ow_bandit_s55__zakopany_z_Eybn" Text="S55 - Zakopaný zítřek - progress" />
				</Port>
				<Port Name="camp_is_unstreamed" Direction="Out" Type="bool">
					<DesignName StringName="ow_bandit_camp_is_unstrea_F3Fr" Text="camp is unstreamed" />
				</Port>
			</Ports>
			<Nodes>
				<IfFunction Name="if_And_2" PositionY="500" PositionX="-1300" MethodName="math::boolean::And" DeclaringType="math::boolean">
					<Edge From="patchTrigger_2.OnPatch" To="Exec" />
					<Edge From="switch3.Value1" To="A" />
					<Edge From="timer_1.Stopped" To="B">
						<Vertex>kG5o5gBn</Vertex>
						<Vertex>CyqtVHPt</Vertex>
					</Edge>
				</IfFunction>
				<IfFunction Name="ifQuestAlreadyFinished" PositionY="190" PositionX="-1300" MethodName="math::boolean::And" DeclaringType="math::boolean">
					<Edge From="patchTrigger_1.OnPatch" To="Exec" />
					<Edge From="switch3.Value1" To="A" />
				</IfFunction>
				<IntermissionTrigger Name="intermissionTrigger_1" PositionY="340" PositionX="-130">
					<Edge From="timerDoneAndBanditsUnstreamed.bool" To="IsActive" />
				</IntermissionTrigger>
				<State Name="krab_banditCamp_owBanditsStreamState" PositionY="-190" PositionX="230" TypeT="banditsStreamState">
					<Constant Name="DefaultValue" Value="Streamed" />
					<Edge From="s55__zakopany_zitrek_zacal" To="SetUnstreamed" />
					<Edge From="intermissionTrigger_1.OnIntermission" To="SetStreamed" />
				</State>
				<Function Name="or5" PositionY="90" PositionX="680" MethodName="math::boolean::Or" DeclaringType="math::boolean">
					<Edge From="krab_banditCamp_owBanditsStreamState.Unstreamed" To="A" />
					<Edge From="timer_1.Running" To="B">
						<Vertex>IeTx40sT</Vertex>
					</Edge>
				</Function>
				<Output Name="Output">
					<Edge From="or5.bool" To="camp_is_unstreamed" />
				</Output>
				<PatchTrigger Name="patchTrigger_1" PositionY="190" PositionX="-1820">
					<Constant Name="TransitionToVersion" Value="ver_01_04" />
				</PatchTrigger>
				<PatchTrigger Name="patchTrigger_2" PositionY="710" PositionX="-1830">
					<Constant Name="TransitionToVersion" Value="ver_01_05" />
				</PatchTrigger>
				<Layer Name="profile1" PositionY="-90" PositionX="680">
					<Asset Name="Profiles" Alias="krab_bandits" />
					<Edge From="krab_banditCamp_owBanditsStreamState.Streamed" To="IsActive" />
				</Layer>
				<Switch Name="switch3" PositionY="440" PositionX="-1850" TypeT="wh::questmodule::QuestProgress" ValueTypes="bool" SwitchValues="Done Failed">
					<Constant Name="DoneValue1" Value="true" />
					<Constant Name="FailedValue1" Value="true" />
					<Constant Name="DefaultValue1" Value="false" />
					<Edge From="s55__zakopany_zitrek__progress" To="Switch" />
				</Switch>
				<Timer Name="timer_1" PositionY="80" PositionX="-740">
					<Constant Name="Duration" Value="2d" />
					<Constant Name="TimeType" Value="WorldTime" />
					<Edge From="s55__zakopany_zitrek_skoncil" To="SetRunning" />
					<Edge From="ifQuestAlreadyFinished.True" To="SetRunning" />
					<Edge From="if_And_2.True" To="SetRunning" />
				</Timer>
				<Function Name="timerDoneAndBanditsUnstreamed" PositionY="340" PositionX="-360" MethodName="math::boolean::And" DeclaringType="math::boolean">
					<Edge From="timer_1.Finished" To="A" />
					<Edge From="krab_banditCamp_owBanditsStreamState.Unstreamed" To="B">
						<Vertex>CrJHYQKl</Vertex>
						<Vertex>KAPXrpWN</Vertex>
					</Edge>
				</Function>
			</Nodes>
			<EdgeVertices>
				<EdgeVertex Name="CrJHYQKl" PositionY="590" PositionX="480" />
				<EdgeVertex Name="CyqtVHPt" PositionY="760" PositionX="-1290" />
				<EdgeVertex Name="IeTx40sT" PositionY="234" PositionX="-353" />
				<EdgeVertex Name="KAPXrpWN" PositionY="590" PositionX="-350" />
				<EdgeVertex Name="kG5o5gBn" PositionY="760" PositionX="-620" />
			</EdgeVertices>
			<Types>
				<Type TypeName="banditsStreamState">
					<StateTypeEnumeration Name="Streamed" ObjectiveValueType="None" />
					<StateTypeEnumeration Name="Unstreamed" ObjectiveValueType="None" />
				</Type>
			</Types>
			<Assets>
				<ProfileAsset Name="krab_bandits" AssetProfiles="krab_banditCamp_bandits" />
			</Assets>
			<Text StringName="ow_banditi__bandit_camp_r_uNRO" Text="OW Banditi - Bandit camp Rabštejnsko" />
		</Module>
	</Skald>
