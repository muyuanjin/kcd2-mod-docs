<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="fabrizio" Purpose="CharacterControl">
			<Ports>
				<Port Name="stream" Direction="In" Type="trigger">
					<DesignName StringName="fabrizio_stream_Unau" Text="stream" />
				</Port>
				<Port Name="unstream" Direction="In" Type="trigger">
					<DesignName StringName="fabrizio_unstream_fL4B" Text="unstream" />
				</Port>
				<Port Name="fabrizio_streamed" Direction="Out" Type="bool">
					<DesignName StringName="fabrizio_fabrizio_streamed_fOqd" Text="fabrizio &lt;streamed&gt;" />
				</Port>
			</Ports>
			<Nodes>
				<State Name="fabrizioStreamingState" PositionY="-150" PositionX="30" TypeT="FabrizioStreamingState">
					<Constant Name="DefaultValue" Value="Streamed" />
					<Edge From="stream" To="SetStreamed" />
					<Edge From="unstream" To="SetUnstreamed" />
				</State>
				<Output Name="Output">
					<Edge From="fabrizioStreamingState.Streamed" To="fabrizio_streamed" />
				</Output>
				<Layer Name="profile2" PositionY="-150" PositionX="380">
					<Asset Name="Profiles" Alias="fabrizioProfile" />
					<Edge From="fabrizioStreamingState.Streamed" To="IsActive" />
				</Layer>
			</Nodes>
			<Types>
				<Type TypeName="FabrizioStreamingState">
					<StateTypeEnumeration Name="Streamed" ObjectiveValueType="None" />
					<StateTypeEnumeration Name="Unstreamed" ObjectiveValueType="None" />
				</Type>
			</Types>
			<Assets>
				<ProfileAsset Name="fabrizioProfile" AssetProfiles="kkut_fabrizio" />
			</Assets>
			<Text StringName="fabrizio_fHVT" Text="Fabrizio" />
		</Module>
	</Skald>
</Database>