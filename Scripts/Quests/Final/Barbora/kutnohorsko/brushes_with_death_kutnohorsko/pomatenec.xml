			<Text StringName="s140_pomatenec_HMpk" Text="Pomatenec" />
			<QuestName StringName="qname_pomatenec_ZjKI" Text="Pomatenec" />
			<QuestDescription StringName="qdesc_pomatenec_z1Xx" Text="Chtěl jsem o malíři zjistit něco víc, ale on než by mi něco sám řekl, mě raději poslal do jakési zemnice poblíž Malešova. Že prý se tam mám podívat, nasát atmosféru a pak si s ním můžu promluvit o tom, co tam bylo." />
			<Objectives>
				<Objective TypeT="Progress" Name="najdi_zemnici_kterou_zminoval_vojtech">
					<LocalizedName StringName="pomatenec_najdi_misto_H9hH" Text="Najdi zemnici, kterou zmiňoval Vojtěch." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="CampArea">
							<Log StringName="najdi_zem_zemnice_ma_byt__tWdu" Text="Zemnice má být opuštěná a prý ji najdu na severovýchodě od Malešova u cesty." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="najdi_zem_zemnici_jsem_na_83ql" Text="Zemnici jsem našel, ale vypadá to, že není tak opuštěná, jak Vojtěch tvrdil." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="PromluvSPomatencem" Name="promluv_si_s_clovek_ktery_v_zemnici_bydli">
					<LocalizedName StringName="pomatenec_promluv_si_s_po_Qq3b" Text="Promluv si s člověkem, který v zemnici bydlí." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="PromluvSPomatencemRefusal" Marker="PomatenyStarik">
							<Log StringName="promluv_s_zkusim_si_proml_7VHu" Text="Měl bych si i promluvit s člověkem, co v té zemnici bydlí.  Třeba Vojtěcha zná." />
						</EnumLog>
						<EnumLog Type="None" Name="ProbihaSouboj" />
						<EnumLog Type="Started" Name="PromluvSPomatencemDialog" Marker="PomatenyStarik">
							<Log StringName="promluv_s_ten_chlap_me_na_D8eO" Text="Snad se ten chlap po tom boji trochu uklidnil. Zkusím si s ním promluvit teď. Ať můžu Vojtěchovi říct, kdo to je a co v té &quot;jeho&quot; zemnici dělá." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="PomatenecKilled">
							<Log StringName="promluv_s_toho_chlapa_co__wLPc" Text="Toho chlapa, co v té zemnici bydlel, jsem radši zabil. Vojtěch stejně říkal, že má být opuštěná." />
						</EnumLog>
						<EnumLog Type="Completed" Name="PomatenecTalked">
							<Log StringName="promluv_s_promluvil_jsem__rcRd" Text="Promluvil jsem si s tím chlapem, co v té zemnici žije, ale vypadá to, že je to blázen. To, co říkal, nemělo moc hlavu a patu. Zmínil ale Vojtovo a Burkhardovo jméno. " />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="PomatenecInteractionState" Name="vyres_situaci_s_agresivnim_muzem_ze_zemnice">
					<LocalizedName StringName="pomatenec_vyres_pomatence_ZEIS" Text="Vyřeš situaci s agresivním mužem ze zemnice." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="None" Name="WaitingForInteraction" />
						<EnumLog Type="Started" Name="DuringFight">
							<Log StringName="uklidni_a_ten_chlap_me_hn_atsX" Text="Ten chlap mě hnedka napadl! Musím ho nějak uklidnit a pak si s ním zkusit promluvit, ať zjistím, co se to tady děje." />
						</EnumLog>
						<EnumLog Type="Completed" Name="PlayerWon">
							<Log StringName="uklidni_a_ten_chlap_z_te__afXN" Text="Ten chlap z té zemnice mě hned napadl, ale zvládl jsem se mu ubránit." />
						</EnumLog>
						<EnumLog Type="Completed" Name="PomatenecWon">
							<Log StringName="uklidni_a_ten_chlap_z_te__9oFb" Text="Ten chlap z té zemnice mě hned napadl. A já se mu nezvládl ubránit. Naštěstí jsem ale přežil." />
						</EnumLog>
						<EnumLog Type="Completed" Name="PomatenecKilled">
							<Log StringName="vyres_sit_nemel_jsem_nala_FTAi" Text="Neměl jsem náladu se s tím chlapem bavit, takže jsem se ho na nic neptal." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="HutExplorationState" Name="prozkoumej_zemnici_a_okoli">
					<LocalizedName StringName="pomatenec_prozkoumej_zemn_n39G" Text="Prozkoumej zemnici a okolí." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="areaSearching">
							<Log StringName="prozkoume_i_kdyz_tu_nekdo_1o4y" Text="Sice to tady nebylo tak opuštěné, ale ještě se kolem té zemnice porozhlédnu. Co tak mohl Vojtěch chtít, abych tady viděl?" />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="prozkoume_prohledl_jsem_s_KRco" Text="Prohlédl jsem si zemnici a její okolí a bylo tady pár zajímavostí, na které bych se měl Vojtěcha zeptat. Byly snad tohle věci, kvůli kterým mě sem poslal? A měl bych si s ním promluvit i o tom bláznovi, kterého jsem tady potkal." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressAfterMeetCrazy" Name="promluv_si_s_vojtechem">
					<LocalizedName StringName="pomatenec_promluv_si_s_vo_YsLS" Text="Promluv si s Vojtěchem." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="TalkedWith" Marker="malirSoul">
							<Log StringName="promluv_s_mel_bych_zajit__rrIy" Text="Měl bych zajít zpátky za Vojtěchem a říct mu, co jsem u té zemnice viděl a o tom bláznovi, co v ní bydlí. A doufám, že se o Vojtěchovi konečně něco dozvím." />
						</EnumLog>
						<EnumLog Type="Started" Name="Killed" Marker="malirSoul">
							<Log StringName="promluv_s_mel_bych_zajit__v33q" Text="Měl bych zajít zpátky za Vojtěchem a říct mu, co jsem u té zemnice viděl a že jsem u ní zabil nějakého blázna. A doufám, že se o Vojtěchovi konečně něco dozvím." />
						</EnumLog>
						<EnumLog Type="Completed" Name="DoneHappy">
							<Log StringName="promluv_s_promluvil_jsem__QF1I" Text="Promluvil jsem si s malířem Vojtěchem a zjistil, že v té zemnici žije jeho dávný kamarád Libor. Sice se už spolu nebaví, ale vypadal, že je rád, že je naživu. &#xD;&#xA;Taky jsem zjsitil, že měl kdysi druhého kamaráda, co se jmenoval Vojtěch. A toho zabil Burkhard! Postupně to do sebe začíná všechno zapadat. No, uvidíme, jestli se někdy dozvím ještě něco dalšího." />
						</EnumLog>
						<EnumLog Type="Completed" Name="DoneSad">
							<Log StringName="promluv_s_promluvil_jsem__gCzp" Text="Promluvil jsem si s Vojtěchem, ale o jeho minulosti se mi nepodařilo zjistit skoro nic. Místo toho se ještě víc uzavřel do sebe. No, teď už s tím nic neudělám." />
						</EnumLog>
						<EnumLog Type="Completed" Name="DoneSuperSad">
							<Log StringName="promluv_s_promluvil_jsem__fxST" Text="Promluvil jsem si s Vojtěchem a ukázalo se, že ten blázen z té zemnice byl jeho kamarád z děství Libor. Bohužel se Libor mým přičiněním oběsil, což teda Vojtěch nese hodně těžce a odmítá se mnou o tom dál mluvit. No, tohle teda nedopadlo moc dobře." />
						</EnumLog>
					</Logs>
				</Objective>
			</Objectives>
