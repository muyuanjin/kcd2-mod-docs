			<QuestDescription StringName="qdesc_malovano_jest_o1nf" Text="Malíř Vojtěch má napilno s přípravou oltáře v Sedleci, takže nemá čas věnovat se svým menším zakázkám. A to ani těm dokončeným, ale nezaplaceným." />
			<Objectives>
				<Objective TypeT="LapisAcquirement" Name="ziskej_malirovu_odmenu">
					<LocalizedName StringName="malovano__ziskej_od_rycht_iHEw" Text="Získej malířovu slíbenou odměnu." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="lapisLazuli">
							<Log StringName="ziskej_ma_rychtar_z_prito_o2xR" Text="Rychtář z Přítok si od malíře Vojtěcha objednal výmalbu jedné ze síní na nové tvrzi. Vojtěch dílo dokončil, ale rychtář odmítl vydat slíbenou platbu - drahokam, lapis lazuli, ze kterého malíř dokáže vyrobit modrou barvu. Vojtěch mě pověřil, abych se za rychtářem vypravil a výplatu z něj nějak dostal." />
						</EnumLog>
						<EnumLog Type="Updated" Name="StartedAgain" Marker="lapisLazuli">
							<Log StringName="ziskej_ma_ziskany_drahoka_jHjO" Text="Získaný drahokam se mi podařilo ztratit. Musím ho získat zpátky a pak ho donést malíři." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Acquired">
							<Log StringName="ziskej_ma_odmenu_kterou_r_0aRs" Text="Odměnu, kterou rychtář z Přítok slíbil malíři Vojtěchovi, se mi podařilo získat. Lapis lazuli, modrý drahokam." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
					</Logs>
				</Objective>
				<Objective TypeT="ProgressAbortable" Name="vylepsi_malirovo_dilo" IsOptional="true">
					<LocalizedName StringName="malovano__premaluj_maliro_zIxV" Text="&quot;Vylepši&quot; malířovo dílo." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="paintingTrigger">
							<Log StringName="premaluj__rychtar_chce_ob_qM15" Text="Rychtář chce malbou pět slávu na Annu z Valdštejna, která stavbu zadala. Nezaplacené dílo ale na nikoho dojem neudělá. Mohl bych o tuhle zásadní informaci dílo vylepšit..." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="premaluj__rychtar_chtel_o_M0kj" Text="Rychtář chtěl malbou pět slávu na Annu z Valdštejna. Nezaplaceným se ale chlubit nedá, takže jsem na malbu tuhle podstatnou drobnost dopsal. Myslím, že to malíře Vojtěcha pobaví a odměna mu chybět nebude." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailableAbortable" Name="najdi_pres_den_adelu_z_mnisku_pobliz_vrby_a_uraz_ji" IsOptional="true">
					<LocalizedName StringName="malovano__najdi_pres_den__638f" Text="Najdi přes den Adélu z Mníšku poblíž vrby a uraž jí." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="adelaChillArea">
							<Log StringName="najdi_pre_rychtar_chce_ud_fhSx" Text="Rychtář chce udělat dojem na šlechtičnu Adélu z Mníšku, kterou sem byla vypravena, aby zkontrolovala průběh stavby. Rychtář vymyslel, že Adélu urazím, zatímco on náhodou půjde kolem a vyzvě mě na souboj. Adéla prý každý den za jasného počasí vysedává pod vrbou před tvrzí, kde kouká na stavbu. Určitě bych jí tam měl najít okolo poledne." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="najdi_pre_rozhodl_jsem_se_5cS5" Text="Rozhodl jsem se spolupracovat s rychtářem a urazil šlechtičnu Adélu, což vedlo k tomu, že mě rychtář vyzval na souboj v obraně její cti." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Failed">
							<Log StringName="najdi_pre_rychtar_chtel_n_6hCX" Text="Rychtář chtěl na Adélu z Mníšku udělat dojem, ale spolupracovat s ním a šlechtičnu urážet už nemá smysl. Rychtářův plán s duelem už realizovat nepůjde." />
