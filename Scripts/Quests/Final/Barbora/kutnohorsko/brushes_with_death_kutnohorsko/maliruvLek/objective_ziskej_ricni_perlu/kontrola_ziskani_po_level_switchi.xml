<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="kontrola_ziskani_po_level_switchi">
			<Ports>
				<Port Name="ondlcwake" Direction="In" Type="trigger">
					<DesignName StringName="kontrola__ondlcwake_zyLQ" Text="OnDLCWake" />
				</Port>
				<Port Name="objective_state" Direction="In" Type="Perla">
					<DesignName StringName="kontrola__objective_state_TcL4" Text="Objective state" />
				</Port>
				<Port Name="perla_ziskana" Direction="Out" Type="trigger">
					<DesignName StringName="kontrola__perla_ziskana_yTQ9" Text="Perla získána" />
				</Port>
			</Ports>
			<Nodes>
				<HasItems_Soul Name="HasItems_Soul" PositionY="80" PositionX="240" Namespace="utils.item">
					<Asset Name="soul" Alias="player" />
					<Constant Name="amount" Value="1" />
					<Edge From="konstanty_maliruv_lek.item_ricni_perla" To="itemclass" />
				</HasItems_Soul>
				<If Name="if3" PositionY="-70" PositionX="240">
					<Edge From="ondlcwake" To="Exec" />
					<Edge From="switch2.Value1" To="Condition" />
				</If>
				<If Name="if4" PositionY="-70" PositionX="600">
					<Edge From="HasItems_Soul.hasitems" To="Condition" />
					<Edge From="if3.True" To="Exec" />
				</If>
				<konstanty_maliruv_lek Name="konstanty_maliruv_lek" PositionY="230" PositionX="-130" Namespace="library_maliruv_lek" />
				<Output Name="Output">
					<Edge From="if4.True" To="perla_ziskana" />
				</Output>
				<Switch Name="switch2" PositionY="30" PositionX="-130" TypeT="Perla" ValueTypes="bool" SwitchValues="Active Retry">
					<Constant Name="ActiveValue1" Value="true" />
					<Constant Name="RetryValue1" Value="true" />
					<Constant Name="DefaultValue1" Value="false" />
					<Edge From="objective_state" To="Switch" />
				</Switch>
			</Nodes>
			<Text StringName="kontrola_ziskani_perly_po_qWxt" Text="Kontrola získání perly po level switchi" />
		</Module>
	</Skald>
</Database>