			<Text StringName="s138_truhlari_Bq4C" Text="Truhláři" />
			<QuestName StringName="qname_truhlari_djhU" Text="Truhláři" />
			<QuestDescription StringName="qdesc_truhlari_Fd7e" Text="Vojtěch vypadá víc rozrušeně než obvykle. To neznačí nic dobrého. K dokončení svého díla mu už jen schází sošky na oltář, které vyrábí kutnohorští truhláři." />
			<Objectives>
				<Objective TypeT="CarpenterShopVisit" Name="zeptej_se_v_truhlarske_dilne">
					<LocalizedName StringName="s138_truh_zeptej_se_v_dil_XdfI" Text="Zeptej se v truhlářské dílně." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="areaDilna">
							<Log StringName="zeptej_se_musim_se_zeptat_n7dQ" Text="Vojtěch říkal, že dílna truhláře Třísky je u západní brány. Snad bude mistr truhlář schopen říct, jak na tom ty sošky jsou." />
						</EnumLog>
						<EnumLog Type="Updated" Name="TriskaSilent" Marker="areaDilna">
							<Log StringName="zeptej_se_triska_mlzi_mus_QoQI" Text="Tříska mi něco tají. Ale třeba o těch soškách bude vědět někdo jiný v dílně. A nebo to s Třískou budu muset vyřešit po zlém." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="zeptej_se_zjistil_jsem_ze_kxmG" Text="Zjistil jsem, že truhlářům k dokončení oltáře chybí už jenom jedna soška. Naneštěstí ji sebral Chrudoš, jeden z tovaryšů, a šel ji prodat nějakým překupníkům. " />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled" />
						<EnumLog Type="None" Name="Aborted" />
					</Logs>
				</Objective>
				<Objective TypeT="RescueChrudos" Name="osvobod_chrudose" IsOptional="true">
					<LocalizedName StringName="truhlari_promluv_si_s_tov_qYg4" Text="Osvoboď Chrudoše." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="truhlarChrudos">
							<Log StringName="promluv_s_musim_najit_chr_omSs" Text="Chrudoš je sice zloděj, ale kdoví, co mu ti lapkové ještě provedou. Možná bych ho měl osvobodit. " />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="promluv_s_chrudos_mi_slib_EQbe" Text="Chrudoše jsem zachránil. Nikdo by neměl zůstat svázanej v táboře lapků. " />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Died">
							<Log StringName="promluv_s_chrudos_je_mrtv_UmPZ" Text="Chrudoš je bohužel mrtvý, ale stejně by se jako zloděj nemohl vrátit." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="NotRescued">
							<Log StringName="osvobod_c_doplnit_uCGG" Text="Chrudoše jsem nechal v táboře. Stejně je to zloděj." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
						<EnumLog Type="None" Name="DoneNoNotification" />
					</Logs>
				</Objective>
				<Objective TypeT="TalkToChrudos" Name="promluv_si_s_chrudosem" IsOptional="true">
					<LocalizedName StringName="truhlari_promluv_s_chrudo_uAsV" Text="Promluv si s Chrudošem." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="ActiveClear" Marker="truhlarChrudos">
							<Log StringName="promluv_s_s_prekupniky_to_9UEY" Text="S překupníky to po dobrém nešlo. Měl bych si promluvit s Chrudošem." />
						</EnumLog>
						<EnumLog Type="Started" Name="ActiveFleeing" Marker="truhlarChrudos">
							<Log StringName="promluv_s_chrudos_po_osvo_VOaZ" Text="Chrudoš po osvobození utíkal na jih. Řekl, že počká kousek na cestě u spáleného domu, ale pochybuju, že tam bude čekat dlouho. Měl bych si s ním promluvit, než odejde." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="promluv_s_chrudos_mi_pode_mKDW" Text="Chrudoš mi poděkoval za záchranu a odešel." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Panicked" />
						<EnumLog Type="None" Name="Aborted" />
						<EnumLog Type="Canceled" Name="ChrudosDied" />
					</Logs>
				</Objective>
				<Objective TypeT="FindStatue" Name="najdi_vyrezavanou_sosku">
					<LocalizedName StringName="truhlari_najdi_sosku_meXt" Text="Najdi vyřezávanou sošku." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="meetingPlace">
							<Log StringName="najdi_sos_musim_najit_sos_mosx" Text="Musím najít tovaryše Chrudoše a přesvědčit ho, aby vrátil sošku dřív, než ji prodá těm překupníkům. V dílně mi řekli, že měli nějaký potkávací místo u nějakého domu jižně pod Cimburkem. Mám prý jít kolem Cimburka po cestě na Malešov, než dojdu k brodu. Za ním dojít k rozcestí, po kterým mám jít vlevo a pak na soucestí mám jít do lesa na jih. Tam by prý měla být stará chatrč, kde se s těma překupníkama scházeli." />
						</EnumLog>
						<EnumLog Type="Updated" Name="ChrudosAttacked" Marker="searchingArea">
							<Log StringName="najdi_vyr_musim_najit_sos_tvTu" Text="Našel jsem ten dům, ale Chrudoš ani překupníci tu nejsou. Musím je najít a zjistit, co se stalo se soškou k oltáři. Snad najdu nějaké stopy, které mě k nim dovedou." />
						</EnumLog>
						<EnumLog Type="Updated" Name="ChrudosCaptured" Marker="banditCampArea">
							<Log StringName="najdi_vyr_nasel_jsem_chru_iTM9" Text="Našel jsem Chrudoše. Je uvázaný v táboře lapků. Soška je snad někde poblíž." />
						</EnumLog>
						<EnumLog Type="Updated" Name="ChrudosGaveInfo" Marker="banditStash">
							<Log StringName="najdi_vyr_musim_najit_sos_8AZb" Text="Musím najít sošku. Podle Chrudoše ji zamkli banditi do truhly." />
						</EnumLog>
						<EnumLog Type="Updated" Name="ChrudosDidntGiveInfo" Marker="banditCampArea">
							<Log StringName="najdi_vyr_od_chrudose_uz__w6X3" Text="Od Chrudoše už nic nezjistím. Snad bude soška někde v táboře, kde ho drželi." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
