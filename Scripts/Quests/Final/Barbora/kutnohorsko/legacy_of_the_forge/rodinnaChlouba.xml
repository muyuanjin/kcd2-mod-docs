			<Text StringName="u201_rodinna_chlouba_p6vL" Text="Rodinná chlouba" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="rodinnach_jindra_se_od_mi_F3KU" Text="Jindra se od mistra Klause Eichnera dozvídá, že dávného kamaráda svého otce Martina Standu Mouchu najde u Hořanských dolů, kde pracuje jako kovář. Doufá, že se od něj dozví podrobnosti o opravě orloje. Jenže Moucha je v problémech, dluží peníze jednomu ze strážných, což musí Jindra vyřešit. Moucha mu pak poví historii opravy orloje a navede ho na kutnohorského písaře Vettera, jehož rodina vlastní Srdce orloje, které kdysi ve Škodově kovárně vyrobili a bylo jim ukradeno, jen si myslí, že jde o nějaký starobylý artefakt. Jindra ho musí od písaře získat a odnést do kovárny. Pak si může o dalších krocích promluvit s Magdalénou (navazuje U202). V tomto questu se rovněž odemkne možnost najmout Mouchu do platnéřské dílny." />
				</GameplayActionElement>
				<NotificationElement>
					<Text StringName="rodinnach_pijavice_PZWq" Text="Pijavice" />
				</NotificationElement>
			</Elements>
			<QuestName StringName="qname_u201_rodinna_chlouba_v2Kr" Text="Martinův sen" />
			<QuestDescription StringName="qdesc_u201_rodinna_chlouba_bHQ3" Text="Pokouším se najít tovaryše a kamaráda mého otce Standu Mouchu, abych se dozvěděl víc o opravě kutnohorského orloje." />
			<Objectives>
				<Objective TypeT="ProgressUpdated" Name="najdi_byvaleho_tovaryse_standu_mouchu">
					<LocalizedName StringName="rodinna_c_hledej_mouchu_uDDv" Text="Najdi bývalého tovaryše Standu Mouchu." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="horanskoArea">
							<Log StringName="najdi_byv_od_cechmistra_k_KGVx" Text="Od cechmistra Klause Eichnera jsem se dozvěděl, že bývalý Škodův tovaryš a kamarád mého otce Martina Standa zvaný Moucha pracuje u hořanských dolů jako kovář. Měl bych ho vyhledat a zeptat se ho na tehdejší opravu orloje." />
						</EnumLog>
						<EnumLog Type="Updated" Name="Updated" Marker="horanskoSmallArea">
							<Log StringName="najdi_byv_od_kovare_u_hor_a0sY" Text="Od kováře u hořanských dolů jsem se dozvěděl, že bývalý Škodův tovaryš a kamarád mého otce Martina Standa zvaný Moucha v současné době pracuje v dole jako havíř a bydlí kousek nad dvorcem. Měl bych ho vyhledat a zeptat se ho na tehdejší opravu orloje." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="najdi_byv_u_horanskych_do_g6uu" Text="U hořanských dolů jsem našel bývalého Škodova tovaryše a kamaráda mého otce Martina Standu zvaného Moucha. Po úrazu ruky ztratil práci v kovárně a v současnosti se živil jako havíř." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="Progress" Name="promluv_s_mouchou">
					<LocalizedName StringName="rodinnach_promluv_s_mouch_9J5G" Text="Promluv si s Mouchou." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="moucha">
							<Log StringName="promluv_s_chtel_jsem_se_s_dbwT" Text="Chtěl jsem se Standy zeptat na opravu orloje, ale nebyl schopen se soustředit. Prý ho jeden z důlních strážných šikanuje kvůli dluhu, který není schopen zaplatit. Měl bych si s ním o jeho problému promluvit, jinak se od něj nejspíš nic nedozvím." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done" />
					</Logs>
				</Objective>
				<Objective TypeT="RodinnaChloubaTheProblem" Name="vyres_mouchovy_potize">
					<LocalizedName StringName="rodinnach_vyres_mouchuv_p_zlL9" Text="Vyřeš Mouchovy potíže." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="Sikanator">
							<Log StringName="vyres_mou_chtel_jsem_se_s_dhHw" Text="Chtěl jsem se Standy zeptat na opravu orloje, ale nebyl schopen se soustředit. Prý ho jeden z důlních strážných šikanuje kvůli dluhu, který není schopen zaplatit. Měl bych se pokusit jeho potíže vyřešit. " />
						</EnumLog>
						<EnumLog Type="Updated" Name="ActiveRace">
							<Log StringName="vyres_mou_chtel_jsem_se_s_e5zE" Text="Chtěl jsem se Standy zeptat na opravu orloje, ale nebyl schopen se soustředit. Jeden z důlních stážných ho šikanoval, kvůli dluhu, který nebyl schopen zaplatit. Domluvil jsem se se strážným, že když nad ním vyhraju koňský závod, dluh Standovi odpustí." />
						</EnumLog>
						<EnumLog Type="Updated" Name="ActiveLostRace" Marker="Sikanator">
							<Log StringName="vyres_mou_chtel_jsem_se_s_IGWk" Text="Chtěl jsem se Standy zeptat na opravu orloje, ale nebyl schopen se soustředit. Jeden z důlních stážných ho šikanoval, kvůli dluhu, který nebyl schopen zaplatit. Domluvil jsem se se strážným, že když nad ním vyhraju koňský závod, dluh Standovi odpustí. Jenže závod jsem prohrál. Budu Mouchovy potíže muset vyřešit jinak." />
						</EnumLog>
						<EnumLog Type="Completed" Name="ResolvedNoteOfHand">
							<Log StringName="vyres_mou_chtel_jsem_se_s_6PAs" Text="Chtěl jsem se Standy zeptat na opravu orloje, ale nebyl schopen se soustředit. Jeden z důlních stážných ho šikanoval, kvůli dluhu, který nebyl schopen zaplatit. Jeho potíže se mi podařilo vyřešit." />
						</EnumLog>
						<EnumLog Type="Completed" Name="ResolvedDeadBully">
							<Log StringName="vyres_mou_chtel_jsem_se_s_Ox40" Text="Chtěl jsem se Standy zeptat na opravu orloje, ale nebyl schopen se soustředit. Jeden z důlních stážných ho šikanoval, kvůli dluhu, který nebyl schopen zaplatit. Zbavil jsem ho jeho potíží tím, že jsem zbavil svět člověka, který mu ty potíže způsoboval. " />
						</EnumLog>
						<EnumLog Type="Completed" Name="ResolvedWonRace">
							<Log StringName="vyres_mou_chtel_jsem_se_s_2QvG" Text="Chtěl jsem se Standy zeptat na opravu orloje, ale nebyl schopen se soustředit. Jeden z důlních stážných ho šikanoval, kvůli dluhu, který nebyl schopen zaplatit. Zbavil jsem ho jeho potíží tím, že jsem nad jeho věřitelem vyhrál koňský závod." />
						</EnumLog>
					</Logs>
				</Objective>
