<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="helper_blacksmithing_side_job_progress">
			<Ports>
				<Port Name="pomocnik_prijima_objednavku" Direction="In" Type="trigger">
					<DesignName StringName="helper_bl_pomocnik_prijim_jIw0" Text="Pomocník přijímá objednávku" />
				</Port>
				<Port Name="pomocnik_ktery_bude_objednavku_vyrabet" Direction="In" Type="BlacksmithingHelper">
					<DesignName StringName="helper_bl_pomocnik_ktery__wFT6" Text="Pomocník, který bude objednávku vyrábět" />
				</Port>
				<Port Name="pomocnik_se_kterym_zrovna_jindra_mluvi" Direction="In" Type="BlacksmithingHelper">
					<DesignName StringName="helper_bl_pomocnik_se_kte_quqq" Text="Pomocník, se kterým zrovna Jindra mluví" />
				</Port>
				<Port Name="pomocnik_pracuje_na_objednavce" Direction="Out" Type="bool">
					<DesignName StringName="helper_bl_pomocnik_pracuj_DzPi" Text="Pomocník pracuje na objednávce" />
				</Port>
				<Port Name="pomocnik_dokoncuje_vyrobek" Direction="Out" Type="trigger">
					<DesignName StringName="helper_bl_pomocnik_dokonc_BdFh" Text="Pomocník dokončuje výrobek" />
				</Port>
			</Ports>
			<Nodes>
				<IfFunction Name="ifcompare3" PositionY="-70" PositionX="-290" TypeT="BlacksmithingHelper" MethodName="Control::Compare" DeclaringType="Control">
					<Constant Name="Op" Value="Equals" />
					<Edge From="pomocnik_prijima_objednavku" To="Exec" />
					<Edge From="pomocnik_ktery_bude_objednavku_vyrabet" To="ValueA" />
					<Edge From="pomocnik_se_kterym_zrovna_jindra_mluvi" To="ValueB" />
				</IfFunction>
				<Output Name="Output">
					<Edge From="timer_preparingProduct.OnFinished" To="pomocnik_dokoncuje_vyrobek" />
					<Edge From="timer_preparingProduct.Running" To="pomocnik_pracuje_na_objednavce" />
				</Output>
				<Timer Name="timer_preparingProduct" PositionY="-100" PositionX="10">
					<Constant Name="Duration" Value="24h" />
					<Constant Name="TimeType" Value="WorldTime" />
					<Edge From="ifcompare3.True" To="SetRunning" />
				</Timer>
			</Nodes>
			<Text StringName="helper_blacksmithing_side_HDIJ" Text="Helper blacksmithing side job progress" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="helper_bl_pomocnik_nejako_42oM" Text="Pomocník nějakou dobu pracuje na výrobku, jde jen o obalený timer." />
				</GameplayActionElement>
			</Elements>
		</Module>
	</Skald>
</Database>