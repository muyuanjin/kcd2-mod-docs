							<Log StringName="promluv_s_magdalena_mi_po_uYFU" Text="Magdaléna mi poradila, že jestli to s opravou orloje myslím vážně, měl bych se nejdříve domluvit s kutnohorským rychtářem Andreasen Plümelem." />
