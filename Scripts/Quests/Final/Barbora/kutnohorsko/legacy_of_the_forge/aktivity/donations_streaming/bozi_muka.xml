			</Ports>
			<Definitions>
				<Definition File="bozi_muka/intermissioncheck.xml" />
			</Definitions>
			<Nodes>
				<State Name="boziMukaSoulWasKilled" PositionY="430" PositionX="1200" TypeT="bool">
					<Edge From="deathtrigger1.OnAllDeath" To="SetTrue" />
				</State>
				<SoulDeathTrigger Name="deathtrigger1" PositionY="430" PositionX="850">
					<Asset Name="Souls" Alias="boziMukaSoul" />
					<Edge From="streamprofileshandling.profileactive" To="IsActive" />
				</SoulDeathTrigger>
				<intermissioncheck Name="intermissioncheck" PositionY="277" PositionX="150">
					<Edge From="bozi_muka_tagpoint" To="target" />
					<Edge From="readyToUnstream.State" To="Awake" />
				</intermissioncheck>
				<Output Name="Output">
					<Edge From="streamprofileshandling.profileactive" To="bozi_muka_active_profile" />
					<Edge From="boziMukaSoulWasKilled.State" To="bozimuka_soul_was_killed" />
				</Output>
				<State Name="readyToUnstream" PositionY="370" PositionX="-170" TypeT="bool">
					<Edge From="readytounstream" To="SetTrue" />
					<Edge From="streamprofileshandling.onunloaded" To="SetFalse">
						<Vertex>svLhfeAn</Vertex>
						<Vertex>CK8zLsvT</Vertex>
					</Edge>
				</State>
				<streamprofileshandling Name="streamprofileshandling" PositionY="-44" PositionX="475" Namespace="utils.streaming">
