					<Constant Name="autodeactivatenotificationafterstream" Value="false" />
					<Edge From="stream_bozi_muka" To="streamprofiles" />
					<Edge From="unstream_bozi_muka" To="unstreamprofiles" />
					<Edge From="intermissioncheck.onintermission" To="unstreamprofiles" />
				</streamprofileshandling>
			</Nodes>
			<EdgeVertices>
