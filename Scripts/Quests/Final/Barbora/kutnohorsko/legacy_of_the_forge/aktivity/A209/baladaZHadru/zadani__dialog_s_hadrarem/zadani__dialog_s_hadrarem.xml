				<GameplayActionElement>
					<Text StringName="zadani__d_zaroven_jindrov_hvjj" Text="Zároveň Jindrovi řekne, že nyní mu už prozradí o co jde. Ostatně se to dozví z těch listin a prosí ho, aby zachoval mlčení, že se mu to vyplatí, dostane velkou prestiž." />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="zadani__d_hadrar_rekne_ka_gvM9" Text="Hadrář řekne, kam má odnést peníze." />
