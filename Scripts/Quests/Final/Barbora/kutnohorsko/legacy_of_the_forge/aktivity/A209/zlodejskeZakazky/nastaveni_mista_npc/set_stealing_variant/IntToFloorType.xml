<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="IntToFloorType">
			<Ports>
				<Port Name="floorid" Direction="In" Type="int">
					<DesignName StringName="flooridtr_floorid_Kqet" Text="floorID" />
				</Port>
				<Port Name="floor" Direction="Out" Type="FloorType">
					<DesignName StringName="flooridtr_floor_F9u2" Text="floorType" />
				</Port>
			</Ports>
			<Nodes>
