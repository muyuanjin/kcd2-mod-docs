			<Text StringName="iniciacni_aktivita_a6AC" Text="Sochař bez budoucnosti" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="malir_iniciacni_aktivita_VWg5" Text="Iniciační aktivita zlodějských zakázek. Jindru si zavolá hospodský Škvíra a pošle ho za Hadrářem, který s ním chce mluvit. Ten mu vysvětlí, že si pořídil kovárnu ve zmoklé čtvrti a bylo by dobré myslet na své sousedy menší službou. Zrovna jeden mladý umělec se dostal do potíží. Žárlivý domácí ho vyhodil z domu, jenže tam nechal všechny svoje kresby a nářadí, bez kterého nedokončí zakázku na sochy ve Vlašském dvoře včas. Jindra mu je má pomoci získat." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_malirbezbudoucnosti_VEHp" Text="Sochař bez budoucnosti" />
			<QuestDescription StringName="qdesc_malirbezbudoucnosti_XC5P" Text="Hospodský Škvíra, z hospody nedaleko mojí kovárny, se mnou chce o něčem mluvit a celé to vypadá trochu záhadně, tak snad z toho nekoukají žádné potíže." />
			<Objectives>
				<Objective TypeT="ProgressFailable" Name="jdi_za_skvirou">
					<LocalizedName StringName="iniciacni_jdi_za_skvirou_ulm5" Text="Jdi za Škvírou" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="Skvira">
							<Log StringName="jdi_za_sk_doneslo_se_mi_z_bcpR" Text="Doneslo se mi, že si se mnou chce promluvit můj blízký soused hospodský Škvíra z hostince Díra na dolním rohu ulice, kde stojí moje kovárna." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="jdi_za_sk_promluvil_jsme__6hIE" Text="Promluvil jsme si s hospodským Škvírou a nejsem si jistý, před čím mě vlastně chtěl varovat." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="jdi_za_sk_za_hospodskym_s_9EPY" Text="Za hospodským Škvírou jsem nakonec nezašel." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="promluv_vecer_s_hadrarem">
					<LocalizedName StringName="iniciacni_promluv_s_hadra_ZE0I" Text="Promluv večer s Hadrářem" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="eveningAreaMarker">
							<Log StringName="promluv_v_doufam_ze_mi_vi_PVsq" Text="Doufám, že mi víc prozradí ten tajemný muž, co mu říkají Hadrář. Mám se s ním setkat večer v hospodě U Železného orla. Měl by mít na sobě pěkný modrý klobouk." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="promluv_v_hospodsky_me_po_Yd7P" Text="Hospodský mě požádal, abych se setkal s mužem, kterému se říká Hadrář. Setkal jsem se s ním v hospodě U Železného orla a dost mě překvapil. Nebyl to žádný drban, ale dobře oblečený měšťan. Neřekl mi své pravé jméno ani důvod, proč rozdává chudým jídlo výměnou za staré hadry, ale slíbil, že mi to prozradí až se lépe poznáme. Tuším, že ten člověk je cokoliv jen ne hloupý blázen. V jeho konání se dá tušit skrytý plán." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="promluv_v_na_schuzku_s_ha_aLOv" Text="Na schůzku s Hadrářem jsem nedorazil, takže netuším, co mi vlastně chtěl, ani k čemu by mi to bylo dobré." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="ziskej_socharovy_veci">
					<LocalizedName StringName="iniciacni_ukradni_predmet_mmSb" Text="Získej sochařovy věci" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" IsTracked="true" Marker="kradeniArea">
							<Log StringName="ziskej_ma_hadrar_me_pozad_h4iX" Text="Hadrář mě požádal, abych pomohl jednomu mladému umělci, kterého něšťasné řízení osudu připravilo o budoucnost. Tedy vlastně ještě ne, pořád se ještě dá hodně zachránit. Stačí získat kresby z domu žárlivého měšťana Adama Welvara, před kterým musel mladý Damián uprchnout. Pokud bych přitom našel i sochařovo nářadí a jeho zlatou brož bylo by to skvělé. Všechno by mělo být ve velkém pokoji v prvním patře domu s okny do ulice." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="ziskej_ma_hadrar_me_pozad_jFj2" Text="Hadrář mě požádal o pomoc s jedním nešťastným sochařem Damiánem. Tenhle mladík musel utéct oknem před žárlivým měšťanem Adamem Welvarou, u kterého bydlel. Bohužel tam nechal všechny přípravné kresby na své první velké sochařské dílo pro Vlašský dvůr v Kutné Hoře." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="ziskej_ma_patrani_po_mali_Blil" Text="Pátrání po sochařových věcech jsem nakonec vzdal." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailableAbortable" Name="dones_veci_skvirovi">
					<LocalizedName StringName="iniciacni_dones_item_velv_HYfH" Text="Dones věci Škvírovi" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="Skvira">
							<Log StringName="dones_mal_nastesti_se_mi__TFxa" Text="Naštěstí se mi podařilo všechno najít a nyní to stačí jen odnést hospodskému Škvírovi, aby se už postaral o zbytek. Hospodského najdu v jeho hospodě Díra ve Chmelné, ale neměl bych mu tam lézt po zavíračce." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="dones_mal_nastesti_se_mi__gvVc" Text="Naštěstí se mi podařilo všechny jeho věci najít a odnést hospodkému Škvírovi a on už se postaral o zbytek. Netuším jestli si Damián mohl za svou smůlu sám, ale podle jeho kreseb hádám, že by byla velká škoda, kdyby ty nové sochy ve Vlašském dvoře nedokončil." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Failed">
