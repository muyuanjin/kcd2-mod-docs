			<Text StringName="hrisnilide_SwpB" Text="Hříšní lidé kutnohorští" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="hrisnilide_hadrar_zada_ji_KIDM" Text="Hadrář zadá Jindrovi choulostivou žádost. Je potřeba vyměnit dodatek k závěti, která se druhý den ráno bude vypořádávat. Nebožtík se na smrtelné posteli rozhodl odkázat část majetku hornickým sirotkům, ale chamtivý bratranec podplatil kněze, aby to zapřel a nikdo jiný u toho nebyl. Kněze dohnalo svědomí a požádal Hadráře o pomoc. Jindra tedy zachraňuje hned dvě hříšné duše před peklem." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_hrisnilide_eY7c" Text="Hříšní lidé kutnohorští" />
			<QuestDescription StringName="qdesc_hrisnilide_xnSV" Text="Všichni lidé jsou hříšní, bohatí si myslí, že můžou cokoliv a chudí už často nemají co ztratit. Člověk by se proto měl snažit pomáhat tam, kde to má smysl, snad se potom svět stane o něco lepším místem k životu." />
			<Objectives>
				<Objective TypeT="ChangeDocument" Name="vymen_listinu_na_tvrzi">
					<LocalizedName StringName="hrisnilide_vymen_dokument_eCOl" Text="Vyměň listinu na tvrzi" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="areaMarker">
							<Log StringName="vymen_lis_jeden_knez_vyhl_yPUL" Text="Jeden kněz vyhledal Hadráře, protože jeho duši tíží velmi těžký hřích, zapřel totiž poslední vůli bohatého nebožtíka, který na smrtelné posteli odkázal svůj majetek vdovám a havířským sirotkům. Nechal se uplatit lakomým dědicem. Později ho svědomí tížilo natolik, že sepsal falešnou listinu. Nyní je potřeba ji vyměnit za pravou, která prý leží na dřevěném pulpitu v prvním patře věže přítocké tvrze." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="vymen_lis_jeden_knez_vyhl_tRQJ" Text="Jeden kněz vyhledal Hadráře, protože jeho duši tížil velmi těžký hřích, zapřel totiž poslední vůli bohatého nebožtíka, který na smrtelné posteli odkázal svůj majetek vdovám a havířským sirotkům. Nechal se uplatit lakomým dědicem. Později ho svědomí tížilo natolik, že sepsal falešnou listinu. Tu se mi podařilo na přítocké tvrzi obratně vyměnit za pravý pergamen." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="vymen_lis_jeden_knez_vyhl_5Bx9" Text="Jeden kněz vyhledal Hadráře, protože jeho duši tížil velmi těžký hřích, zapřel totiž poslední vůli bohatého nebožtíka, který na smrtelné posteli odkázal svůj majetek vdovám a havířským sirotkům. Nechal se uplatit lakomým dědicem. Později ho svědomí tížilo natolik, že sepsal falešnou listinu a chtěl, abych ji vyměnil za pravou, ale odmítnul jsem." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="TimedOut">
							<Log StringName="vymen_lis_jeden_knez_vyhl_Sozt" Text="Jeden kněz vyhledal Hadráře, protože jeho duši tížil velmi těžký hřích, zapřel totiž poslední vůli bohatého nebožtíka, který na smrtelné posteli odkázal svůj majetek vdovám a havířským sirotkům. Nechal se uplatit lakomým dědicem. Později ho svědomí tížilo natolik, že sepsal falešnou listinu a chtěl abych ji vyměnil za pravou. Bohužel se mi to nepodařilo, než byla závěť zaknihována." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="SeenByDocumentChange">
							<Log StringName="vymen_lis_videli_me_jak_v_jujK" Text="Jeden kněz vyhledal Hadráře, protože jeho duši tížil velmi těžký hřích, zapřel totiž poslední vůli bohatého nebožtíka, který na smrtelné posteli odkázal svůj majetek vdovám a havířským sirotkům. Nechal se uplatit lakomým dědicem. Později ho svědomí tížilo natolik, že sepsal falešnou listinu a chtěl abych ji vyměnil za pravou. Bohužel mě u toho viděli a celý plán tím selhal." />
						</EnumLog>
					</Logs>
