				<Objective TypeT="FindAlmuznik" Name="ziskej_listiny_od_almuznika">
					<LocalizedName StringName="balada_z__najdi_almuznika_WH4i" Text="Získej listiny od almužníka" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" IsTracked="true" Marker="area_findAlmuznik">
							<Log StringName="najdi_alm_ti_zatraceni_mi_EhLs" Text="Ti zatracení mizerové mě podrazili a chvíli předtím, než jsem přišel, obě ukradené Hadrářovy listiny prodali klášternímu almužníkovi. Řekli mi, že má na sobě bílou kutnu a výrazný červený klobouk. Odešel prý městskou branou směrem na velké kutnohorské náměstí. Pokud chci zachránit, co se dá, musím ho najít dřív, než mně nadobro zmizí." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="najdi_alm_ti_zatraceni_mi_WjZi" Text="Ti zatracení mizerové mě podrazili a chvíli předtím, než jsem přišel, tak dopis i královskou listinu prodali klášternímu almužníkovi. Pokud jsem chtěl zachránit, co se dalo, musel jsem ho jít rychle najít. Štěstí mi přálo a bratra Gerlasia jsem podle popisu těch dvou mizerů ve městě našel a získal od něj, co jsem potřeboval." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="AlmuznikLeavedLevel">
							<Log StringName="najdi_alm_ti_zatraceni_mi_CNf1" Text="Bohužel se mně nepodařilo získat ukradené Hadrářovy listiny zpátky a sedlecký opat se tak nejspíš dozvěděl, co měl Johan Krumphanzl, zvaný Hadrář, tajně v plánu." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="KilledAlmuznik">
							<Log StringName="ziskej_li_hledaneho_almuz_6CYg" Text="Hledaného almužníka jsem nekřesťansky zabil, takže nyní už stačí ho jenom prohledat, jestli má u sebe listiny, které hledám." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="KilledHadrar">
							<Log StringName="ziskej_li_nejak_spatne_se_ghIK" Text="Nějak špatně se to seběhlo a Hadrář už nežije, takže jeho listiny už mu jsou platné jako mrtvému nové boty." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="FailedSkillcheck">
							<Log StringName="ziskej_li_nepodarilo_se_m_Ew4H" Text="Nepodařilo se mi klášterního Almužníka Gerlasia přesvědčit, budu muset najít jiný způsob jak od něj ty zpropadené listiny získat." />
						</EnumLog>
