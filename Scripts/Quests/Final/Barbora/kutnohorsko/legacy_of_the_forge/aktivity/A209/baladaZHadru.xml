			<Text StringName="balada_z_hadru_9F9K" Text="Balada z hadrů" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="baladazha_hadrar_si_zavol_s5Ik" Text="Hadrář si zavolá Jindru, protože má problémy. Okradli ho, vzali mu důležitý dopis a smlouvu, která ho může usvědčit z toho, co plánuje. Především, pokud se tyto věci dostanou do rukou kláštera a jeho opata. Vyděrači se ozvali, kam má přinést peníze, aby dostal věci zpátky. Jenže tam nechce jít, aby neprolomil svoje inkognito." />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="baladazha_jindra_odnese_v_2ngR" Text="Jindra odnese výkupné, ale dva vyděrači mu podle řeknou, že už to předali klášternímu almužníkovi s červenou čepicí. Jindra si ho má najít, jestli chce." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_baladazhadru_oqIT" Text="Hříšní lidé kutnohorští" />
			<QuestDescription StringName="qdesc_baladazhadru_bAoN" Text="Všichni lidé jsou hříšní, bohatí si myslí, že můžou cokoliv a chudí už často nemají co ztratit. Člověk by se proto měl snažit pomáhat tam, kde to má smysl, snad se potom svět stane o něco lepším místem k životu." />
			<Objectives>
				<Objective TypeT="ProgressFailable" Name="setkej_se_s_vyderaci">
					<LocalizedName StringName="balada_z__jdi_na_misto_se_nVpY" Text="Setkej se s vyděrači" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="area_meetingPoint">
							<Log StringName="predej_vy_hadrar_vlastnim_vraD" Text="Hadrář, vlastním jménem Johan, dělá kolem sebe velké tajnosti, protože má velkolepý obchodní plán. Škoda, že mi ho neprozradil dřív, možná bych zvážil, zda by se v mojí kovárně nenašlo místo i na jeho papírnu. Johan totiž chce ze starých hadrů dělat papír, který je mnohem levnější, než pergamen vyráběný v klášterech. To je také důvod, proč se Johan obává, že by mu to mniši mohli chtít překazit. Takže když mu nyní zmizely důležité listiny, je odhodlaný získat je zpátky za každou cenu. Požádal mě, abych vyděračům odnesl tučné výkupné." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="jdi_na_mi_nasel_jsem_vyku_0sww" Text="Hadrář, vlastním jménem Johan, dělal kolem sebe velké tajnosti, protože měl velkolepý obchodní plán. Škoda, že mi ho neprozradil dřív, možná bych zvážil, zda by se v mojí kovárně nenašlo místo i na jeho papírnu. Johan totiž chtěl ze starých hadrů dělat papír, který je mnohem levnější, než pergamen vyráběný v klášterech. To byl také důvod, proč se Johan obával, že by mu to mniši mohli chtít překazit. Takže když mu zmizely důležité listiny, byl odhodlaný získat je zpátky za každou cenu. Požádal mě, abych vyděračům odnesl tučné výkupné." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="predej_vy_hadrar_vlastnim_WKQT" Text="Hadrář, vlastním jménem Johan, dělal kolem sebe velké tajnosti, protože měl velkolepý obchodní plán a chtěl ze starých hadrů dělat papír. Ten je mnohem levnější, než pergamen vyráběný v klášterech. To byl také důvod, proč se Johan obával, že by mu to mniši mohli chtít překazit. Takže když mu zmizely důležité listiny, byl odhodlaný získat je zpátky. Požádal mě, abych vyděračům odnesl tučné výkupné. Odmítl jsem to, nechtěl jsem se namočit do něčeho podezřelého." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="vytriskej_to_z_nich">
