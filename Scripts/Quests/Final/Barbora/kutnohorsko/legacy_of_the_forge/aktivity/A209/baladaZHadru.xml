					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="fighters">
							<Log StringName="vytriskej_rozhodl_jsem_se_nyuQ" Text="Rozhodl jsem se z vyděračů dostat informaci o ukradených listinách silou. Jenom je nesmím zabít, to by mi toho už moc neřekli." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="vytriskej_rozhodl_jsem_se_vS5t" Text="Rozhodl jsem se z vyděračů dostat informaci o ukradených listinách silou. Nebylo to lehký, ale nakonec zazpívali komu je nedávno prodali." />
						</EnumLog>
