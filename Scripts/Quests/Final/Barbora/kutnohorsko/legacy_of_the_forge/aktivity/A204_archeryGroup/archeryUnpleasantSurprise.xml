			<Notes>
				<Note Name="note3" PositionY="280" PositionX="2290">
					<Text StringName="archeryun_note3_Oznn" Text="Kafka je mladším ze dvou sourozenců, jeho starší brácha Brada vedl skupinu amatérských lupičů, kteří sem tam se scházeli a dělali drobnější fachy. Loupili, okrádali a nebáli se i mordu. Po nějakém čase chtěl s tím Kafka seknout a dohodnul se s bráchou, že on už taky našetřil dost. Kafka se dohodnul, že si půjčí od Brady peníze a založí si truhlářskou živnost v Kutné Hoře. Začal se živit jako lukař.&#xD;&#xA;Po nějakém čase měl peníze i s úrokem vrátit, což taky udělal ale Bradu hned potom sebrali. Banda si proto myslí, že Kafka svého bráchu udal a žádné peníze mu nedal. Nyní ho nový vůdce bandy Koniáš vydírá a chce po něm peníze i s úroky zpátky. &#xD;&#xA;Pravda je, že Koniáš bandu trochu víc zprofesionalizoval a začal pracovat mnohem tvrději jako lapka. Taky je tajemstvím, že ten kdo udal Bradu je Koniáš, protože věděl o tom, že bráchové chtějí s loupením seknout a bál se, že ukradnou prachy a potopí zbytek party. Koniáš proto udal místo, kde rychtář najde Bradu. Kam se poděli peníze ovšem neví nikdo, Brada je stihnul ukrýt nedlouho před dopadením poblíž místa, kde se setkal s Kafkou. A tam jsou peníze doposud." />
				</Note>
			</Notes>
			<Text StringName="archery_unpleasant_surpri_X98o" Text="Nemilé překvapení" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="archeryun_jindra_jde_se_z_dqmn" Text="Jindra jde se zadavatelem do barborského lomu, kde ale probíhá přepadení Kafky. Ten se kryje před lupiči, kteří ho odstřelují z kamenického lešení. Zadavatel odběhne pro pomoc do města. Pokud Jindra pomůže Kafkovi, má následně rozhovor s Kafkou, kde se dozví, že si na něj banda zasednula." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_archeryunpleasantsu_TqMn" Text="Kutnohorští ostrostřelci" />
			<QuestDescription StringName="qdesc_archeryunpleasantsu_dlZC" Text="Člověk nemůže být pořád jenom v dílně u kovadliny. Někdy je potřeba zajít mezi lidi a strávit společné chvíle s dalšími mistry a tovaryši." />
			<Objectives>
				<Objective TypeT="ProgressFailableAbortable" Name="zazen_utocniky">
					<LocalizedName StringName="archeryun_p_rozstrilej_vs_VJJX" Text="Zažeň útočníky!" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" IsTracked="true">
							<Log StringName="zazen_uto_jak_je_videt_ta_9dxf" Text="Jak je vidět, tak se Kafka dostal do pěkné šlamastyky. Vypadá to, že ti mizerové ho překvapili a teď si s ním hrají jako kočka s myší. Budu jim muset ukázat, kdo je tady pánem střelnice!" />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="zazen_uto_kafka_se_na_str_ISMa" Text="Kafka se na střelnici v barborském lomu dostal do potíží. Tlupa mizerů ho tam překvapili a pěkně podusila. Netuším o co přesně šlo, ale ti lotři dostali, co zasloužili." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Failed">
							<Log StringName="zazen_uto_o_kafkovy_probl_mMsG" Text="O Kafkovy problémy jsem se dál nestaral, takže nevím, proč ho ti mizerové v lomu přepadli." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
					</Logs>
				</Objective>
				<Objective TypeT="ProgressAbortable" Name="promluv_s_kafkou">
					<LocalizedName StringName="archeryun_p_pokecej_s_roz_2Agb" Text="Promluv s Kafkou" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="kafka">
							<Log StringName="promluv_s_rad_bych_zjisti_bsRh" Text="Rád bych zjistil, o co tady šlo a ty mrtvoly kolem, mně to určitě neřeknou. Měl bych se zeptat Kafky, co ti lotři po něm chtěli." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="promluv_s_mrtvy_maji_tu_h_IaOb" Text="Mrtví mají tu hlavní vlastnost, že nemluví. Zeptal jsem se proto Kafky, co po něm chtěli, protože mi to nepřišlo jako běžné přepadení. Kafka přisvědčil, že to není poprvé, co si přišli pro výpalné. Měl jsem trochu pocit, že mi neřekl všechno, ale to už je jeho věc. Od těch darebáků by už měl mít pokoj." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
					</Logs>
				</Objective>
			</Objectives>
