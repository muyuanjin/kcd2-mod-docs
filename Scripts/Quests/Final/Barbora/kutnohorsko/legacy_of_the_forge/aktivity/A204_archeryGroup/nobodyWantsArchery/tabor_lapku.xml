					<Text StringName="tabor_lap_2_hrac_ma_oba_d_PWkV" Text="2. Hráč má oba dopisy a přesvědčí Koniáše, že by měl nechat Kafku být, jinak se ostatní lapkové dozví, že to byl on, kdo udal Bradu;" />
				</GameplayActionElement>
				<GameplayActionElement>
