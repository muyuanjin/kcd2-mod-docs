			<Elements>
				<GameplayActionElement>
					<Text StringName="initialar_jindra_je_posla_gdif" Text="Jindra je poslán tipsterem za cechmistrem Gottfriedem aus Steyr, který má přátelský rozhovor při kterém ho pozve střílet. Prvně má zajít za jeho českým tovaryšem Brůnou, který ho prý vezme na novou střelnici. Jenže tam dojde ke konfrontaci s řezníkem Matějem a soutěži ve střelbě. Výsledek může být různý, ale vždy dojde ke smíru." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_initialarchery_6ehE" Text="Příjemná kratochvíle" />
			<QuestDescription StringName="qdesc_initialarchery_5WTf" Text="Čeká mě návštěva u dalšího cechmistra, tentokrát mistra Gottrieda aus Steyr. Doufám, že půjde veskrze o příjemné setkání." />
			<Objectives>
				<Objective TypeT="ProgressFailable" Name="promluv_si_s_brunou">
					<LocalizedName StringName="initialar_p_promluv_si_s__fDq0" Text="Promluv si s Brůnou" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="zadavatel">
							<Log StringName="promluv_s_mistr_gottfried_h4HX" Text="Mistr Gottfried, zdá se, si umí pěkně užívat života, ale vedle dobrého jídla a pití,  je i velkým nadšencem do střelby z kuší a luků. Ve městě je to prý oblíbená kratochvíle mnoha tovaryšů i mistrů. Pozval mě, abych se také přidal. Nejdřív to ale mám zkusit s jeho tovaryšem Brůnou, abych někdy v budoucnu mohl změřit síly i s ním." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="promluv_s_mistr_gottfried_qEBL" Text="Mistr Gottfried si uměl užívat života, ale vedle dobrého jídla a pití, byl i velkým nadšencem do střelby z kuší a luků. Ve městě to byla oblíbená kratochvíle mnoha tovaryšů i mistrů. Pozval mě, abych se také přidal. Nejdřív jsem to měl zkusit s jeho tovaryšem Brůnou, abych někdy v budoucnu mohl změřit síly i s ním." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="promluv_s_mistr_gottfried_JxLu" Text="Mistr Gottfried si uměl užívat života, ale vedle dobrého jídla a pití, byl i velkým nadšencem do střelby z kuší a luků. Ve městě to byla oblíbená kratochvíle mnoha tovaryšů i mistrů. Pozval mě, abych se také přidal, ale odmítl jsem to." />
						</EnumLog>
					</Logs>
				</Objective>
