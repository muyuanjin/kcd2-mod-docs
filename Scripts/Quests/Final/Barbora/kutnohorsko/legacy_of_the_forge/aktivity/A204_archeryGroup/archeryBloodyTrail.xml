					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="zadavatel">
							<Log StringName="promluv_s_meli_bychom_si__AWHX" Text="Měli bychom si jít zastřílet, kvůli tomu jsme sem přece původně s Jardou přišli." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="promluv_s_nakonec_jsme_se_JgQy" Text="Nakonec jsme se bohužel ke střílení už nedostali. Jarda se bál, že by si na nás mohli počkat další lotři. Snad si to brzy vynahradíme." />
						</EnumLog>
