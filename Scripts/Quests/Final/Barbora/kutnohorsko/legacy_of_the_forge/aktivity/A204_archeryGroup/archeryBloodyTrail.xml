					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="kafka">
							<Log StringName="p_vrat_se_p_uz_je_to_doce_l9ZE" Text="Už je to docela dlouho, co jsem se pokusil pomoci truhláři Kafkovi najít zloděje, kteří ho okradli. Možná bych se za ním měl vrátit a říct mu, že se mně je nepodařilo najít." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="p_vrat_se_p_promluvil_jse_dylH" Text="Promluvil jsem si s Kafkou, ale je škoda, že jsem ty lapky nenašel..." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
