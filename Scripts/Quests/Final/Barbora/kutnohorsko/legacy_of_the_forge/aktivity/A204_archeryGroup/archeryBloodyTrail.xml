					<LocalizedName StringName="archerybl_p_dones_kusi_br_HL44" Text="Vrať Kafkovi kuši" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="kafka">
							<Log StringName="vrat_kafk_ti_dva_darebaci_ejK8" Text="Ti dva darebáci pobrali, co na střelnici bylo a navíc přibrali i kuši, kterou by bylo dobré vrátit majiteli." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="vrat_kafk_co_ti_darebaci__jSym" Text="Co ti darebáci ukradli jsem vrátil Kafkovi. Nečekal to a přes svůj bídný stav byl rád, že aspoň v něčem mu dneska přálo štěstí." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Failed">
							<Log StringName="vrat_kafk_ukradenou_kusi__UDmw" Text="Ukradenou kuši jsem Kafkovi nevrátil a nechal si ji pro sebe." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
					</Logs>
				</Objective>
				<Objective TypeT="ProgressAbortable" Name="promluv_s_jardou">
