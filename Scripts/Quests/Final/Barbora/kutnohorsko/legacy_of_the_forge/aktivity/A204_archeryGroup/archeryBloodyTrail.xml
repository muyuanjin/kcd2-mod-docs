			<Elements>
				<GameplayActionElement>
					<Text StringName="archerybl_jindra_se_zadav_Q3rq" Text="Jindra se zadavatelem jdou opět na střelnici v barborském lomu, ale rozhodčí Kafka zde chybí. Hráč ho jde hledat, najde ho nedaleko, kde je zraněný a volá o pomoc. Hráč ho může ošetřit a dostat tak víc prestiže. Kafka řekne, že ho přepadli, okradli ho a kam běželi. Hráč dostane area marker ve kterém může najít dva lupiče. Kafka chce vrátit jeho kuši, kterou mu vzali. Podle toho co hráč udělá dostane prestiž." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_archerybloodytrail_UjsO" Text="Kutnohorští ostrostřelci" />
			<QuestDescription StringName="qdesc_archerybloodytrail_0cEP" Text="Člověk nemůže být pořád jenom v dílně u kovadliny. Někdy je potřeba zajít mezi lidi a strávit společné chvíle s dalšími mistry a tovaryši." />
			<Objectives>
				<Objective TypeT="ProgressAbortable" Name="najdi_kafku">
					<LocalizedName StringName="archerybl_zjisti_co_se_st_LuaX" Text="Najdi Kafku" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="searchArea">
							<Log StringName="zjisti_co_musim_najit_bre_19w5" Text="Na střelnici v lomu chybí rozhodčí Kafka. Mohli bychom si zastřílet i bez něj, ale lepší bude se po něm podívat, přece jenom, co kdyby se mu něco stalo." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="zjisti_co_nasel_jsem_ho_sZOO" Text="Na střelnici v lomu chyběl rozhodčí Kafka. Mohli jsme si zastřílet i bez něj, ale nedalo nám to a šli jsme se po něm podívat. Na místě totiž bylo více stop, které ukazovali nato, že se mu mohlo něco stát. Našel jsem ho o něco dál, chudák ležel zmlácený mezi skalami, očividně ho někdo přepadl." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
					</Logs>
				</Objective>
				<Objective TypeT="BloodTrail_Crossbow" Name="ziskej_kafkovu_kusi_obsolete">
					<LocalizedName StringName="archerybl_p_najdi_utocniky_3gJ9" Text="Získej Kafkovu kuši obsolete" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="None" Name="Bandit" />
						<EnumLog Type="Started" Name="BanditObjective" Marker="banditsArea">
							<Log StringName="p_najdi_u_p_musim_najit_u_nldX" Text="Přepadli ho nějací dva lotři. Sebrali mu jeho památeční kuši společně s výdělkem, co nedávno dostal od cechmistrů, kteří si byli zastřílet před námi." />
						</EnumLog>
						<EnumLog Type="Updated" Name="BanditDeadObjective" Marker="crossbow">
							<Log StringName="p_ziskej__p_lapky_jsem_vy_PGNA" Text="Ti dva lotři nebyli daleko. Místo toho, aby utekli, klidně žvanili na nedaleké pasece. Dobře věděli, že je Kafka nemůže dopadnout. Teď ještě najít tu ukradenou kuši." />
						</EnumLog>
						<EnumLog Type="Completed" Name="PlayerObjective">
							<Log StringName="p_ziskej__p_musim_ziskat__9wRY" Text="Našel jsem kuši, kterou sem už někdy viděl. Podle řemeslné značky by mohla patřit rozhodčímu Kafkovi z barborského lomu. Měl bych mu ji vrátit." />
						</EnumLog>
						<EnumLog Type="None" Name="Player" />
						<EnumLog Type="None" Name="Kafka" />
						<EnumLog Type="None" Name="PlayerEnd" />
						<EnumLog Type="Canceled" Name="BanditEnd">
							<Log StringName="ziskej_ka_p_lapky_jsem_ne_HGC7" Text="Lapky jsem nenašel." />
						</EnumLog>
					</Logs>
				</Objective>
