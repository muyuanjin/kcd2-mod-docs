<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="ArenaBarrier">
			<Ports>
				<Port Name="stream" Direction="In" Type="trigger">
					<DesignName StringName="arenabarr_stream_yHbg" Text="Stream" />
				</Port>
				<Port Name="unstream" Direction="In" Type="trigger">
					<DesignName StringName="arenabarr_unstream_dqmG" Text="Unstream" />
				</Port>
				<Port Name="profileactive" Direction="Out" Type="bool">
					<DesignName StringName="arenabarr_profileactive_jfvt" Text="ProfileActive" />
				</Port>
			</Ports>
			<Nodes>
				<Output Name="Output">
					<Edge From="streamprofileshandling.profileactive" To="profileactive" />
				</Output>
				<SetGameContext Name="setgamecontext6" PositionY="200" PositionX="330">
					<Constant Name="Context" Value="global_deterrentAreasActive" />
					<Edge From="streamprofileshandling.profileactive" To="IsActive" />
				</SetGameContext>
				<streamprofileshandling Name="streamprofileshandling" PositionY="-100" PositionX="-10" Namespace="utils.streaming">
					<Asset Name="profiles" Alias="barriers" />
					<Constant Name="autodeactivatenotificationafterstream" Value="false" />
					<Edge From="stream" To="streamprofiles" />
					<Edge From="unstream" To="unstreamprofiles" />
				</streamprofileshandling>
			</Nodes>
			<Assets>
				<ProfileAsset Name="barriers" AssetProfiles="dlc2_duels_barriers" />
			</Assets>
			<Text StringName="arenabarrier_2VEl" Text="ArenaBarrier" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="arenabarr_bariery_kolem_o_qoVq" Text="Bariery kolem ohradek, kde hrac bojuje (ani npc, ani hrac nemohou odejit). Pokud v ohradce je NPC, tak ho teleportuje ven deterrent area" />
				</GameplayActionElement>
			</Elements>
		</Module>
	</Skald>
</Database>