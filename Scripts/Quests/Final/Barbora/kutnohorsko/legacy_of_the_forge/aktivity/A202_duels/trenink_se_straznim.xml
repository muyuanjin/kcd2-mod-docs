			<Elements>
				<GameplayActionElement>
					<Text StringName="trenink_s_duel_se_strazni_cK5v" Text="Duel se straznim s halapartnou, ktery probiha za mestem v Mezholezsku. Po combatu pribehne zenska a poprosi o pomoc, banditi prepadli karavanu. Hrac muze pomoct nebo odejit." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_trenink_se_straznim_tvCJ" Text="Přátelské klání" />
			<QuestDescription StringName="qdesc_trenink_se_straznim_TOjO" Text="Potkal jsem strážného, který měl halapartnu, tak jsem ho vyzval na přátelský duel. Ostatně, proti halapartně nemám šanci bojovat každý den." />
			<Objectives>
				<Objective TypeT="TreninkSeStraznim_Duel" Name="zabojuj_si_se_straznym">
					<LocalizedName StringName="trenink_s_zbij_oponenta_8OGa" Text="Zabojuj si se strážným." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="Strazni">
							<Log StringName="poraz_str_zkusit_si_boj_p_S3la" Text="Strážný souhlasil, ale museli jsme jít za město, aby nás u toho nikdo neviděl. Každopádně už jsme na místě. Snad to zvládnu." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="poraz_str_tak_je_po_boji__Vwbe" Text="Tak, je po boji, ale vypadá to, že se něco děje. Přiběhla nějaká ženská a volá o pomoc." />
						</EnumLog>
						<EnumLog Type="Completed" Name="DoneNoHelp">
							<Log StringName="poraz_str_tak_je_po_boji__RaIT" Text="Tak, je po boji, ale něco se děje. Přiběhla nějaká ženská a volá o pomoc. Vypadá to, že strážný bude mít práci, ale já se do toho plést nebudu." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="bez_s_zenou_na_misto_prepadeni">
					<LocalizedName StringName="trenink_s_bez_za_zenskou_6e1j" Text="Běž s ženou na místo přepadení!" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="ZenaZPrepadeni">
							<Log StringName="bez_s_zen_vypada_to_ze_pa_bdxg" Text="Vypadá to, že patří ke karavaně a přepadli ji. Strážný se do toho hned pustil, tak jsem ho v tom nechtěl nechat. " />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="bez_s_zen_no_to_je_neco_n_Wbvp" Text="No to je něco! Nějaká banda přepadla karavanu a už se tu řežou!" />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="bez_s_zen_vypada_to_ze_pa_JNl2" Text="Vypadá to, že patří ke karavaně a přepadli ji, ale naštěstí je tu strážný, aby pomohl. Však on je tou svojí halapartnou srovná." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="zabij_lapky">
					<LocalizedName StringName="trenink_s_zabij_vsech_ban_b3cR" Text="Zabij lapky!" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="enemies">
							<Log StringName="zabij_lap_dam_tem_zmetkum_GpiL" Text="Dám těm zmetkům, co proto!" />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="zabij_lap_tak_i_tenhle_bo_Cl2y" Text="Tak i tenhle boj mám za sebou. Zatracení banditi!" />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="zabij_lap_chtel_jsem_stra_rsBQ" Text="Chtěl jsem strážnému pomoct, ale něco mi do toho vlezvlo." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="promluv_se_zenou">
					<LocalizedName StringName="trenink_s_promluv_si_s_ze_jouY" Text="Promluv se ženou." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="ZenaZPrepadeni">
							<Log StringName="promluv_s_snad_je_ta_zens_SApz" Text="Snad je ta ženská v pořádku. Byl to hroznej masakr. Měl bych se za ní podívat." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="promluv_s_zenska_osetruje_Ubzm" Text="Ženská ošetřuje zraněný a sama vypadá, že je v pořádku. Ta karavana očividně měla ochranku, ale na takovou bandu to nestačilo. Snad se z toho chudák sebere." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="promluv_s_jeste_me_napadl_xnsl" Text="Ještě mě napadlo, že se podívám, jak je na tom ta ženská, ale něco mi do toho vlezlo. Snad ji nic není." />
						</EnumLog>
					</Logs>
				</Objective>
