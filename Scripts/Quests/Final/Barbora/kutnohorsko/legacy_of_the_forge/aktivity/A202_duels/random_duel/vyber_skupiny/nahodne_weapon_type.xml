<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="nahodne_weapon_type">
			<Ports>
				<Port Name="generate" Direction="In" Type="trigger">
					<DesignName StringName="nahodne_w_generate_cu2v" Text="Generate" />
				</Port>
				<Port Name="weapon_type" Direction="Out" Type="Duels_Weapon">
					<DesignName StringName="nahodne_w_weapon_type_InGR" Text="Weapon Type" />
				</Port>
				<Port Name="type" Direction="In" Type="Duels_Type">
					<DesignName StringName="nahodne_w_type_tDOK" Text="Type" />
				</Port>
			</Ports>
			<Nodes>
				<State Name="DuelsWeaponRand" PositionY="-60" PositionX="-30" TypeT="Duels_Weapon">
					<Edge From="switch3.Value1" To="Value" />
					<Edge From="valuefromshuffledinterval.number_was_selected" To="Exec">
						<Vertex>pmI95H2I</Vertex>
						<Vertex>CmBaGuyf</Vertex>
					</Edge>
					<Edge From="updateWeaponType.OnTrigger" To="Exec" />
				</State>
				<IfFunction Name="ifcompare6" PositionY="-80" PositionX="-1030" TypeT="Duels_Type" MethodName="Control::Compare" DeclaringType="Control">
					<Constant Name="Op" Value="NotEquals" />
					<Constant Name="ValueB" Value="Fistfight" />
					<Edge From="generate" To="Exec" />
					<Edge From="type" To="ValueA" />
				</IfFunction>
				<Output Name="Output">
					<Edge From="DuelsWeaponRand.State" To="weapon_type" />
				</Output>
				<Switch Name="switch3" PositionY="-60" PositionX="-370" TypeT="int" ValueTypes="Duels_Weapon" SwitchValues="0 1 2">
					<Constant Name="0Value1" Value="LongSword" />
					<Constant Name="1Value1" Value="Axe" />
					<Constant Name="2Value1" Value="Mace" />
					<Constant Name="DefaultValue1" Value="ShortSword" />
					<Edge From="valuefromshuffledinterval.number_from_interval" To="Switch" />
				</Switch>
				<HasteTrigger Name="updateWeaponType" PositionY="-330" PositionX="-370">
					<Constant Name="IsHidden" Value="true" />
				</HasteTrigger>
				<valuefromshuffledinterval Name="valuefromshuffledinterval" PositionY="-80" PositionX="-740" Namespace="utils.random">
					<Constant Name="interval" Value="4" />
					<Constant Name="salt__seed_string" Value="duelyWeaponType" />
					<Edge From="ifcompare6.True" To="get_next_permutation" />
				</valuefromshuffledinterval>
			</Nodes>
			<EdgeVertices>
				<EdgeVertex Name="CmBaGuyf" PositionY="340" PositionX="-90" />
				<EdgeVertex Name="pmI95H2I" PositionY="340" PositionX="-350" />
			</EdgeVertices>
			<Text StringName="nahodne_weapon_type_LDy6" Text="Nahodne Weapon Type" />
		</Module>
