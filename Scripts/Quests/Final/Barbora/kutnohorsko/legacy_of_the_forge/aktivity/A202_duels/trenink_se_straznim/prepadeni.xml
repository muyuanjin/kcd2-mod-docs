					<Text StringName="prepadeni_zenska_bezi_do__Ljjr" Text="Zenska bezi do mista prepadeni a ukazuje kde probiha, pak ceka." />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="prepadeni_strazni_taky_ta_vTmO" Text="Strazni taky tam bezi a zacne bojovat proti banditum." />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="prepadeni_banditi_a_ochra_bu5V" Text="Banditi a ochranka karavany cekaji kdyz pribezi strazni nebo hrac, pak zacinaji bojovat mezi sebou (aby nezemreli jeste pred tim nez prijdou)." />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="prepadeni_jakmile_pribezi_gBuO" Text="Po combatu hrac muze promluvit se straznim a dostane odmenu, pokud pomohl (kontrola hitu od hracu). Pokud hrac nepomohl, strazni o tom rekne v dialogu a zadna odmena nebude." />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="prepadeni_pokud_hrac_nena_GOJM" Text="Pokud hrac nenabidne pomoc a quest skonci, tak prepadeni a combat vypadaji uplne stejne. Hrac se tam muze pridat a pak promluvit se straznim, ale quest nebude aktivni." />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="prepadeni_pokud_zenska_ze_zymz" Text="Pokud zenska zemre nebo hrac odejde prilis daleko od mista prepadeni, bude fail objectivu a ukonceni questu." />
				</GameplayActionElement>
