<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="fail_questu">
			<Ports>
				<Port Name="fail_questu" Direction="Out" Type="trigger">
					<DesignName StringName="fail_ques_fail_questu_dm6Z" Text="Fail objectivu" />
				</Port>
				<Port Name="hrac_ma_omezeni_cas_na_pomoc" Direction="In" Type="trigger">
					<DesignName StringName="fail_ques_hrac_ma_omezeni_L8qp" Text="Hrac ma omezeni cas na pomoc" />
				</Port>
				<Port Name="hrac_pomohl" Direction="In" Type="trigger">
					<DesignName StringName="fail_ques_hrac_pomohl_hLZP" Text="Hrac pomohl" />
				</Port>
				<Port Name="je_aktivni" Direction="In" Type="bool">
					<DesignName StringName="fail_ques_je_aktivni_wFX1" Text="je aktivni" />
				</Port>
			</Ports>
			<Nodes>
				<SoulDeathTrigger Name="deathtrigger3" PositionY="340" PositionX="-60">
					<Asset Name="Souls" Alias="ZenaZPrepadeni" />
					<Edge From="je_aktivni" To="IsActive" />
				</SoulDeathTrigger>
				<DistanceTrigger Name="distancetrigger2" PositionY="70" PositionX="-60">
					<Asset Name="Origin" Alias="player" />
					<Asset Name="Target" Alias="ZenaZPrepadeni" />
					<Constant Name="Operator" Value="GreaterEquals" />
					<Constant Name="Distance" Value="250" />
					<Edge From="je_aktivni" To="IsActive" />
				</DistanceTrigger>
				<Output Name="Output">
					<Edge From="distancetrigger2.OnMatch" To="fail_questu" />
					<Edge From="timer1.OnFinished" To="fail_questu" />
					<Edge From="deathtrigger3.OnAllDeath" To="fail_questu" />
				</Output>
				<Timer Name="timer1" PositionY="-270" PositionX="-60">
					<Constant Name="Duration" Value="2h" />
					<Constant Name="TimeType" Value="WorldTime" />
					<Edge From="hrac_ma_omezeni_cas_na_pomoc" To="SetRunning" />
					<Edge From="hrac_pomohl" To="SetStopped" />
				</Timer>
			</Nodes>
			<Text StringName="fail_questu_ZKR0" Text="Fail objectivu" />
		</Module>
	</Skald>
</Database>