<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="questitem">
			<Ports>
				<Port Name="quest_started" Direction="In" Type="trigger">
					<DesignName StringName="questitem_quest_started_NjUr" Text="quest started" />
				</Port>
				<Port Name="done_or_fail" Direction="In" Type="trigger">
					<DesignName StringName="questitem_done_or_fail_my2h" Text="done quest - clean up" />
				</Port>
				<Port Name="player_found_quest_item" Direction="Out" Type="trigger">
					<DesignName StringName="questitem_player_found_qu_q9tW" Text="player found all items" />
				</Port>
				<Port Name="fail" Direction="In" Type="trigger">
					<DesignName StringName="questitem_fail_U0Sb" Text="fail quest - clean up" />
				</Port>
				<Port Name="trackovani_zeleza" Direction="Out" Type="wh::questmodule::nodes::Tracker">
					<DesignName StringName="questitem_trackovani_zele_18tu" Text="trackování železa" />
				</Port>
			</Ports>
			<Nodes>
				<AddStashDefaultItem Name="addstashdefaultitem10" PositionY="-420" PositionX="320">
					<Asset Name="Stashes" Alias="stash" />
					<Edge From="anonymLetter.Active" To="IsActive" />
					<Edge From="anonymni_dopis.dopis" To="ItemClass" />
				</AddStashDefaultItem>
				<State Name="anonymLetter" PositionY="-420" PositionX="30" TypeT="Progress">
					<Edge From="quest_started" To="SetActive" />
					<Edge From="done_or_fail" To="SetDone" />
					<Edge From="fail" To="SetDone" />
				</State>
				<anonymni_dopis Name="anonymni_dopis" PositionY="-570" PositionX="10" Namespace="mrtvinemluvi" />
				<Output Name="Output">
					<Edge From="zelezo_ve_stashi.tracker" To="trackovani_zeleza" />
					<Edge From="zelezo_ve_stashi.player_found_all_items" To="player_found_quest_item" />
				</Output>
				<zelezo_ve_stashi Name="zelezo_ve_stashi" PositionY="-20" PositionX="30" Namespace="mrtvinemluvi">
					<Edge From="quest_started" To="active" />
				</zelezo_ve_stashi>
			</Nodes>
			<Text StringName="questitem_Wke5" Text="QuestItem a dopis" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="questitem_ve_zricenine_v__nwMj" Text="Ve zřícenině v prvním patře se po startu questu nachází 8x železo a anonymní dopis" />
				</GameplayActionElement>
			</Elements>
		</Module>
	</Skald>
</Database>