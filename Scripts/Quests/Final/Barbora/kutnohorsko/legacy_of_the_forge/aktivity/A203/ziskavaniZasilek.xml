				<Objective TypeT="AdditionalLogs_A203" Name="najdi_ztracene_veci">
					<LocalizedName StringName="genericca_informace_o_pre_ljl6" Text="Najdi ztracené věci" />
					<Logs>
						<EnumLog Type="None" Name="Hidden" />
						<Log Name="lettlers">
							<Log StringName="informace_mam_sehnat_ukra_Wp0N" Text="Včera přepadli našeho jízdního posla a sebrali mu důležité dopisy. Cechmistr Eichner zjistil o případu pár podrobností a myslí si, že ví, kde by ti lotři mohli být. Požádal mě, abych zajistil zbytek a ukradené dopisy vypátral. Všechny tři dopisy nesou pečeť cechu." />
						</Log>
						<Log Name="guild_stamp">
							<Log StringName="informace_mam_sehnat_cech_KMr1" Text="Včera se na cestě do města ztratil jeden zkušenej forman. Vedle jiného zboží měl u sebe i staré cechovní raznice ze zrušené hutě. Pokud by padli do rukou někomu chytrému, mohl by s nimi udělat velkou škodu. Cechmistr Eichner už zjistil o přepadení více a má jistou stopu. Požádal mě, abych zařídil zbytek a tři ukradené cechovní raznice získal." />
						</Log>
						<Log Name="armor1">
							<Log StringName="informace_mam_sehnat_ukra_nlXq" Text="Dva dny zpátky se ztratila platnéřská zakázka pro bohatého šlechtice. Pacholek, co ji vezl, se ztratil a urozený zákazník se už nechal slyšet, že nic neobdržel. Cechmistr Eichner už zjistil, kde tovaryše viděli naposledy a má podezření, že celou věc by mohli mít na svědomí lotři z blízkého okolí. Požádal mě, jestli bych se v místě neporozhlédl a ztracenou zbroj zkusil najít. Jedná se o panskou zbroj - přilbu, kyrys a plátové nohy." />
						</Log>
						<Log Name="guild_seal">
							<Log StringName="informace_mam_sehnat_plom_sDaP" Text="Přepadli posli, který vezl na hutě nové plombovací známky na pytle se zbožím. Cechmistr už zjistil, že šlo spíš o náhodu, každopádně už ví, kde hledat ty mizery, co to udělali. Požádal mě proto, zda bych ty dvě ukradené známky nezískal." />
						</Log>
						<Log Name="steel">
							<Log StringName="informace_mam_sehnat_ocel_l4Qu" Text="Cechovní vůz vezoucí nejlepší kutnohorskou ocel na cestě přepadli. Cechmistr zatím neví, kdo by za tím mohl stát, ale zjistil, kde by se ukradené zboží mohlo nacházet. Požádal mě, abych věc prozkoumal a když to půjde dobře, tak naše zboží získal zpátky. Jde o deset prutů toledské oceli." />
						</Log>
						<Log Name="family_valuables">
							<Log StringName="informace_mam_sehnat_rodi_RYpL" Text="Na cestě do Kutné Hory nějací mizerové okradli rodinu jednoho váženého kovářského mistra. Pro cechmistra Eichnera je otázkou cti, aby ochránil členy našeho cechu a požádal mě, abych mu s tím pomohl. Má už jisté podezření, kde by se ukradené rodinné cennosti mohli nacházet, pokud je ti lotři už nestihli dávno prodat. Jedná se o dědičný meč, dámskou brož, stříbrný prsten s drahokamem, zlatý prsten s křížem a škapulíř s okýnkem." />
						</Log>
						<Log Name="journeyman_paper">
							<Log StringName="informace_mam_sehnat_vyuc_C7Qb" Text="Nedaleko za městem se stalo přepadení, které cechmistr Eichner těžce nese. Nějací mizerové si tam počíhali na čerstvě vyučeného kovářského tovaryše. Chudák naštěstí přežil, i když dost zbitý, ale přišel o své výuční listy a náčrty, které si každý mistr hlídá jako oko v hlavě. Klaus Eichner by rád dostál svému předsevzetí ochraňovat členy cechu a požádal mě, abych mu pomohl. Zjistil totiž, kde se ti mizerové utábořili a já souhlasil, že se pokusím ukradené listiny získat. Jde o výuční list a tři kovářské recepty." />
						</Log>
						<Log Name="orphan_property">
							<Log StringName="informace_mam_sehnat_siro_jbmP" Text="U Benešova nějaká tlupa přepadla kovárnu a těď se prý potlouká nedaleko Kutné Hory. Z dědí jsou sirotci a i když nešlo o člena našeho cechu, cechmistr Eichner by rád dostál pověsti, že si umíme zjednat pořádek a pokud se ti hrdlořezové usadili někde v okolí, je stejně jen otázkou času, než vyvedou něco dalšího. Slíbil jsem Eichnerovi, že se po sirotčím majetku podívám. Jde o sirotčí majetek, vzácný kovářský recept a honosný růženec." />
						</Log>
						<Log Name="silver">
							<Log StringName="informace_mam_sehnat_mist_Oux7" Text="Na cestě do Kolína přepadli lapkové jednoho z našich členů a sebrali mu pečetní prsten i nějaké rodinné stříbro. Mistr naštěstí vyváznul živý. Cechmistr Eichner to samozřejmě nechce nechat jen tak, aby si někdo nemyslel, že se neumíme o své lidi postarat. Požádal mě proto, zda bych se po těch lotrech nepodíval. Získal totiž nepotvrzenou zprávu, kde by zhruba mohli tábořit. Měl bych získat ukradený mistrův pečetní prsten, stříbrný křížek s insignií, stříbrná smaltovaná brož a stříbrný pohár." />
						</Log>
						<Log Name="armor2">
							<Log StringName="informace_mam_sehnat_ukra_sgm9" Text="Před dvěma dny byl přepadený vůz s drahou milánskou zbrojí pro urozeného zákazníka. Cechmistr Eichner to nepovažuje za běžné přepadení, ale zatím netuší, zda nitky vedou někam dál. Každopádně už získal zprávy, kde by se ukradené zboží mohlo nacházet. Slíbil jsem mu, že se po ukradené zásilce podívám. Jedná se o milánskou zbroj - kyrys, plátové nohy a železné rukavice." />
						</Log>
						<Log Name="alchemyst_material">
							<Log StringName="informace_mam_sehnat_alch_uOGm" Text="Už podruhé si někdo počíhal na kupecký vůz, který vezl drahé alchymistické přísady určené pro sváření a legování oceli i zdobení zbraní. Nejenom, že se jedná o těžko nahraditelnou ztrátu, ale navíc se kvůli to zpožďují důležité zakázky. Naštěstí Eichner už má menšní stopu, kam vítr fouká. Požádal mě, abych ji prověřil a pokud to půjde přísady získal zpátky. Jedná se o arabskou gumu, syrský asfalt, mastix a vzácnou rtuť." />
						</Log>
						<Log Name="blades">
							<Log StringName="informace_mam_sehnat_ukra_DasP" Text="Včera se neznámým mizerům podařilo zastavit a vykrást vůz, který vezl zakázku prvotřídních čepelí pro významného pána. Ten to naštěstí ještě neví, o přepadení se cechmistr Eichner dozvěděl od pacholka a vozky, kteří přepadení přežili bez úhony. Klaus Eichner získal i další stopy, které ukazují na místo, kde by se ti lotři mohli skrývat. Ztratily se čtyři různé dlouhé meče ve skvělé kvalitě - válečný, rytířský, obyčejný a široký meč." />
						</Log>
					</Logs>
				</Objective>
