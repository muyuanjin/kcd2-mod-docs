			<Text StringName="posledni_bere_vse_WWfa" Text="Poslední bere vše" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="posledni__jindra_ma_dojit_r5gZ" Text="Jindra má dojít na předávku itemu za item, jenže na místě může v dialogu odhalit, že jedná s převlečenými podvodníky, kteří mu dávají špatné  zboží. Následně hráče chtějí zabít, pokud je obviní z podvodu. Hráč je může také chtít přinutit, aby mu dali správné zboží. " />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="posledni__pokud_prinese_z_WSku" Text="Pokud přinese zpátky podvodné zboží, řekne mu zadavatel, že ho podvedli, ale že je rád, že tam nebyl on, protože mohl přijít o život." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_posledni_bere_vse_93zS" Text="Ve službách cechu" />
			<QuestDescription StringName="qdesc_posledniberevse_8vXn" Text="Cechmistr Klaus Eichner si mě vybral za společníka při pátrání po ukradeném zboží našeho cechu a řešení potíží, o kterých by nikdo další neměl vědět." />
			<Objectives>
				<Objective TypeT="ProgressFailable" Name="setkej_se_s_olbertem">
					<LocalizedName StringName="poslednib_promluv_s_kupcem_6zmP" Text="Setkej se s Olbertem" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="Eichner">
							<Log StringName="jdi_na_sc_doprovod_cechmi_9cUS" Text="Cechmistr Klaus Eichner nakonec  zjistil, kdo ve skutečnosti stojí v pozadí přepadení vozů s cechovním zbožím. Bohužel, to pro něj byla větší rána, než čekal, protože tím mužem je jeho mladší bratr Olbert, který je od krále jmenovaným úředníkem dohlížejícím na kutnohorská cla. Přestože se Klausovi už včera přiznal, nesdělil mu žádné důvody. Všechno se má vyjasnit na schůzce, kterou si s bratrem domluvil. Cechmistr si myslí, že za vším stojí politika, protože jeho bratr nepotřebuje loupit na cestách. Slíbil jsem, že Klause na tuto schůzku doprovodím, protože jsem zvědav o co tady ve skutečnosti jde." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="jdi_na_sc_doprovodil_jsem_V03k" Text="Cechmistr Klaus Eichner nakonec zjistil, kdo ve skutečnosti stojí v pozadí přepadení vozů s cechovním zbožím. Bohužel, to pro něj byla větší rána, než čekal, protože tím mužem je jeho mladší bratr Olbert, který je od krále jmenovaným úředníkem dohlížejícím na kutnohorská cla. Přestože se Klausovi už dříve přiznal, nesdělil mu žádné důvody. Všechno se vyjasnilo až o něco později na schůzce, kterou si s bratrem domluvil. Olbert byl věrným stoupencem krále Václava a proto, když zjsitil, že náš cech dodával zbraně a zbroje pánům z Panské jednoty, věrné Zikmundovi, rozhodl se zakročit, ale tak chytře aby to nikdo nepoznal a dal tak kovářskému cechu druhou šanci." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="jdi_na_sc_odmitnul_jsem_d_CCyF" Text="Cechmistr Klaus Eichner nakonec zjistil, kdo ve skutečnosti stojí v pozadí přepadení vozů s cechovním zbožím. Bohužel, to pro něj byla větší rána, než čekal, protože tím mužem je jeho mladší bratr Olbert, který je od krále jmenovaným úředníkem dohlížejícím na kutnohorská cla. Přestože se Klausovi už včera přiznal, nesdělil mu žádné důvody. Všechno se vyjasnilo o něco později na schůzce, kterou si s bratrem domluvil. Nabídl mně, abych ho doprovodil, ale odmítnul sjem, protože jsem se nechtěl zaplést do nejasných obchodních intrik" />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="CombatObjective" Name="pobij_podvodniky">
					<LocalizedName StringName="poslednib_pobij_podvodniky_MEB5" Text="Pobij podvodníky" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" />
						<EnumLog Type="Completed" Name="PlayerWin">
							<Log StringName="pobij_pod_dostali_co_proto_WyDX" Text="Dostali co proto." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="PlayerRunAway">
							<Log StringName="pobij_pod_jsem_posera_zdr_1abc" Text="Jsem posera, zdrhnul jsem." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="CechmistrDied" />
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="najdi_dukaz">
					<LocalizedName StringName="poslednib_najdi_zbozi_j8Nl" Text="Najdi důkaz" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="areaMarker">
							<Log StringName="najdi_zbo_podle_dohody_mu_3ryp" Text="Podle dohody musím prověřit, zda je ztracené zboží tam, kde nám popsal Olbert. Předpokládám, že nemá důvod lhát, ale Klaus by rád, abych mu přivezl nějaký důkaz. Všechno by mělo být ukryté v opuštěné šachtě jihozápadně od Kouřimské brány do Kutné Hory." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="najdi_zbo_nasel_jsem_ztra_8Rf5" Text="Našel jsem ztracené cechovní zboží ve skrýši v opuštěné důlní štole nedaleko Kutné Hory. Budeme muset pro to poslat vůz, nebo možná i dva, protože tam je jistě všechno, co se nám ztratilo z obchodu s Panskou Jednotou." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="najdi_zbo_nenasel_jsem_sk_INWF" Text="Nenašel jsem skrýš se zbožím, kterou mi popsal Olbert Eichner." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="p_dukaz_klausovi">
					<LocalizedName StringName="poslednib_odvez_dukaz_kla_JHCU" Text="Odnes důkaz Klausovi" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="Eichner">
							<Log StringName="odvez_duk_nyni_bych_se_me_zBnt" Text="Sebral jsem drobnou zdobenou dýku, co vypadá jako práce mistra Matyáše ze Žatce. Nyní bych se měl vrátit za Klausem Eichnerem a říct mu, že jeho bratr skutečně nelhal a naše dohoda s ním skutečně platí. Během dne bych měl mistra zastihnout v jeho obchodě." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="odvez_duk_sebral_jsem_tam_wqvE" Text="Sebral jsem drobnou zdobenou dýku a vrátil se s ní za cechmistrem Eichnerem. Jeho nálada nebyla právě dvakrát skvělá, ostatně nebylo se čemu divit. Jeho bratr dosáhl svého, ale riskoval jejich rodinou pověst. Kdyby se o našem setkání na vinici dozvěděl kdokoliv další mohlo by to vážně ohrozit nejenom cech, ale právě i jeho budoucnost. Požádal mě proto, abych o všem pomlčel, za to jsem v něm získal dlužníka, ale i zdá se, že i skutečného přítele." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="odvez_duk_dukaz_ze_skryse_FtoV" Text="Důkaz ze skrýše se zbožím jsem Klausovi neodevzvdal." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="ProgressFailable" Name="odevzdej_item">
					<LocalizedName StringName="poslednib_odevzdej_item_NyCr" Text="Promluv s Eichnerem" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="Eichner">
							<Log StringName="odevzdej__mel_jsem_zjisti_8RC3" Text="Měl jsem zjistit, zda skrýš, kterou nám prozradil Olbert Eichner skutečně obsahuje to, co nám slíbil. A to jsem udělal. Teď bych měl zajít za cechmistrem Klausem Eichnerem a potvrdit mu, že jeho bratr mluvil pravdu a jeho dohoda je v tomto ohledu poctivá." />
						</EnumLog>
