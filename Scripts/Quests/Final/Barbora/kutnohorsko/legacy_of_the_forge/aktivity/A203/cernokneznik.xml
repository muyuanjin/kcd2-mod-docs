			<Elements>
				<GameplayActionElement>
					<Text StringName="cernoknez_cechmistr_posil_TIcr" Text="Cechmistr posílá hráče za alchymistou, který je podezřelý z kacířství, ale má pro cech důležitou zakázku. Alchymista je ubytován v KH, ale v jeho pokoji jsou pouze poházené věci a papíry. Focus kamera a bárk Jindry. Mezi věcmi je kniha jako klíč k vyluštení poznámky, ze které lze zjistit, kde je skrýš ve které je i hledaný item." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_cernokneznik_2Jpd" Text="Ve službách cechu" />
			<QuestDescription StringName="qdesc_cernokneznik_nTuz" Text="Cechmistr Klaus Eichner si mě vybral za společníka při pátrání po ukradeném zboží našeho cechu a řešení potíží, o kterých by nikdo další neměl vědět." />
			<Objectives>
				<Objective TypeT="ProgressFailableAbortable" Name="zajdi_za_alchymistou">
					<LocalizedName StringName="cernoknez_zajdi_za_alchym_aO4Q" Text="Zajdi za alchymistou" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="alchymistHomeArea">
							<Log StringName="zajdi_za__mam_ziskat_od_a_wCYc" Text="Cechmistr Bušek má těžkou hlavu z jedné prapodivné zakázky. Alchymista Johan Lasnius si u něj objednal a z poloviny rovnou i zaplatil výrobu tenkých železných obručí. Další splátka v podobě alchymistických přísad měla proběhnout při předání zakázky, tam ale magister Johan už nedorazil, protože byl mezitím nařknut z čarodějnictví a uprchnul z města. Mistr Bušek by na tohohle černokněžníka nejraději zapomněl, ale Johan se po pár dnech ozval a dožaduje své zakázky. Bušek mě proto požádal, jestli bych obchod v tichosti nezařídil. Mám odnést Johanovi zakázku a vrátit se se slíbenými alchymistickými přísadami." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="zajdi_za__sel_jsem_za_alc_fxPj" Text="Cechmistr Bušek měl těžkou hlavu z jedné prapodivné zakázky. Alchymista Johan Lasnius si u něj objednal a z poloviny rovnou i zaplatil výrobu tenkých železných obručí. Další splátka v podobě alchymistických přísad měla proběhnout při předání zakázky, tam ale magister Johan už nedorazil, protože byl mezitím nařknut z čarodějnictví a uprchnul z města. Mistr Bušek by na tohohle černokněžníka nejraději zapomněl, ale Johan se po pár dnech ozval a dožadoval své zakázky. Bušek mě proto požádal, jestli bych obchod v tichosti nezařídil. Jenže když jsem přišel do hostince, bylo jasné, že alchymista není doma." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Failed">
							<Log StringName="zajdi_za__kaslu_na_item_LwS2" Text="Cechmistr Bušek má těžkou hlavu z jedné prapodivné zakázky. Jeden alchymista prohlášený za kacíře si u něj objednal železné obruče. Požádal mě jestli bych zakázku v tichosti nedoručil, ale odmítl jsem." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
