					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="alchymistRoomArea">
							<Log StringName="prozkoume_podivam_se_jest_LJbm" Text="Místnost hostince, kde jsem se měl sejít s alchymistou je ve strašném stavu. Vypadá to, jakoby zde proběhl nějaký strašný zápas, ale přitom dveře byly zamčeny zevnitř! Na zemi leží rozházené alchymistovi osobní věci i nějaké rozbité flákonky. Měl bych to tady lépe prohledat." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="prozkoume_nasel_jsem_list_wYpP" Text="Místnost v hostinci, kde jsem se měl sejít s alchymistou, byla ve strašném stavu. Vypadalo to, jakoby zde proběhl nějaký strašný zápas, ale přitom byly dveře zamčeny zevnitř! Mezi rozházenými a zničenými věcmi na zemi jsem našel podivný list s alchymistickými symboly a nějaké zápisky. Vypadalo to, že dohromady skrývají nějakou hádanku." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Failed">
							<Log StringName="prozkoume_kaslu_na_zakazku_A4ak" Text="Místnost v hostinci, kde jsem se měl sejít s alchymistou, byla ve strašném stavu. Vypadalo to, jakoby zde proběhl nějaký strašný zápas, ale přitom byly dveře zamčeny zevnitř! Jedno bylo ale jasné, alchymista zde nebyl a žádná stopa po něm nezbyla." />
