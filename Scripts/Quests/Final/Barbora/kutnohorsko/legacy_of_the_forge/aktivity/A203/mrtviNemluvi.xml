			<Elements>
				<GameplayActionElement>
					<Text StringName="mrtvineml_cechmistr_posil_xiJ3" Text="Cechmistr posílá Jindru pro ukradenou zásilku jako obvykle, ale když Jindra přijde na místo vidí, že zde došlo k bitce a jsou zde jen samí mrtví. Po bližším ohledání najde jednoho živého, ale umírajícího. Může mu ulevit od bolesti a ten mu řekne, kde je skrýš a v ní to, co hráč hledá." />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="mrtvineml_umirajici_pozad_53MN" Text="Umírající požádá Jindru, aby dal jeho milé předmět, jenže když za ní Jindra přijde, tak zjistí, že milá už jiného má a o mrtvého se dávno nezajímá." />
				</GameplayActionElement>
