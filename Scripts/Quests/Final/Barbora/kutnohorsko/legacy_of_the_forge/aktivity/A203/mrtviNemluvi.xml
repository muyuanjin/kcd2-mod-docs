						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="najdi_tab_nasel_jsem_kemp_qG1A" Text="Když jsem ovšem přišel do tábora lotrů, kteří by to podle Eichnera měli mít na svědomí, našel jsem jen samé mrtvoly." />
						</EnumLog>
