			<QuestDescription StringName="qdesc_mrtvinemluvi_U4ny" Text="Cechmistr Klaus Eichner si mě vybral za společníka při pátrání po ukradeném zboží našeho cechu a řešení potíží, o kterých by nikdo další neměl vědět." />
			<Objectives>
				<Objective TypeT="ProgressFailable" Name="najdi_ztracene_zbozi">
					<LocalizedName StringName="mrtvi_nem_zajdi_pro_zasil_RurS" Text="Najdi ztracené zboží" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" IsTracked="true">
							<Log StringName="zajdi_pro_mam_vyzvednout__YYym" Text="Cechmistr Klaus Eichner má další případ, který je ale dosti zvláštní. Klaus se totiž tentokrát snažil ochránit přepravované zboží tím, že poslal dva různé vozy a zatímco jeden vezl plátky oceli, druhý měl v truhlici jenom kamení. Přes tuto pečlivou přípravu někdo přesto přepadl a vyloupil vůz se zbožím. Cechmistr si to nedokáže vysvětlit, protože o daném plánu s nikým nemluvil. Požádal mě proto, abych se ujal vyšetřování a pokusil se zjistit víc i o tom, jak se to stalo a přitom sehnal ztracenou plátkovou ocel." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="zajdi_pro_na_miste_jsou_s_v03T" Text="Cechmistr Klaus Eichner má další případ, který je ale dosti zvláštní. Klaus se totiž tentokrát snažil ochránit přepravované zboží tím, že poslal dva různé vozy a zatímco jeden vezl plátky oceli, druhý měl v truhlici jenom kamení. Přes tuto pečlivou přípravu přesto někdo přepadl a vyloupil správný vůz. Cechmistr si to nedokáže vysvětlit, protože o daném plánu s nikým nemluvil. Požádal mě proto, abych se ujal vyšetřování a pokusil se zjistit víc o tom, jak se to stalo a sehnat ukradenou plátkovou ocel." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="zajdi_pro_kaslu_na_zasilku_c5z7" Text="Pátrání po ztraceném zboží našeho cechu jsem vzdal." />
						</EnumLog>
					</Logs>
				</Objective>
