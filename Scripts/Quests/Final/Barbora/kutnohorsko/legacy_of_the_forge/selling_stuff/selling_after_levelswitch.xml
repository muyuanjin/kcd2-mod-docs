<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="selling_after_levelswitch">
			<Ports>
				<Port Name="level_switch" Direction="In" Type="trigger">
					<DesignName StringName="selling_a_level_switch_0uSq" Text="Level Switch" />
				</Port>
				<Port Name="no_of_periods" Direction="In" Type="int">
					<DesignName StringName="selling_a_no_of_periods_gKnz" Text="No of periods" />
				</Port>
				<Port Name="update" Direction="In" Type="trigger">
					<DesignName StringName="selling_a_update_EGA7" Text="Update" />
				</Port>
				<Port Name="levelswitch_multiplier" Direction="Out" Type="int">
					<DesignName StringName="selling_a_levelswitch_mul_KurW" Text="LevelSwitch Multiplier" />
				</Port>
			</Ports>
			<Nodes>
				<HasteTrigger Name="_levelswitch" PositionY="-340" PositionX="-1260" />
				<IfFunction Name="ifcompare8" PositionY="-150" PositionX="-1250" TypeT="int" MethodName="Control::Compare" DeclaringType="Control">
					<Constant Name="Op" Value="Greater" />
					<Constant Name="ValueB" Value="0" />
					<Edge From="level_switch" To="Exec" />
					<Edge From="no_of_periods" To="ValueA" />
				</IfFunction>
				<Output Name="Output">
					<Edge From="state5.State" To="levelswitch_multiplier" />
				</Output>
				<Select Name="select6" PositionY="40" PositionX="-880" InputPortGroups="2" ValueTypes="int">
					<Constant Name="BValue1" Value="1" />
					<Edge From="update" To="SelectB" />
					<Edge From="no_of_periods" To="AValue1" />
					<Edge From="_levelswitch.OnTrigger" To="SelectA" />
					<Edge From="ifcompare8.True" To="SelectA" />
					<Edge From="ifcompare8.False" To="SelectB" />
				</Select>
				<State Name="state5" PositionY="-140" PositionX="-540" TypeT="int">
					<Constant Name="DefaultValue" Value="1" />
					<Edge From="select6.Value1" To="Value" />
					<Edge From="select6.OnExec" To="Exec" />
				</State>
			</Nodes>
			<Text StringName="selling_after_levelswitch_x6y1" Text="Selling after LevelSwitch" />
		</Module>
	</Skald>
</Database>