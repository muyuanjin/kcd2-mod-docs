<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="areadetection">
			<Ports>
				<Port Name="chasing" Direction="In" Type="bool">
					<DesignName StringName="areadetec_chasing_1HS0" Text="chasing" />
				</Port>
				<Port Name="searching" Direction="In" Type="bool">
					<DesignName StringName="areadetec_searching_7jqd" Text="searching" />
				</Port>
				<Port Name="volf_entered" Direction="Out" Type="trigger">
					<DesignName StringName="areadetec_volf_entered_VDi6" Text="volf entered" />
				</Port>
				<Port Name="player_entered" Direction="Out" Type="trigger">
					<DesignName StringName="areadetec_player_entered_kcGT" Text="player entered" />
				</Port>
				<Port Name="player_left" Direction="Out" Type="trigger">
					<DesignName StringName="areadetec_player_left_3PQp" Text="player left" />
				</Port>
			</Ports>
			<Nodes>
				<AreaTrigger Name="areatrigger2" PositionY="-70" PositionX="220">
					<Asset Name="Areas" Alias="volfHidingArea" />
					<Edge From="or1.bool" To="IsActive" />
					<Edge From="joinarrays3.Array" To="Souls" />
				</AreaTrigger>
				<IfFunction Name="ifcompare4" PositionY="-150" PositionX="620" TypeT="wh::rpgmodule::I_Soul*" MethodName="Control::Compare" DeclaringType="Control">
					<Constant Name="Op" Value="Equals" />
					<Asset Name="ValueB" Alias="volf" />
					<Edge From="areatrigger2.OnEnter" To="Exec" />
					<Edge From="areatrigger2.Soul" To="ValueA" />
				</IfFunction>
				<IfFunction Name="ifcompare5" PositionY="192" PositionX="653" TypeT="wh::rpgmodule::I_Soul*" MethodName="Control::Compare" DeclaringType="Control">
					<Constant Name="Op" Value="Equals" />
					<Asset Name="ValueB" Alias="player" />
					<Edge From="areatrigger2.OnLeave" To="Exec" />
					<Edge From="areatrigger2.Soul" To="ValueA" />
				</IfFunction>
				<Function Name="joinarrays3" PositionY="190" PositionX="-70" TypeT="wh::rpgmodule::Souls" MethodName="utilities::array::JoinArrays" DeclaringType="utilities::array">
					<Asset Name="A" Alias="volf" />
					<Asset Name="B" Alias="player" />
				</Function>
				<Function Name="or1" PositionY="-70" PositionX="-50" MethodName="math::boolean::Or" DeclaringType="math::boolean">
					<Edge From="chasing" To="A" />
					<Edge From="searching" To="B" />
				</Function>
				<Output Name="Output">
					<Edge From="ifcompare4.True" To="volf_entered" />
					<Edge From="ifcompare4.False" To="player_entered" />
					<Edge From="ifcompare5.True" To="player_left" />
				</Output>
			</Nodes>
			<Text StringName="areadetection_MrbA" Text="AreaDetection" />
		</Module>
	</Skald>
</Database>