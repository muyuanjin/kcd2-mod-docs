			<Elements>
				<GameplayActionElement>
					<Text StringName="uchazec_jindrich_uvidi_v__owIo" Text="Jindřich uvidí v Kutné Hoře vyhořelou kovárnu, ke které se váže stará vzpomínka na jeho otce Martina. Setkává se s vdovou po kováři Škodovi Magdalénou, která mu potvrdí, že Martin zde kdysi dávno dělal tovaryše. Posteskne si, že kovárnu za dvacet let cech nebyl schopen opravit a ponouká Jindru, aby si promluvil s cechmistrem Buškem a pokusil se v té věci něco udělat. Jindra se domluví s Buškem, složí cechovní zkoušky a získá právo užívat a vylepšovat kovárnu. Po základním úklidu mu Magdaléna vysvětlí, jak kovárnu dále vylepšovat, a nastartuje se první aktivita - Kování. " />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_uchazec_02s7" Text="Uchazeč" />
			<QuestDescription StringName="qdesc_uchazec_9hIj" Text="Našel jsem v Kutné Hoře pobořenou kovárnu, která se historicky váže k mému otci Martinovi. Pokusím se ji získat do správy." />
			<Objectives>
				<Objective TypeT="Progress" Name="promluv_si_s_cechmistrem_buskem">
					<LocalizedName StringName="s201_ucha_promluv_si_s_bu_jRqL" Text="Promluv si s mistrem Buškem." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="Busek">
							<Log StringName="promluv_s_v_kutne_hore_js_NLId" Text="V Kutné Hoře jsem narazil na starou vyhořelou kovárnu, která ve mně vyvolala dávné vzpomínky. Když jsem byl před lety ve městě s otcem jako malý kluk, ukazoval mi ji a říkal, že tady prožil nejkrásnější léta svého života. Z rozjímání nad minulostí mne vyrušila stará žena. Ukázalo se, že jde o vdovu po kováři Škodovi, který v té kovárně Martina učil. Jmenuje se Magdaléna. Byla ke mně velice otevřená a stýskala si nad současným ostudným stavem kovárny, se kterým podle ní nechce cech kutnohorských kovářů nic dělat. Když jsem se nabídl, že se to pokusím napravit, poslala mne za jedním z mistrů, Buškem Starším, do jeho platnéřství v Radniční naproti věži s orlojem, abych si promluvil o podmínkách převzetí kovárny.   " />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="promluv_s_v_kutne_hore_js_D4xM" Text="V Kutné Hoře jsem narazil na starou vyhořelou kovárnu, která ve mně vyvolala dávné vzpomínky. Když jsem byl před lety ve městě s otcem jako malý kluk, ukazoval mi ji a říkal, že tady prožil nejkrásnější léta svého života. Z rozjímání nad minulostí mne vyrušila stará žena. Ukázalo se, že jde o vdovu po kováři Škodovi, který v té kovárně Martina učil. Jmenuje se Magdaléna. Byla ke mně velice otevřená a stýskala si nad současným ostudným stavem kovárny, se kterým podle ní nechce cech kutnohorských kovářů nic dělat. Když jsem se nabídl, že se to pokusím napravit, poslala mne za jedním z mistrů, Buškem Starším. Ten mi oznámil, že kovárnu mohou přidělit poze členovi cechu. Po mém zájmu o vstup do něj mne nejdříve varoval, že cech mezi sebe pouští cizince jen velice nerad, ale když se dozvěděl, že jsem Martinův syn a že mám s kovařinou zkušenosti, rázem pookřál a zařídil mi možnost složit cechovní zkoušku, která se skládá z  části ústní a části řemeslné." />
						</EnumLog>
					</Logs>
				</Objective>
