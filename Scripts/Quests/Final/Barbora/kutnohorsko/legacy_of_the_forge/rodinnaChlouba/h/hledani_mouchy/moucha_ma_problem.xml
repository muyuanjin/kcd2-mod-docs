<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<DialogWrapper Name="moucha_ma_problem">
			<Ports>
				<Port Name="hledani_mouchy_active" Direction="In" Type="bool">
					<DesignName StringName="moucha_ma_vracim_se_za_mo_YdYQ" Text="hledání mouchy active" />
				</Port>
				<Port Name="mluv_s_mouchou_active" Direction="In" Type="bool">
					<DesignName StringName="moucha_ma_mluv_s_mouchou__ENQ6" Text="mluv s mouchou active" />
				</Port>
				<Port Name="vyres_mouchuv_problem" Direction="Out" Type="trigger">
					<DesignName StringName="moucha_ma_vyres_mouchuv_p_MraC" Text="vyřeš Mouchův problém" />
				</Port>
				<Port Name="predani_upisu_mouchovi" Direction="Out" Type="trigger">
					<DesignName StringName="moucha_ma_predani_upisu_m_MqNk" Text="předání úpisu Mouchovi" />
				</Port>
				<Port Name="mluv_s_mouchou" Direction="Out" Type="trigger">
					<DesignName StringName="moucha_ma_mluv_s_mouchou_7XQV" Text="mluv s Mouchou" />
				</Port>
				<Port Name="bez_sikanatora" Direction="Out" Type="bool">
					<DesignName StringName="moucha_ma_bez_sikanatora_R9uF" Text="bez šikanátora" />
				</Port>
				<Port Name="rekl_o_orloji" Direction="Out" Type="bool">
					<DesignName StringName="moucha_ma_rekl_o_orloji_6kT8" Text="řekl o orloji" />
				</Port>
			</Ports>
			<Definitions>
				<Definition File="moucha_ma_problem/moucha_ma_problem.xml" />
			</Definitions>
			<Nodes>
				<Function Name="and2" PositionY="-160" PositionX="-280" MethodName="math::boolean::And" DeclaringType="math::boolean">
					<Edge From="daytimecheck.isdaytime" To="A" />
					<Edge From="hledani_mouchy_active" To="B" />
				</Function>
				<Function Name="and3" PositionY="0" PositionX="-280" MethodName="math::boolean::And" DeclaringType="math::boolean">
					<Edge From="mluv_s_mouchou_active" To="B" />
					<Edge From="daytimecheck.isdaytime" To="A" />
				</Function>
				<daytimecheck Name="daytimecheck" PositionY="-300" PositionX="-600" Namespace="utils.time" />
				<Function Name="deathcheck1" PositionY="250" PositionX="-330" MethodName="wh::rpgmodule::DeathCheck" DeclaringType="wh::rpgmodule">
					<Asset Name="Souls" Alias="Sikanator" />
				</Function>
				<HasItems_Soul Name="HasItems_Soul" PositionY="430" PositionX="-310" Namespace="utils.item">
					<Asset Name="soul" Alias="player" />
					<Constant Name="amount" Value="1" />
					<Edge From="Konstanty.dluzni_upis" To="itemclass" />
				</HasItems_Soul>
				<Konstanty Name="Konstanty" PositionY="240" PositionX="-720" Namespace="rodinnachloubalib" />
				<moucha_ma_problem Name="moucha_ma_problem">
					<Edge From="deathcheck1.IsDead" To="sikanator_je_mrtvy" />
					<Edge From="HasItems_Soul.hasitems" To="hrac_ma_upis" />
					<Edge From="and2.bool" To="hledani_mouchy_active" />
					<Edge From="and3.bool" To="mluv_s_mouchou_active" />
				</moucha_ma_problem>
				<Output Name="Output">
					<Edge From="moucha_ma_problem.vyres_mouchuv_problem" To="vyres_mouchuv_problem" />
					<Edge From="moucha_ma_problem.predani_upisu_mouchovi" To="predani_upisu_mouchovi" />
					<Edge From="moucha_ma_problem.bez_sikanatora" To="bez_sikanatora" />
					<Edge From="moucha_ma_problem.mluv_s_mouchou" To="mluv_s_mouchou" />
					<Edge From="moucha_ma_problem.rekl_o_orloji" To="rekl_o_orloji" />
				</Output>
			</Nodes>
		</DialogWrapper>
	</Skald>
</Database>