				<SceneActionElement>
					<Text StringName="stara_kov_povzdechne_si_QtZW" Text="Vidíme užaslou tvář malého Jindry, jak se dívá na zlověstně vypadající kovárnu. Drží v ruce klacík. Otec si ustaraně povzdechne." />
