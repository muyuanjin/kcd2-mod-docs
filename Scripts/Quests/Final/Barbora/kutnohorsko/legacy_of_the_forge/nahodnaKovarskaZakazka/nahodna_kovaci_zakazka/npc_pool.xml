<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="npc_pool">
			<Ports>
				<Port Name="tryselect" Direction="In" Type="trigger">
					<DesignName StringName="npc_pool_tryselect_lOZF" Text="TrySelect" />
				</Port>
				<Port Name="ispoolselected" Direction="In" Type="bool">
					<DesignName StringName="npc_pool_ispoolselected_hhe2" Text="IsPoolSelected" />
				</Port>
				<Port Name="souls" Direction="In" Type="wh::rpgmodule::Souls">
					<DesignName StringName="npc_pool_souls_nNvH" Text="Souls" />
				</Port>
				<Port Name="soul" Direction="Out" Type="wh::rpgmodule::I_Soul*">
					<DesignName StringName="npc_pool_soul_xxPG" Text="Soul" />
				</Port>
			</Ports>
			<Nodes>
				<ElementAt Name="elementat1" PositionY="100" PositionX="-160" TypeT="wh::rpgmodule::Souls">
					<Edge From="valuefromshuffledinterval.number_from_interval" To="Index" />
					<Edge From="souls" To="Array">
						<Vertex>wvpoEup4</Vertex>
					</Edge>
				</ElementAt>
				<If Name="if6" PositionY="-220" PositionX="-960">
					<Edge From="tryselect" To="Exec" />
					<Edge From="ispoolselected" To="Condition" />
				</If>
				<Length Name="length2" PositionY="280" PositionX="-1150" TypeT="wh::rpgmodule::Souls">
					<Edge From="souls" To="Array">
						<Vertex>wvpoEup4</Vertex>
					</Edge>
				</Length>
				<Output Name="Output">
					<Edge From="elementat1.Value" To="soul" />
				</Output>
				<Function Name="touintint3" PositionY="280" PositionX="-890" MethodName="math::conversion::ToUint(int)" DeclaringType="math::conversion">
					<Edge From="length2.Length" To="int" />
				</Function>
				<valuefromshuffledinterval Name="valuefromshuffledinterval" PositionY="-160" PositionX="-600" Namespace="utils.random">
					<Constant Name="salt__seed_string" Value="kovaniNahodnyVyberNpc" />
					<Edge From="touintint3.uint" To="interval" />
					<Edge From="if6.True" To="get_next_permutation" />
				</valuefromshuffledinterval>
			</Nodes>
			<EdgeVertices>
				<EdgeVertex Name="wvpoEup4" PositionY="190" PositionX="-1280" />
			</EdgeVertices>
			<Text StringName="npc_pool_OcIV" Text="Random blacksmithing NPC from pool" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="npc_pool_pokud_je_vybrany_DhfS" Text="Pokud je vybraný, posune vnitřní shuffled index a na výstupu vyhodí soulu z poolu." />
				</GameplayActionElement>
			</Elements>
		</Module>
	</Skald>
</Database>