			<Elements>
				<GameplayActionElement>
					<Text StringName="iniciacni_v_iniciacni_akt_e989" Text="V iniciační aktiviě, je Jindra poslán cechmistrem Zbořkem za Klausem Eichnerem. Ten mu u poháru vína vysvětlí, že je jakýmsi šéfem cechovní rozvědky a často řeší přepadení formanů se zbožím. Nastíní také politické pozadí těchto akcí." />
				</GameplayActionElement>
				<GameplayActionElement>
					<Text StringName="iniciacni_nasledne_posle__cs63" Text="Následně pošle hráče za získáním ukradené zakázky &quot;jakoby&quot; šlo o generické získávání." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_iniciacni_aktivita_ScI1" Text="Klaus se představuje" />
			<QuestDescription StringName="qdesc_iniciacni_aktivita_e9MO" Text="Zavolal si mě cechmistr Klaus Eichner. Vypadá to, že být členem cechu obnáší nejenom příjemné hraní kostek, ale i další povinnosti. Jenom doufám, že jsem neporušil nějakou důležitou vyhlášku." />
			<Objectives>
				<Objective TypeT="Progress" Name="promluv_s_eichnerem1">
					<LocalizedName StringName="iniciacni_promluv_s_eichn_IWL6" Text="Promluv s Eichnerem" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="Eichner">
							<Log StringName="promluv_s_promluv_s_eichn_Is8G" Text="Chce se mnou mluvit cechmistr Klaus Eichner. Vlastně nevím, co přesně má v cechu na starosti, ale myslím, že se to už brzo dozvím. Během dne bych se za ním měl stavit v jeho obchodě." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="promluv_s_cechmistr_klaus_Le9l" Text="Cechmistr Klaus Eichner byl muž, který se vyzná a cech měl na prvním místě. Myslím, že i díky němu patřil kutnohorský cech kovářů k nejmocnějším ve městě. Bez zbytečných ohledů zajišťoval, aby ostatní mistři měli klid na práci a jejich zakázky se dostaly tam, kam mají." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="Progress" Name="ziskej_zpet_ukralistiny">
					<LocalizedName StringName="iniciacni_ziskej_zpet_lis_QDAE" Text="Získej zpět ukradené listiny" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" IsTracked="true" Marker="campArea">
							<Log StringName="ziskej_zp_prave_kvuli_bez_EKw9" Text="Právě kvůli bezpečnosti si mě zavolal. Na pražské cestě přepadli vůz a ukradli z něj důležité cechovní smlouvy se zelenou pečetí. Mistr Eichner mě požádal, abych se je pokusil nějak chytře získat zpátky." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="ziskej_zp_prave_kvuli_bez_UDEr" Text="Právě kvůli bezpečnosti si mě zavolal. Na pražské cestě přepadli vůz a ukradli z něj důležité cechovní smlouvy, které se mi nakonec podařilo získat." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="Progress" Name="odevzdej_listiny">
					<LocalizedName StringName="iniciacni_odevzdej_listiny_jBq8" Text="Odevzdej listiny" />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="Eichner">
							<Log StringName="odevzdej__nyni_uz_jenom_s_0VBq" Text="Nyní už jenom stačí zavést sebrané smlouvy zpátky cemistrovi Eichnerovi do Kutné Hory. Během dne bude jistě u sebe v obchodě." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="odevzdej__sebrane_cechovn_Ln60" Text="Sebrané cechovní smlouvy jsem odevzdal, ale cosi mi říkalo, že si mě mistr Eichner oblíbil a není to naposledy, co jsem pro něj pátral po zmizelém zboží." />
						</EnumLog>
					</Logs>
