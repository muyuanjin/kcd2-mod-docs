<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Module Name="horse_hitreactionnotification">
			<Ports>
				<Port Name="isactive" Direction="In" Type="bool">
					<DesignName StringName="horse_hit_isactive_10fS" Text="IsActive" />
				</Port>
				<Port Name="onnotification_hitinsidesmallerarea" Direction="Out" Type="trigger">
					<DesignName StringName="horse_hit_onnotification__0TMC" Text="OnNotification_HitInsideSmallerArea" />
				</Port>
			</Ports>
			<Nodes>
				<AIConceptSignalTrigger Name="aiconceptsignaltriggerhitreactionnotification1" PositionY="-50" PositionX="-80" NotificationName="hitReactionNotification">
					<Asset Name="attacker_value_filter" Alias="player" />
					<Asset Name="victim_value_filter" Alias="phantomHorse" />
					<Edge From="isactive" To="IsActive" />
				</AIConceptSignalTrigger>
				<Function Name="areacheck4" PositionY="-170" PositionX="360" MethodName="wh::rpgmodule::AreaCheck" DeclaringType="wh::rpgmodule">
					<Asset Name="Souls" Alias="phantomHorse" />
					<Asset Name="Areas" Alias="deadKnight_barkArea" />
				</Function>
				<IfFunction Name="ifand2" PositionY="-50" PositionX="720" MethodName="math::boolean::And" DeclaringType="math::boolean">
					<Edge From="aiconceptsignaltriggerhitreactionnotification1.OnNotification" To="Exec" />
					<Edge From="areacheck4.IsInside" To="A" />
					<Edge From="switch3.Value1" To="B" />
				</IfFunction>
				<Output Name="Output">
					<Edge From="ifand2.True" To="onnotification_hitinsidesmallerarea" />
				</Output>
				<Switch Name="switch3" PositionY="70" PositionX="360" TypeT="crime_attackKind" ValueTypes="bool" SwitchValues="stone armed missile stealth dog unarmed playerHorseCollision collision pebble">
					<Constant Name="stoneValue1" Value="false" />
					<Constant Name="armedValue1" Value="true" />
					<Constant Name="missileValue1" Value="true" />
					<Constant Name="stealthValue1" Value="false" />
					<Constant Name="dogValue1" Value="true" />
					<Constant Name="unarmedValue1" Value="false" />
					<Constant Name="playerHorseCollisionValue1" Value="false" />
					<Constant Name="collisionValue1" Value="false" />
					<Constant Name="pebbleValue1" Value="true" />
					<Constant Name="DefaultValue1" Value="false" />
					<Edge From="aiconceptsignaltriggerhitreactionnotification1.hitType" To="Switch" />
				</Switch>
			</Nodes>
			<Text StringName="horse_hitreactionnotifica_AeYn" Text="Horse_HitReactionNotification" />
		</Module>
	</Skald>
</Database>