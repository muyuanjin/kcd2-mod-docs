			<QuestDescription StringName="qdesc_bazilisci_vejce_QDUR" Text="S Vojtěchem není nic jen tak černobílé. Chybí mu pojidlo do barvy, a tak po mně chce, abych mu sehnal baziliščí vejce. Prý má jeho žloutek magické vlastnosti." />
			<Objectives>
				<Objective TypeT="FindingEgg" Name="najdi_vejce_cerneho_kohouta">
					<LocalizedName StringName="bazilisci_najdi_vejce_od__oBHo" Text="Najdi vejce černého kohouta." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="farmar">
							<Log StringName="najdi_vej_promluv_si_s_fa_raZt" Text="Získat baziliščí vejce není nic jednoduchého. Musím nejdřív sehnat vejce, které snesl černý kohout. Netuším sice, jak je něco takového vůbec možné, ale zkusím malíři věřit a vydám se na Semín. Ve vsi tam prý žije sedlák Slávek, který takového zvláštního kohouta má." />
						</EnumLog>
						<EnumLog Type="Updated" Name="SearchFarm" Marker="farmArea">
							<Log StringName="najdi_vej_prohledej_farmu_tqj8" Text="Sedlák Slávek mi bohužel nic neřekne. Zkusím prohledat jeho statek, někde přece toho kohouta schovávat musí." />
						</EnumLog>
						<EnumLog Type="Updated" Name="FindPlaceInForest" Marker="kohoutiVejceAreaBig">
							<Log StringName="najdi_vej_najdi_cerneho_k_e5Nf" Text="Podařilo se mi najít pár černých kohoutích per. S jejich pomocí bych snad měl najít i vejce, které hledám." />
						</EnumLog>
						<EnumLog Type="Updated" Name="CollectEgg" Marker="kohoutiVejceArea">
							<Log StringName="najdi_vej_seber_kohouti_v_r0Ts" Text="Na východní straně vesnice u lesa je ohrádka s odpadem a v ní mrtvý kohout, snad tam bude i vejce. Měl bych si pospíšit" />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="najdi_vej_nasel_jsem_vejc_vrzL" Text="Našel jsem vejce snesené černým kohoutem. " />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="FindingHole" Name="najdi_misto_kam_vejce_ulozit">
					<LocalizedName StringName="bazilisci_hledani_jamy_FZDZ" Text="Najdi místo, kam vejce uložit." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Started" Marker="ZabyAreaWide">
							<Log StringName="hledani_j_bez_hledat_jamu_1Kpg" Text="Kohoutí vejce pak musí být uloženo někde, kde ho budou moci vysedět ropuchy. Ty prý bývají často slyšet u rybníka pod Želejovskou hospodou. Měl bych to tam prozkoumat, určitě ty potvory už z dálky uslyším." />
						</EnumLog>
						<EnumLog Type="Updated" Name="LocationUpdatedToSmall" Marker="ZabyAreaSmall">
							<Log StringName="hledani_j_rybar_upresnil__8T2Y" Text="Místní mi poradili, kde zhruba můžu najít ropuchy. Teď už stačí jen jít za kvákáním." />
