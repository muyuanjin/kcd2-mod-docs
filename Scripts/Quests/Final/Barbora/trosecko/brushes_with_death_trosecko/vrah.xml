			<QuestName StringName="qname_vrah_OqfN" Text="Portrét v rudé" />
			<QuestDescription StringName="qdesc_vrah_aklY" Text="Malíř Vojtěch je celý ztrápený a vypadá to, že za to může mordýř jménem Burkhard, který sem přitáhl. Zabíjí lidi brutálním způsobem a vzhledem k tomu, že je na něj vypsána odměna od rychtáře Troskovic Drozda, tak se mi vyplatí jít se ho zbavit. Třeba se díky tomu konečně od Vojtěcha dočkám pár důležitých odpovědí." />
			<Objectives>
				<Objective TypeT="ZabijLapku" Name="zabij_burkharda">
					<LocalizedName StringName="vrah_zabijvudcelapku_jNLj" Text="Zabij Burkharda." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="KillBandit" Marker="campMapMarkerArea">
							<Log StringName="zabijvudc_zabij_vudce_lap_nmWA" Text="Vrah Burkhard má prý tábor někde na severozápad od Trosek, ale určitě tam nebude sám. Kolem sebe shromáždil bandu mladých kluků, které používá jako prodlouženou paži i živý štít. Mohl bych se s nimi vypořádat, ale bylo by daleko lepší nechat je žít. Kdo ví, třeba v nich ještě něco dobrého zbylo. Zato Burkhardův život má jen tu cenu, jakou na něj vypsal troskovický rychtář Drozd. " />
						</EnumLog>
						<EnumLog Type="Completed" Name="BanditKilled">
							<Log StringName="zabijvudc_zabil_jsi_vudce_6DG0" Text="Zabil jsem Burkharda Krvavého a v kraji snad bude konečně trochu klid. Jestli chci ale za svou práci odměnu od troskovického rychtáře Drozda, měl bych mu ukázat Burkardovu helmu jako důkaz." />
						</EnumLog>
						<EnumLog Type="None" Name="BanditSurvived" />
					</Logs>
				</Objective>
				<Objective TypeT="NavratKMaliri" Name="vrat_se_k_maliri">
					<LocalizedName StringName="vrah_navratkmaliri_L3TZ" Text="Vrať se k malíři." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="ReturnToPainter" Marker="malir">
							<Log StringName="navratkma_vrat_se_k_maliri_VwWz" Text="Malíř Vojtěch už určitě netrpělivě čeká, až mu řeknu, co se s Burkhardem stalo. Měl bych za ním co nejdřív zajít." />
						</EnumLog>
						<EnumLog Type="Completed" Name="DoneBanditKilled">
							<Log StringName="navratkma_vratil_jsem_se__rpqw" Text="Řekl jsem malíři Vojtěchovi o smrti Burkharda. Ale nevypadal moc šťastný. Každopádně mi slíbil odpovědět na spoustu otázek a ukázat něco zajímavého, ale ne tady na Troskách. Mám ho navštívit v Kutné Hoře. Měl bych se tam zastavit, až to bude možné." />
						</EnumLog>
						<EnumLog Type="Completed" Name="DoneBanditSurvived">
							<Log StringName="vrat_se_k_zalhal_jsem_mal_8Ltg" Text="Zalhal jsem malíři, že jsem Burkharda zabil. Stačilo ho přesvědčit s helmou a bylo to. Snad na něj nikde nenarazí, to by bylo nemilé. Každopádně mi Vojtěch slíbil odpovědět na spoustu otázek a ukázat něco zajímavého, ale ne tady na Troskách. Mám ho navštívit v Kutné Hoře. Měl bych se tam zastavit, až to bude možné." />
						</EnumLog>
					</Logs>
				</Objective>
			</Objectives>
