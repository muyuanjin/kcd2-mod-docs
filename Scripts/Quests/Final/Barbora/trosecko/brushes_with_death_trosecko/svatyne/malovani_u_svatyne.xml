	<Skald>
		<Scene Name="malovani_u_svatyne" IsLocked="false">
			<Text StringName="malovani_u_svatyne_dhok" Text="malování u svatyně" />
			<Elements>
				<SceneActionElement>
					<Text StringName="malovani__exttrosecka_kra_SfFo" Text="EXT.Trosecká krajina poblíž pohanské svatyně.PODVEČER" />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="malovani__je_podvecer_slu_BCay" Text="Je podvečer, slunce pomalu začíná zapadat, teplo, zkrátka krásný letní okamžik." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="malovani__jindra_lezi_ve__TOfs" Text="Jindra leží ve stínu pod stromem v malém údolí s vysokou trávou a podřimuje." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="malovani__nedaleko_jindry_BytP" Text="Nedaleko Jindry si všímáme malíře, který sedí na velkém kameni a v jedné ruce drží dřevěnou desku (plátna nebyla) a v druhé ruce štětec. Je očividně zabraný do malování. Už to patrně dělá celé hodiny. No vlastně od chvíle, co s Jindrou přišli. Vidíme i to, že maluje pohanskou svatyni. Svatyně má podobu obrovské rohaté hlavy pohanského boha podsvětí Velese. Malíř ji bedlivě pozoruje, aby ji správně zachytil a skoro se až zdá, jako kdyby ona pozorovala jeho. Buďme ale opatrní v tom, že malíř nemaluje přesně to, co vidí! Jen se tím inspiruje a tvoří dobovou malbu." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="malovani__seq1_ztXp" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Parenthetical>
												<Text StringName="malo_malir_znavene_mimo_o_fV0F" Text="maluje, povídá si pro sebe" />
											</Parenthetical>
											<Text StringName="malo_malir_hotovo_Rvk2" Text="Kruci, namaloval jsem mu o zub víc!" />
										</Response>
										<Response Role="MALIR">
											<Parenthetical>
												<Text StringName="malo_malir_zamysli_se_nS2a" Text="zamyslí se" />
											</Parenthetical>
											<Text StringName="malo_malir_no_rekneme_ze__dmIe" Text="No... Řekněme, že..." />
										</Response>
										<Response Role="MALIR">
											<Text StringName="malo_malir__to_je_PIxA" Text="... to je..." />
										</Response>
										<Response Role="MALIR">
											<Text StringName="malo_malir_mala_hezka_chy_YX9V" Text="Malá hezká chybka.">
												<Note StringName="malo_malir_mala_hezka_chy_YX9V_note" Text="happy little accident - Bob Ross reference" />
											</Text>
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="malovani__malir_pokracuje_iWuR" Text="Malíř je téměř hotov. Postaví se a odloží desku na padlý strom před sebou. Prohlíží si své dílo, ale je vyrušen chrápajícím Jindrou." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="malovani__seq1_dzX8" Text="seq1" />
									<Elements>
										<Response Role="HENRY">
											<Parenthetical>
												<Text StringName="malo_henry_chrape_umFh" Text="chrápe" />
											</Parenthetical>
											<Text StringName="malo_henry_chrrr_kmDp" Text="&lt;chrrr&gt;" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="malovani__malir_dostane_n_PDTU" Text="Malíř dostane nápad. Vezme nakousnuté jablko, které si odložil na kámen, otočí se a trefí jablkem Jindru do obličeje. Není to velká rána, ale stačí, aby se Jindra leknutím probudil." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="malovani__seq1_VJkY" Text="seq1" />
									<Elements>
										<Response Role="HENRY">
											<Text StringName="malo_henry_au_6jxo" Text="&lt;Au&gt;" />
										</Response>
										<Response Role="HENRY">
											<Parenthetical>
												<Text StringName="malo_henry_probuzen_jablk_IX5C" Text="probuzen jablkem" />
											</Parenthetical>
											<Text StringName="malo_henry_kurva_RUVK" Text="Kurva!" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="malovani__malir_se_pousme_MoZG" Text="Malíř se pousměje a otáčeje se zpátky k obrazu napůl pro sebe - napůl k Jindrovi prohlásí:" />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
