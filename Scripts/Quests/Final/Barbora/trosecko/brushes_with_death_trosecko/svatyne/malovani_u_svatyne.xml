									<DesignName StringName="malovani__seq1_qGxb" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Text StringName="malo_malir_spravedlnost_b_knDI" Text="Spravedlnost Boží dílem jablka... &lt;haha&gt;" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="malovani__jindra_vstava_l_W3tg" Text="Jindra vstává, lehce zívne - čekal, než malíř domaluje, opravdu dlouho - a jde se podívat na obraz." />
				</SceneActionElement>
