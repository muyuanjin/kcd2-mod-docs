						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="promluv_s_promluvil_jsem__nSMy" Text="Promluvil jsem si s Květoslavou. Tedy pokud se tomu vůbec dá říkat rozhovor..." />
