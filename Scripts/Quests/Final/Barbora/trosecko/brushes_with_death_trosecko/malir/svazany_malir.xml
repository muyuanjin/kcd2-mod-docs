<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Name="brambora">
	<Skald>
		<Scene Name="svazany_malir" IsLocked="false">
			<Text StringName="svazany_malir_JobJ" Text="Svázaný malíř" />
			<Elements>
				<SceneActionElement>
					<Text StringName="svazany_m_ext_otevrene_pr_TKQh" Text="EXT. KRAJ LESA POBLÍŽ TROSEK. LIBOVOLNÁ DENNÍ DOBA A POČASÍ." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="svazany_m_scena_by_mela_p_xEsq" Text="Pozn.: Když hráč přichází k objective markeru, uvidí muže přivazaného ke stromu a uslyší, že s někým mluví, i když není vidět s kým. Když se ještě víc přiblíží, spustí se cutscéna. Jindřich přichází k muži-malíři, který je přivázaný ke stromu a s někým mluví. Vedle sebe má brašnu, ze které ale byly vysypány všechny věci. Je to vybavení na cestu: deka, pár kusů oblečení, chléb, klobása. Malíř sebou ošívá, snaží se vymanit z pout." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_2PQ5" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Text StringName="svaz_malir_ale_tohle_neni_RcRV" Text="Vždyť jsem vyzkoušel úplně všechno. Nejde to!" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_malir_se_osiva__qFDR" Text="Malíř se ošívá, vidíme ho více zblízka." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_CDJg" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Text StringName="svaz_malir_sakra_nemuzes__zFZL" Text="Sakra, nemůžeš bejt aspoň chvíli zticha?" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_vidime_ze_malir_SB29" Text="Vidíme, že malíř mluví na pomalovanou lebku na zemi." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_dgTw" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Text StringName="svaz_malir_nic_jsem_nevzd_ACNs" Text="Nic jsem nevzdal. Jenom jsem chtěl odsud pryč!" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_ted_uz_spolu_le_k7TT" Text="Jindřich se rozhlíží, ale nevidí nikoho, s kým by si muž mohl povídat. Pomalu a opatrně, aby nebyl slyšet, kráčí směrem ke svázanému." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="svazany_m_vidime_lebku_z__yp4G" Text="Lebka stojí a mlčí… ale Malíř její hlas slyší." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_Bl86" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Text StringName="svaz_malir_jak_naschval_n_E79L" Text="Nezahrávej si se mnou!" />
										</Response>
										<Response Role="MALIR">
											<Text StringName="svaz_malir_mas_jediny_ste_bV7E" Text="Maš jediný štěstí, že jsem svázanej-" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_zatimco_malir_h_lqLr" Text="Vtom praskne větvička, na kterou zrovna šlápl přicházející Jindřich. Malíř se na něj otočí – lekne se, když vidí, že není sám. Najednou se výraz v jeho tváři změní – jako by se z něj stal jiný člověk." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_kTFN" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Parenthetical>
												<Text StringName="svaz_malir_najednou_mile__Ni1Q" Text="najednou mile" />
											</Parenthetical>
											<Text StringName="svaz_malir__ja_te_prosim__FsTH" Text="Jaký štěstí!" />
										</Response>
										<Response Role="MALIR">
											<Text StringName="svaz_malir_jdes_jako_na_z_IhZB" Text="Jdeš jako na zavolanou, mladíku!" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_jindra_je_uz_do_bLi0" Text="Jindřich se zastaví. Je zmaten. Podívá se na lebku, Malíř si jeho pohledu všimne. Je mu jasné, že to nezafungovalo – Jindřich dobře viděl, s kým ve skutečnosti mluvil." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_1c1F" Text="seq1" />
									<Elements>
										<Response Role="HENRY">
											<Text StringName="svaz_henry_co_to_tady_del_7ZX5" Text="Co to tady děláš?" />
										</Response>
										<Response Role="MALIR">
											<Parenthetical>
												<Text StringName="svaz_malir_v_lehce_nervoz_Nm0p" Text="v lehce nervózním žeru, trochu teatrálně" />
											</Parenthetical>
											<Text StringName="svaz_malir_co_by_jen_tak__Bd5H" Text="Jen jsem tu tak stál a někdo ke mně přivázal strom! Hrůza!" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_malir_lehce_pok_kQr6" Text="Malíř lehce pokyne hlavou na pozdrav." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_UX20" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Text StringName="svaz_malir_pochvalen_bud__pJeQ" Text="Pochválen buď Ježíš Kristus." />
										</Response>
										<Response Role="HENRY">
											<Parenthetical>
												<Text StringName="svaz_henry_klidneji_slusne_cP6M" Text="klidněji, slušně" />
											</Parenthetical>
											<Text StringName="svaz_henry_az_na_veky_ieDY" Text="Až na věky..." />
										</Response>
										<Response Role="MALIR">
											<Parenthetical>
												<Text StringName="svaz_malir_kyne_hlavou_na_oLg9" Text="kyne hlavou na pouta" />
											</Parenthetical>
											<Text StringName="svaz_malir_byl_bys_tak_ho_3KOB" Text="Byl bys tak hodnej...?" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_jindra_se_pousm_vk7m" Text="Jindřich rozpačitě přikývne a jde toho blázna rozvázat. Obejde strom, aby se dostal k poutům na Malířových rukou. Vytahuje dýku a chystá se rozříznout jeho pouta." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_Xrld" Text="seq1" />
									<Elements>
										<Response Role="HENRY">
											<Text StringName="svaz_henry_proc_ne_jeste__Iyrq" Text="No... Proč ne." />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_zatimco_jde_jin_275R" Text="Zatímco jde Jindra k malíři, v popředí se mihne vlk. Ani jeden z mužů si ho ale zatím nevšiml." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_YlwQ" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Text StringName="svaz_malir_jeste_zes_sel__plcf" Text="Ještě, žes šel zrovna kolem, hochu..." />
										</Response>
										<Response Role="MALIR">
											<Text StringName="svaz_malir_ani_si_nechci__aePf" Text="Ani si nechci představovat, co v tom lese číhá za příšery..." />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_malir_se_nahle__11af" Text="Vtom se z lesa ozve zavytí. Ani není vzdálené - vlci jsou zjevně velmi blízko. Jindřich se zarazí a otáčí se k lesu. V dálce se něco hýbe." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="svazany_m_jindrich_udela__FAM5" Text="blíží se dvojice vlků, kteří se připravují k útoku." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_PDTa" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Parenthetical>
												<Text StringName="svaz_malir_nervozne_fzx4" Text="tiše, aby nepopudil vlky, v nervózním žertu" />
											</Parenthetical>
											<Text StringName="svaz_malir_myslis_treba_t_ouRL" Text="Stojím za tebou, příteli." />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="svazany_m_malir_se_kouka__68kx" Text="Jindřich se otočí, věnuje Malíři nechápavý pohled." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="svazany_m_seq1_LFoh" Text="seq1" />
									<Elements>
										<Response Role="MALIR">
											<Parenthetical>
												<Text StringName="svaz_malir_nervozne_zertu_QmCh" Text="nervózně žertuje" />
											</Parenthetical>
											<Text StringName="svaz_malir_do_nich_pritel_HXx1" Text="Můžeš se spolehnout!" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text Text="" />
				</SceneActionElement>
			</Elements>
		</Scene>
	</Skald>
