				<SceneActionElement>
					<Text StringName="cs__zabit_jindrich_opatrn_3aYU" Text="JINDŘICH opatrně otevírá dveře do zadní místnosti, pouze na úzkou škvíru a nahlíží dovnitř." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cs__zabit_v_mistnosti_je__DWYE" Text="V místnosti na zemi jsou tři prázdná lůžka a okolo se povaluje léčitelské náčiní - nožíky, obvazy, obklady, vědro a trojice misek, lžic a pohárků od jídel. Je jasné, že tu leželo několik lidí." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cs__zabit_uvnitr_se_hadaj_8Fey" Text="Uvnitř se hádají dva muži - BYLINÁŘ a POBOČNÍK ZACHARIÁŠE" />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cs__zabit_bylinar_stoji_c_XNix" Text="BYLINÁŘ stojí čelem ke dveřím a vypadá vystrašeně, POBOČNÍK stojí zády, není mu vidět do obličeje ale je jasné, že zuří." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
