									<Elements>
										<Response Role="DLC3_POBOCNIK">
											<Parenthetical>
												<Text StringName="cs___dlc3_pobo_dozrane_qj4t" Text="dožraně" />
											</Parenthetical>
											<Text StringName="cs___dlc3_pobo_rikals_pre_ruTw" Text="Říkals přece, že jim už bylo líp. Lhal jsi, nebo jsi takovej pitomec?" />
										</Response>
										<Response Role="DLC3_BYLINAR">
											<Parenthetical>
												<Text StringName="cs___dlc3_byli_ohradi_se_8egS" Text="spěšně, nervózně" />
											</Parenthetical>
											<Text StringName="cs___dlc3_byli_pritizilo__ZFbq" Text="Přitížilo se jim. Přišlo to najednou. A už jim nebylo pomoci." />
										</Response>
										<Response Role="DLC3_POBOCNIK">
											<Parenthetical>
												<Text StringName="cs___dlc3_pobo_nastvane_CfOP" Text="naštvaně" />
											</Parenthetical>
											<Text StringName="cs___dlc3_pobo_a_zkousel__tu6g" Text="A ty knihy, co jsem ti sháněl? Máš tu půl klášterní knihovny! Zkoušel ses do nich třeba podívat?" />
										</Response>
										<Response Role="DLC3_BYLINAR">
											<Parenthetical>
												<Text StringName="cs___dlc3_byli_brani_se_cal5" Text="brání se" />
											</Parenthetical>
											<Text StringName="cs___dlc3_byli_precetl_js_mXoz" Text="Přečetl jsem každou! Ale říkal jsem vám stokrát, že nejsem lékař! Nevím, co jste čekali." />
										</Response>
										<Response Role="DLC3_POBOCNIK">
											<Parenthetical>
												<Text StringName="cs___dlc3_pobo_nastvane_v_jX0x" Text="naštvaně, výhrůžně" />
											</Parenthetical>
											<Text StringName="cs___dlc3_pobo_nedochazi__RivI" Text="Že budeš myslet hlavou, do prdele! Teď okolo toho čmuchá kde kdo!" />
										</Response>
										<Response Role="DLC3_BYLINAR">
											<Parenthetical>
												<Text StringName="cs___dlc3_byli_ustrasene_gtLg" Text="ustrašeně" />
											</Parenthetical>
											<Text StringName="cs___dlc3_byli_ja_ja_nech_rRre" Text="Ale nemohl jsem přece..." />
										</Response>
										<Response Role="DLC3_POBOCNIK">
											<Parenthetical>
												<Text StringName="cs___dlc3_pobo_zlostne_L3YS" Text="zlostně" />
											</Parenthetical>
											<Text StringName="cs___dlc3_pobo_snad_jsem__uFly" Text="Snad jsem se vyjádřil jasně. Zůstanou tady, ty se odtud nehneš, a nikdo nesmí o ničem vědět!" />
										</Response>
										<Response Role="DLC3_BYLINAR">
