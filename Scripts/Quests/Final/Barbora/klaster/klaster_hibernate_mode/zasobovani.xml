			<Elements>
				<GameplayActionElement>
					<Text StringName="zasobovani_zasobovani_spi_lAF6" Text="Zásobování špitálu řeší Zachariášův sluha Dénes. Jak se klášter uzavře, cellarius Julián je stále přísnější na příděly a jak nemocných přibývá, zásoby se tenčí. Jindřich se pokusí situaci zlepšit - může orodovat u Juliána a získat / ukrást klíč od spižírny, krást jídlo, nebo najít knihu receptů, odkud zjistí, že jsou v klášterních sádkách raci, které lze lovit a přidat do zásob." />
				</GameplayActionElement>
				<ActionPromptElement>
					<Text StringName="zasobovani_kniha_yRM5" Text="Kniha" />
				</ActionPromptElement>
				<ActionPromptElement>
					<Text StringName="zasobovani_zasoby_ZVFi" Text="Zásoby" />
				</ActionPromptElement>
				<ActionPromptElement>
					<Text StringName="zasobovani_kotka_kqrL" Text="Nešťastná kostka" />
				</ActionPromptElement>
				<ActionPromptElement>
					<Text StringName="zasobovani_madarske_penize_XPSZ" Text="Maďarské peníze" />
				</ActionPromptElement>
				<ActionPromptElement>
					<Text StringName="zasobovani_raci_Ea73" Text="Raci" />
				</ActionPromptElement>
			</Elements>
			<QuestName StringName="qname_zasobovani_gdaT" Text="Chléb náš vezdejší" />
			<QuestDescription StringName="qdesc_zasobovani_V3PK" Text="Jak přibývá nemocných, zásoby se tenčí. A cellarius je stále přísnější, co se přídělů týká. Pokud mají nemocní ve špitále vydržet, bude třeba sehnat další jídlo." />
			<Objectives>
				<Objective TypeT="ProgressFailable" Name="promluv_s_cellariem">
					<LocalizedName StringName="zasobovani_promluv_s_cell_fH2R" Text="Promluv s cellariem." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" Marker="cellarius">
							<Log StringName="promluv_s_mel_bych_si_jit_a9LK" Text="Měl bych si jít promluvit s cellariem Juliánem. Mohl by mi dát nějaké zásoby pro chudáky ve špitále." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done">
							<Log StringName="promluv_s_promluvil_jsem__rT0Q" Text="Promluvil jsem si s cellariem Juliánem. Nic mi nedal, ale naznačil, že když mu seženu jeho spektákly, tak nějaké jídlo najde." />
						</EnumLog>
						<EnumLog Type="Canceled" Name="Canceled">
							<Log StringName="promluv_s_cellarius_julia_gKmW" Text="Cellarius Julián zemřel. Už mi s jídlem pro špitál nepomůže." />
						</EnumLog>
					</Logs>
				</Objective>
				<Objective TypeT="SberRaciKlaster" Name="nasbirej_raky" IsOptional="true">
					<LocalizedName StringName="zasobovani_nasbirej_raky_0pWJ" Text="Nasbírej raky." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="Active" IsTracked="true" Marker="raci_areaMarker">
							<Log StringName="nasbirej__ve_vendelinove__e8EB" Text="Ve Vendelínově kníze jsem se dočetl, že by ve zdejších sádkách a v jezírku u bylinkové zahrady mohli být nějací raci, kterými bychom si mohli trochu přilepšit." />
						</EnumLog>
						<EnumLog Type="Updated" Name="Gathered4" IsTracked="true" Marker="raci_areaMarker">
							<Log StringName="nasbirej__mam_malo_muzu_m_pEgO" Text="Nasbíral jsem nějaké raky. Nevystačí na dlouho, ale lepší, než nic." />
						</EnumLog>
						<EnumLog Type="Updated" Name="Gathered8">
							<Log StringName="nasbirej__jeste_vic_QUgS" Text="Raků jsem našel celkem dost, z tohohle už by mohl špitál alespoň chvíli vyžít. Až budu odevzdávat Denésovi jídlo, měl bych mu dát i raky." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Done8">
							<Log StringName="nasbirej__raku_jsem_nasbi_zKcB" Text="Raky jsem našel přesně tam, kde psal Vendelín. Schovávali se dobře, ale stejně jsem je dostal. S nimi by mohl špitál vydržet o chvilku déle." />
						</EnumLog>
					</Logs>
				</Objective>
