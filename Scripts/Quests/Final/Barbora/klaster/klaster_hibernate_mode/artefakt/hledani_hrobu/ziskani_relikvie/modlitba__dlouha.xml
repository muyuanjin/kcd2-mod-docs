									</Parenthetical>
									<Text StringName="modl_henry_chvala_tobe_pa_jmGN" Text="Chvála tobě, Pane náš všemohoucí." />
								</Response>
								<Response Role="HENRY">
									<Text StringName="modl_henry_a_chvala_tobe__59vx" Text="A chvála tobě, milosrdný Kriste, který jsi pro nás na kříži trpěl." />
