									<Text StringName="modl_henry_a_ze_jsi_mi_do_cxii" Text="A žes mi dovolil najít tenhle poklad." />
								</Response>
								<Response Role="HENRY">
									<Text StringName="modl_henry_odpust_nam_pro_Q7P6" Text="Odpusť nám naše prohřešky a uchraň nás od tý strašlivý nemoci." />
								</Response>
								<Response Role="HENRY">
									<Text StringName="modl_henry_dej_zvitezit_s_pwcK" Text="Dej zvítězit spravedlivejm, potup podlý... A zachraň prosím život mistra Albíka." />
								</Response>
								<Response Role="HENRY">
									<Text StringName="modl_henry_amen_Z5sn" Text="Amen." />
