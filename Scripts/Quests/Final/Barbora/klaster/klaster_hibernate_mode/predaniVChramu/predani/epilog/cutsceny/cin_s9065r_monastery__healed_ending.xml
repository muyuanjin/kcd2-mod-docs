				<SceneActionElement>
					<Text StringName="cin_s9065_int_klasterni_n_Gj6z" Text="INT. KLÁŠTERNÍ NEMOCNICE. NOC." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_bezvladny_albik_2xHt" Text="Bezvládný ALBÍK leží na posteli v lazaretu. Je bledý, nejde poznat, kolik v něm ještě zbývá života. U postele stojí zasmušilý OPAT." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_do_mistnosti_pr_EtCB" Text="Do místnosti přiběhne JINDRA a rovnou urgentně zamíří k Albíkovi. Cestou v rukou už otevírá lahvičku." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_jindra_nalije_a_Auuo" Text="Jindra nalije Albíkovi do pusy PROTIJED. Pak poodstoupí a upustí prázdnou lahvičku na zem. Sledujeme, jak se lahvička zakutálí pod postel a pohledem na ní zůstaneme." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_kompozice_zusta_Vlbe" Text="Kompozice zůstává stejná, ale za lahvičkou se v pozadí se změní světlo: prolínačkou jsme se posunuli o několik hodin dál v čase." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_int_klasterni_n_oQ6T" Text="INT. KLÁŠTERNÍ NEMOCNICE. DEN." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_jindra_pomaha_o_oPLf" Text="Jindra pomáhá ošetřovat další nemocné, když tu ho vyruší zvuk - Albíkovo mumlání. Přijde tedy k jeho posteli a vidí, jak se Albíkovi vrátila barva a jak se snaží těžce otevítat oči. Jindra se nadějiplně usměje." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_nasleduje_sekve_f9kV" Text="-následuje sekvence, která má ukazovat plynutí času po dobu několika dalších dní-" />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_int_klasterni_n_dNh5" Text="INT. KLÁŠTERNÍ NEMOCNICE. DEN." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_albik_pomalu_o__322s" Text="Albík pomalu o holi chodí od lůžka k lůžku a dává instrukce, jak se starat o nemocné." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_jindra_dava_nem_AkBv" Text="Jindra dává nemocným pít." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_nemocnych_v_laz_ogxn" Text="Nemocných v lazaretu ubývá. (možná VC, který se rovnou prolne do stejné kompozice, kdy je už lazaret úplně prázdný a dovnitř svítí okny sluneční paprsky?)" />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_titulek_o_nekol_vsvP" Text="TITULEK: O několik dní později." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_int_chram_den_XgaZ" Text="INT. CHRÁM. DEN." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9065_zadusni_mse_v_c_xswT" Text="Zádušní mše. V chrámu je vyskládáno několik málo rakví za zemřelé. Okolo stojí Jindra, Opat, Ablík a několik dalších mnichů. Mají sepnuté ruce." />
