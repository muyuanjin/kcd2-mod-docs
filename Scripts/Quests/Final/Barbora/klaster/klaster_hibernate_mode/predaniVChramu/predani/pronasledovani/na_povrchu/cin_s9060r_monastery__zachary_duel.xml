				<SceneActionElement>
					<Text StringName="duel_snazi_se_pokracovat__CHCO" Text="Snaží se pokračovat o něco klidněji, aby působil přesvědčivě. Mezitím si ale levou rukou sáhne do opasku za zády a něco nahmatá. Jde o nějakou lahvičku." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="duel_seq1_yN84" Text="seq1" />
									<Elements>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="duel_dlc3_zach__ale_jeste_l3Ly" Text="... ale ještě pořád to jde napravit..." />
										</Response>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="cin__dlc3_zach_jeste_pora_FILF" Text="Ještě pořád můžeme všem pomoct..." />
										</Response>
										<Response Role="HENRY">
											<Text StringName="duel_henry_neverim_ti_uz__QGTr" Text="Nevěřím ti ani slovo." />
										</Response>
										<Response Role="HENRY">
											<Text StringName="cin__henry_dej_mi_ten_pro_gOu2" Text="Dej mi ten protijed a vzdej se!" />
