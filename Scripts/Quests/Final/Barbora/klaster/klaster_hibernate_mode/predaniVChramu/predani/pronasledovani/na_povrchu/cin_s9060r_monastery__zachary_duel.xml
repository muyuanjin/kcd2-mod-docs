				<SceneActionElement>
					<Text StringName="duel_ext_zahrada_uprostre_PYvT" Text="INT. KLÁŠTERNÍ CHODBA. VEČER." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="duel_jindra_prave_vylezl__Q3NJ" Text="Jindra právě vylezl z klášterního sklepení a rychle pokračuje klášterní chodbou, odhodlaně hledá Zachariáše - ale stále je opatrný. Za každým rohem čeká přepadení a léčku." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="duel_najednou_slysi_tupe__otcA" Text="Najednou slyší tupé rány doprovázené mohutným hekáním - někdo vynakládá velkou sílu. Po několika dalších, teď ještě více opatrných, krocích se před Jindrou rozprostře pohled na zoufalého Zachariáše, který buší malou sekerou do mohutných dřevěných dveří vedoucích z kláštera - k jeho smůle zamčených." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="duel_seq1_pgMG" Text="seq1" />
									<Elements>
										<Response Role="HENRY">
											<Parenthetical>
												<Text StringName="duel_henry_jako_rozkaz_al_uKHY" Text="jako rozkaz, ale tiše" />
											</Parenthetical>
											<Text StringName="duel_henry_vzdej_to_3xMp" Text="Vzdej to." />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="duel_zacharias_se_zastavi_V3yv" Text="Zachariáš se zastaví, napřímí. Stále stojí k Jindrovi zády, takže Jindra nevidí zlostný úšklebek, který se Zachariášovi objeví na obličeji. Rychle se otočí, hodí po Jindrovi sekeru a přitom úsilím vykřikne:" />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="duel_seq1_ud9p" Text="seq1" />
									<Elements>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="cin__dlc3_zach__W6mY" Text="&lt;...&gt;" />
										</Response>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="duel_dlc3_zach_aaaaa_GxrK" Text="Aáááá!" />
										</Response>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="cin__dlc3_zach__iUPv" Text="&lt;...&gt;" />
										</Response>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="cin__dlc3_zach__44sB" Text="&lt;...&gt;" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="duel_jindra_se_tak_tak_vy_Ybu5" Text="Jindra se tak tak vyhne, ale zavrávorá. Zachariáš se vrhne kupředu, ale mine Jindru a vběhne naproti do středové klášterní zahrady." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="duel_ext_zahrada_uprostre_EJfl" Text="EXT. ZAHRADA UPROSTŘED KLÁŠTERA. VEČER." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="duel_prsi_a_je_bourka_obc_VO5w" Text="Prší a je bouřka. Občasné bleska osvětlují scénu. Zachariáš zaběhne do zahrady, ale velmi brzy si všimne, že je v pasti - druhý východ je zabarikádovaný haraburdím po opravách kláštera. Otočí se. Jindra ví, že ho dostihl, tváří se odhodlaně a opatrně se přibližuje jako kočka." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="duel_seq1_h8Oq" Text="seq1" />
									<Elements>
										<Response Role="HENRY">
											<Parenthetical>
												<Text StringName="duel_henry_krikne_OLWW" Text="křikne" />
											</Parenthetical>
											<Text StringName="duel_henry_je_konec_q5oP" Text="Je konec!" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="duel_zacharias_je_sice_v__k6Ko" Text="Zachariáš je sice v koncích, ale nechce se vzdát tak snadno. Hystericky vyštěkne:" />
