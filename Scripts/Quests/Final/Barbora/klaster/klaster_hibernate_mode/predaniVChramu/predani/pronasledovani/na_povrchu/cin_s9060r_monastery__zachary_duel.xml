									<Elements>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="duel_dlc3_zach_ty_nebejt__43Gk" Text="Ty!..." />
										</Response>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="cin__dlc3_zach_nebejt_teb_EVYx" Text="Nebejt tebe, nic z toho se nemuselo stát..." />
										</Response>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="cin__dlc3_zach_ale_J6Jw" Text="Ale..." />
										</Response>
										<Response Role="DLC3_ZACHARIAS">
											<Text StringName="cin__dlc3_zach__iWuJ" Text="&lt;...&gt;" />
