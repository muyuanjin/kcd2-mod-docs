				<SceneActionElement>
					<Text StringName="prichod_z_jindra_popochaz_URQS" Text="Jindra popochází před propadlým podzemím v hlavní části chrámu. Je nervózní. Lehce prší a na velká okna bubnuje déšť. Jindra má v rukou ALBÍKOVY ZÁZNAMY." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="prichod_z_zahrmi_blizi_se_8T0i" Text="Zahřmí, blíží se bouřka. Jakoby se všechny tváře soch dívaly na Jindru. Ten se na jeden z nich taky podívá a pohlédne nahoru, když hlavu zase svěsí, otočí se. V chrámu k němu přichází ZACHARIÁŠ. Jindra z něj nechce spustit zrak, ale koutkem oka si všimne, že zleva i zprava vystoupí zpoza sloupů další ozbrojení muži." />
				</SceneActionElement>
