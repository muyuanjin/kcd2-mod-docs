			<Text StringName="prijezd_do_klastera_VYK7" Text="Příjezd do kláštera" />
			<Elements>
				<SceneActionElement>
					<Text StringName="cin_s9010_jde_o_sled_zabe_lLbi" Text="Jde o sled záběrů, jak Albík s Jindrou vyráží z Kutné Hory a přijíždějí do Sedleckého kláštera. Je den, čistá obloha slunce svítí. Počásí dokresluje radostnou atmosféru, která je po dobu celé cutscény." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9010_v_prvnim_zaberu_6bMJ" Text="V prvním záběru vidíme, jak vyjíždějí bránou z Kutné Hory, oba dva na koních, a kamera vyjede nahoru a my v dálce na obzoru vidíme cíl jejich cesty - Sedlecký klášter. Několik záběrů, jak projíždějí krajinou, než dojedou k první bráně kláštera, kde je místní stráže rychle vpouštějí dovnitř. " />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9010_pak_projizdeji__TGst" Text="Pak projíždějí na koních alejí vzrostlých stromů, které vedou k průčelí chrámu. Během toho se Jindra rozhlíží kolem dokola  vidí, že je v klášteře živo. U kašny před vstupem do chrámu na ně čeká jeden z mnichů. Nejdřív jim několik čeledínů pomáhá ze sedla a odvádí koně. Mnich je vítá a Jindra zde musí rytíři vedle mnicha odevzdat zbraň." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9010_albik_s_jindrou_r4nq" Text="Potom už Jindra společně s Albíkem vstupují do chrámu. Jindra si nevěřícne prohlíží strop, kde na lešení dělnící vysoko opravují zdivo. " />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9010_pak_je_mnich_ps_Ftm9" Text="Pak je mnich postupně provádí klášterem až se ocitáme v prostoru rajského dvora, kde uprostřed Opat řeší něco s jedním z mnichů. Albík s Jindrou k němu přistupují a on se k ním otáčí a vřele vítá Albíka." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="cin_s9010_seq1_sMUj" Text="seq1" />
									<Elements>
										<Response Role="DLC3_MNICH_Z_INTRO_CUTSCENY">
											<Text StringName="cin__dlc3_mnic_otce_opate_qdBH" Text="Otče Opate?" />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__albiku_pri_cdFO" Text="Albíku, příteli!" />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__pochvalen__hn4A" Text="Pochválen buď Ježíš Kristus." />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
