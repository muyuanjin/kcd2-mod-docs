			<Text StringName="uzavreni_klastera_7V3j" Text="Uzavření kláštera" />
			<Elements>
				<SceneActionElement>
					<Text StringName="cin_s9020_cutscena_zacina_Nih0" Text="Cutscéna začíná po polylogu, kde Albík se Zachariášem doporučili Opatovi, aby uzavřel kvůli šířící se nákaze klášter." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9020_cutscena_zacina_0r4A" Text="Cutscéná začíná záběrem na mrtvolu na voze, kterou odváží branou na hřbitov za Sedleckým klášterem, kde vidíme jednoho muže, jak kope hrob. V dalším záběru už ten stejný muž zabíjí kladive kříž do země. V následujícím záběru vidíme hřbitov z dálky skrze otevřenou bránu, kterou rytíři pomalu zavírají." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9020_pak_se_presouva_Etur" Text="Pak se přesouváme do konventu. V prvním záběru vidíme mnicha, který se v kapli modlí." />
				</SceneActionElement>
				<LinearDialogueElement>
					<Dialogue>
						<Decision Name="dec1">
							<Sequences>
								<Sequence Name="seq1">
									<DesignName StringName="cin_s9020_seq1_07k0" Text="seq1" />
									<Elements>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__dlc3_modl_tibi_domin_JCZx" Text="Tibi, Dómine, fratrem nostrum" />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__humiliter__4Z97" Text="humíliter commendámus," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__ut_quem_in_el6a" Text="ut, quem in hac vita mortáli" />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__immenso_se_J4VC" Text="imménso semper es prosecútus amóre," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__nunc_a_mal_bBNt" Text="nunc, a malis ómnibus liberátum," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__in_requiem_eB0I" Text="in réquiem íngredi iúbeas sempitérnam." />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__dlc3_modl__tuam_ergo_gI6w" Text="Tuam ergo cleméntiam deprecámur," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__ut_quia_pr_XsKq" Text="ut, quia prima iam transiérunt," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__illum_in_p_ha1C" Text="illum in paradísum tuum benígne perdúcas," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__ubi_neque__2ILQ" Text="ubi neque luctus," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__neque_clam_C8tJ" Text="neque clamor," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__neque_dolo_cL52" Text="neque dolor erit ultra," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__sed_pax_et_En8s" Text="sed pax et gáudium," />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__cum_filio__XbFt" Text="cum Fílio tuo et Spíritu Sancto, in sǽcula sæculórum" />
										</Response>
										<Response Role="OPAT_JAN_SEDLEC">
											<Text StringName="cin__opat_jan__amen_yzQp" Text="Amen" />
										</Response>
									</Elements>
								</Sequence>
							</Sequences>
						</Decision>
					</Dialogue>
				</LinearDialogueElement>
				<SceneActionElement>
					<Text StringName="cin_s9020_vsechny_tyto_za_087M" Text="Následují záběry, jak se mniši  uzavírají do svých cel a rytíři na to dohlíží. Jiný mnich si prohlíží svůj růženec. Ve špitále přibývá nemocných a jiní mniši o se ně starají. Po celou dobu slyšíme mnichovu modlitbu v pozadí. Poslední záběr je zpátky na modlícího se mnich a v kapli, který se na amen pokřižuje." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9020_koukame_do_chra_UkBD" Text="Potom následuje několik záběrů z exteriéru z areálu kláštera, kde všechna místa zejí prázdnotou." />
				</SceneActionElement>
				<SceneActionElement>
					<Text StringName="cin_s9020_nakonec_se_diva_Zda4" Text="Nakonec se vracíme do špitálu, kde Albík a Zachariáš stojí nad jedním z nemocných. Z boku k nim přichází Jindra a ptá se, co te%d budou dělat." />
				</SceneActionElement>
