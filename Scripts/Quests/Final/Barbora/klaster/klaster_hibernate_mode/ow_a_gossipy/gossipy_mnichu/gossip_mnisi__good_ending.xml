								<Response Role="DLC3_GOSSIP_MNICH_1" ReferenceLength="11">
									<Text StringName="goss_dlc3_goss_ale_pan_k__AvjO" Text="Ale Pán k sobě také vezme nejdříve ty, které má nejraději!" />
