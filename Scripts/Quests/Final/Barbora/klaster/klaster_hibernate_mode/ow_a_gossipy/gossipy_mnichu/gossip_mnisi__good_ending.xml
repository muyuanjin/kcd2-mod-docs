								<Response Role="DLC3_GOSSIP_MNICH_1" ReferenceLength="17">
									<Text StringName="goss_dlc3_goss_ano_pan_na_OQkp" Text="Ano. Pán nás před tím ochránil. Ale copak to znamená, že naši zesnulí bližní byly horšími křesťany?" />
