			<Dialogue Type="ingame" TechnicalStatus="Enabled" Initiator="NonPlayer">
				<Decision Name="dec1" Autoselect="true" VoiceoverReductionMaxSequences="1" VoiceoverReductionRole="DLC3_GOSSIP_CIVILOVE_MUZ_2">
					<Sequences>
						<Sequence EndType="EndDialogue" EntryCondition="Port('dlc3_dobry_konec')" Cooldown="50s" Name="seq1">
							<DesignName StringName="gossipy_c_seq1_y1MO" Text="seq1" />
							<Elements>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_1">
									<Text StringName="goss_dlc3_goss_je_mi_tech_hZWg" Text="Můžeme děkovat Pánu, mohlo to skončit ještě mnohem hůř!" />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_2">
									<Parenthetical>
										<Text StringName="goss_dlc3_goss_povzech_LriR" Text="povzech" />
									</Parenthetical>
									<Text StringName="goss_dlc_3_gos_stejne_je__m5wj" Text="Ale stejně mi je nějak ouzko. Představ si, že to poslední, co v životě zažiješ, je bejt zavřenej v zatuchlý cele..." />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_2">
									<Parenthetical>
										<Text StringName="goss_dlc3_goss_povzdech_oswQ" Text="povzdech" />
									</Parenthetical>
									<Text StringName="goss_dlc3_goss_predstav_s_BZDq" Text="A ven se dostaneš až zabalenej v pohřebním rubáši." />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_1">
									<Parenthetical>
										<Text StringName="goss_dlc3_goss_povzdech_nHTL" Text="povzdech" />
									</Parenthetical>
									<Text StringName="goss_dlc3_goss_navlecenej_BcuH" Text="A navíc umřeš s tím, že ses v životě nedotknul ženský..." />
									<ReviewNotesConcept>
										<Item Date="2025-05-19 17:15:02" UserName="jan.zeman" Text="Asi bych dal: A navíc, bez ženskej!" />
									</ReviewNotesConcept>
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_2">
									<Text StringName="goss_dlc_3_gos_a_pritom_j_e4QT" Text="Aspoň, že venku už je zase hezky. Ptáci zpívaj, slunce svítí... Poslední dny jako by i nebe smutnilo s náma." />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_1">
									<Parenthetical>
										<Text StringName="goss_dlc3_goss_ironicky_teHv" Text="ironicky" />
									</Parenthetical>
									<Text StringName="goss_dlc3_goss_proto_se_r_4jmG" Text="Zato teď nás čeká samá krása. Krmení vepřů, kydání hnoje, síření sudů..." />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_2">
									<Parenthetical>
										<Text StringName="goss_dlc3_goss_naznak_rad_E7nu" Text="náznak radosti" />
									</Parenthetical>
									<Text StringName="goss_dlc_3_gos_jo_krasny__yCji" Text="A víš, že se vlastně těším?" />
								</Response>
							</Elements>
						</Sequence>
						<Sequence EndType="EndDialogue" EntryCondition="Port('dlc3_dobry_konec')" Cooldown="50s" Name="seq2">
							<DesignName StringName="gossipy_c_seq2_KtU5" Text="seq2" />
							<Elements>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_1">
									<Text StringName="goss_dlc3_goss_musim_rict_JwRv" Text="Musim říct, že jsem na nás hrdej!" />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_2">
									<Text StringName="goss_dlc3_goss_jako_proc_OjXm" Text="Jako proč? Nikomu jsme nepomohli... Od toho tu jsou lékaři." />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_1">
									<Parenthetical>
										<Text StringName="goss_dlc3_goss_pateticky_bEPF" Text="pateticky" />
									</Parenthetical>
									<Text StringName="goss_dlc3_goss_protoze_js_YZvu" Text="Ale taky jsme se z toho neposrali!" />
									<ReviewNotesConcept>
										<Item Date="2025-05-19 17:19:20" UserName="jan.zeman" Text="Tohle je nepřirozené, to by neřekl. Nějak jinak to napsat." AcceptState="Accepted" />
									</ReviewNotesConcept>
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_2">
									<Text StringName="goss_dlc3_goss_co_kecas_v_guYh" Text="Vždyťs pořád skuhral, že nemůžeš todle, nemůžeš tamto. A to jsme aspoň mohli trajdat po dvoře." />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_2">
									<Text StringName="goss_dlc3_goss_o_nas_prec_7jFa" Text="Uvnitř kláštera to muselo bejt teprve hrozný." />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_1">
									<Text StringName="goss_dlc3_goss_ale_oni_js_eStN" Text="Jim pomohly modlitby. Jako sluhové Boží maj u Pána určitě přednost." />
								</Response>
								<Response Role="DLC3_GOSSIP_CIVILOVE_MUZ_2">
									<Text StringName="goss_dlc3_goss_pred_bohem_L5zG" Text="Víš přece, co se říká: Před Bohem jsme si všichni rovný." />
								</Response>
							</Elements>
						</Sequence>
					</Sequences>
