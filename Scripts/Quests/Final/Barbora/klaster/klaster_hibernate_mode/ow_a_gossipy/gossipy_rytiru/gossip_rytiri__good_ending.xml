								</Response>
								<Response Role="DLC3_GOSSIP_RYTIR_2" ReferenceLength="8.82">
									<Text StringName="ryti_dlc3_goss_ja_teda_za_g377" Text="Nic pěknýho. Ale slyšel jsem, že se Zachariáš chtěl Zikmundovi zavděčit. Asi to u něj měl nahnutý." />
									<Commands>
										<AnimationCommand Delay="0.79" FragmentId="ADLG_Disagree_light" Guid="64f57625-bf5d-e5fd-c4d0-407e66f32194" Variant="0" DesiredDuration="1.2" />
