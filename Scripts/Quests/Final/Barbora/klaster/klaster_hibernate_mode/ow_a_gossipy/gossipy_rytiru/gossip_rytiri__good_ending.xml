										<AnimationCommand Delay="1.07" FragmentId="ADLG_Leave" Guid="5b189cb2-d655-16b0-b0fe-ee554e6c96be" Variant="0" DesiredDuration="2.68" />
									</Commands>
									<ReviewNotesConcept>
										<Item Date="2025-05-20 08:45:23" UserName="jan.zeman" Text="Tady jenom bacha, jak hodně se ten týpek zajímá o státní politiku. Není to jako by volil politickou stranu." AcceptState="Accepted" />
										<Item Date="2025-05-20 08:47:33" UserName="jan.zeman" Text="Moc nevidím vtzah mezi Zachariášem a slovem páni??" AcceptState="Accepted" />
										<Item Date="2025-05-20 08:54:52" UserName="jan.zeman" Text="Myslim, že Zikmund je dobrej král, ale jestli mu sloužej takovýhle svině..." AcceptState="Accepted" />
