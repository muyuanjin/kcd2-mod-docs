										<AnimationCommand Delay="0.03" FragmentId="ADLG_Surprised_light" Guid="09d7e8e4-c10b-6c16-6c1f-7c44f70413f4" Variant="0" />
									</Commands>
									<ReviewNotesStylistic>
										<Item Date="2025-05-20 08:48:54" UserName="jan.zeman" Text="Tak to sakra posral, nebo spíš rovnou zešílel, protože myslet si, že se tímhle někomu zavděčím, to je hrůza!" AcceptState="Accepted" />
									</ReviewNotesStylistic>
