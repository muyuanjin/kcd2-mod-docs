								<Response Role="DLC3_GOSSIP_RYTIR_2" ReferenceLength="4.32">
									<Text StringName="ryti_dlc3_goss_ja_necekal_2oBs" Text="Sem nečekal, že je Zachariáš taková bestie. Kdo by to do něj řek?" />
									<Commands>
