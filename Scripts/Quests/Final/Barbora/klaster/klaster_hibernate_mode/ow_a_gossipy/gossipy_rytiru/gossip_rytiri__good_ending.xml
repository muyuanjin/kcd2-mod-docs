									</Commands>
								</Response>
								<Response Role="DLC3_GOSSIP_RYTIR_1" ReferenceLength="15">
									<Text StringName="ryti_dlc3_goss_to_sou_pan_JBWk" Text="A navíc se vyšplhal až do blízkýho kruhu okolo jeho veličenstva. Co to asi značí?" />
