								<Response Role="DLC3_GOSSIP_RYTIR_2" ReferenceLength="10.04">
									<Text StringName="ryti_dlc3_goss_a_co_dobre_dLWp" Text="Možná byl vážně blázen. Bratrance kopla mula a měl dost podobný nápady. Ale aspoň nikomu neublížil." />
