									</Commands>
								</Response>
								<Response Role="DLC3_GOSSIP_RYTIR_2" ReferenceLength="8.05">
									<Text StringName="ryti_dlc3_goss_nejvetsi_h_uDug" Text="Je to největší hrad na světě, postavenej z rudejch cihel, který září do dálky." />
