										<AnimationCommand Delay="5.37" FragmentId="ADLG_Gesture" Guid="c15cd05d-9a14-4e82-bbc0-f37125934ca8" Variant="14" />
									</Commands>
									<ReviewNotesConcept>
										<Item Date="2025-05-19 17:26:24" UserName="jan.zeman" Text="Dvojitá hradba, příkop, brány vyšší, než domy v Kutný Hoře." AcceptState="Accepted" />
									</ReviewNotesConcept>
								</Response>
								<Response Role="DLC3_GOSSIP_RYTIR_1" ReferenceLength="4">
