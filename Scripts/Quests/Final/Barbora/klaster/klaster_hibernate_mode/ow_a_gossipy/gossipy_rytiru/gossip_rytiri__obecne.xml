								</Response>
								<Response Role="DLC3_GOSSIP_RYTIR_1" ReferenceLength="7">
									<Text StringName="ryti_dlc3_goss_a_ty_prokl_DFIj" Text="A tenhle skvost nám chtěj sebrat Poláci?" />
