								<Response Role="DLC3_GOSSIP_RYTIR_1">
									<Text StringName="ryti_dlc3_goss_presne_ty__14IB" Text="Přesně! Služebnej bratr Karl je nechal šermovat, a jak jsou jeden tupější než druhej, sekli se navzájem!" />
