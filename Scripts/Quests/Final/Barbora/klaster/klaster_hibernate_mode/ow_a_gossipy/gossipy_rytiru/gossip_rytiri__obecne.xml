								</Response>
								<Response Role="DLC3_GOSSIP_RYTIR_2" ReferenceLength="6.79">
									<Text StringName="ryti_dlc3_goss_dve_rady_o_jXv0" Text="Má dvě řady opevnění, brány vyšší než domy v Kutný hoře, a nad tím vším se tyčí kříž." />
