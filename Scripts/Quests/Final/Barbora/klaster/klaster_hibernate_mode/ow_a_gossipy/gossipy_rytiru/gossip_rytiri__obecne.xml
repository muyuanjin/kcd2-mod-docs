								<Response Role="DLC3_GOSSIP_RYTIR_2">
									<Text StringName="ryti_dlc3_goss_to_musel_b_DbS0" Text="To musel Benedikt vyskočit z kůže. Mně vynadal i když jsem tam nahlas kejchnul." />
