										<AnimationCommand Delay="0.07" FragmentId="ADLG_Agree" Guid="8e89c01b-f069-744b-ae82-6d962bbb7755" Variant="0" />
									</Commands>
									<ReviewNotesConcept>
										<Item Date="2025-05-19 17:27:02" UserName="jan.zeman" Text="To zní vážně dobře." AcceptState="Accepted" />
									</ReviewNotesConcept>
								</Response>
								<Response Role="DLC3_GOSSIP_RYTIR_2" ReferenceLength="3.94">
									<Text StringName="ryti_dlc3_goss_je_to_neju_7sUg" Text="Jo, je to nejkrásnější hrad, jakej jsem kdy viděl. A že už jsem jich pár navštívil." />
									<Commands>
										<FacialMoodCommand FacialMood="happy1" />
										<AnimationCommand Delay="0.22" FragmentId="ADLG_Agree" Guid="d3cd78e7-e21f-616e-5809-9af2836ad5d4" Variant="2" DesiredDuration="3.1" />
									</Commands>
									<ReviewNotesConcept>
										<Item Date="2025-05-19 17:27:34" UserName="jan.zeman" Text="Jo, je to největší hrad, co sem v životě viděl." AcceptState="Accepted" />
