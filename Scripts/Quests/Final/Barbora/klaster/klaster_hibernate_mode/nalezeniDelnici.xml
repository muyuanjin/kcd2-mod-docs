			<Text StringName="nalezeni_delnici_b2yE" Text="Nalezení dělníci" />
			<Elements>
				<GameplayActionElement>
					<Text StringName="nalezeni__v_noci_pote_co__A2VQ" Text="V noci poté, co Albíkovi s Jindřichem někdo prohledá pokoje, vypukne v areálu kláštera požár, při němž jsou z plamenů vyproštěna dvě mužská těla. Ze zpráv, které se k Jindřichovi dostanou je zřejmé, že je celá záležitost podezřelá. Jindřich podle rad od Albíka ohledá obě mrtvoly, prozkoumá místo požáru a vyzpovídá svědka, který těla vynesl ven. Tak získá info o tom, jak se asi těla dostala do shořelého domu. Vodítka vedou k domu bylináře, kde Jindřich nestihne zabránit jeho vraždě rukou Zachariášova pomocníka. Toho následně porazí v souboji a spěchá za Albíkem, který netuší nic o tom, že Zachariáš stojí za celým propuknutím nemoci. Ten ale mezitím stihne Albíka otrávit jedem ve víně - Jindřicha následně vydírá, aby mu donesl relikvii a Václavovy záznamy." />
				</GameplayActionElement>
			</Elements>
			<QuestName StringName="qname_nalezeni_delnici_S1Qj" Text="V prach se neobrátíš" />
			<QuestDescription StringName="qdesc_nalezeni_delnici_YFbu" Text="V noci vypukl požár. Ve vyhořelém stavení se našla dvě těla. Něco tu však nehraje a je možné, že šlo o další nakažené." />
			<Objectives>
				<Objective TypeT="OhledejTela" Name="ohledejTela">
					<LocalizedName StringName="nalezeni__ohledejtela_uDvd" Text="Ohledej nalezená těla." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="OhledejTela" Marker="deadbodiesArea">
							<Log StringName="ohledejte_pohledejtelap_JcnR" Text="Po požáru jsou těla uložená ve skládku chmele. Musím se k nim dostat a zjistit o nich co nejvíc." />
						</EnumLog>
						<EnumLog Type="None" Name="PoradSeSAlbikem" />
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="ohledejte_pohledanop_nkDr" Text="Z toho co jsem viděl, jsem vyvodil několik závěrů. Obě těla nesou známky nemoci, a oba zemřeli dřív, než se do té shořelé kůlny dostali." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
						<Log Name="AbortLog">
							<Log StringName="ohledejte_nestihl_jsem_oh_72s6" Text="Nestihl jsem ohledat nalezená těla." />
						</Log>
					</Logs>
				</Objective>
				<Objective TypeT="ProhledejHoreniste" Name="prohledejHoreniste">
					<LocalizedName StringName="nalezeni__prohledejhoreni_a9lw" Text="Prohledej místo požáru." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="ProhledejHoreniste" Marker="horenisteArea">
							<Log StringName="prohledej_pprohledej_hore_lfgV" Text="Měl bych se podívat k té ohořelé kůlně. Třeba objevím nějaké stopy." />
						</EnumLog>
						<EnumLog Type="Completed" Name="Completed">
							<Log StringName="prohledej_pprohledanop_Y0so" Text="Z kůlny zbyla jen hromada spálených trámů, ale objevil jsem u ní několik podivností." />
						</EnumLog>
						<EnumLog Type="None" Name="Aborted" />
						<Log Name="AbortLog">
							<Log StringName="prohledej_misto_pozaru_js_sCdW" Text="Místo požáru jsem neměl čas prozkoumat." />
						</Log>
					</Logs>
				</Objective>
				<Objective TypeT="VyslechniSvedka" Name="vyslechniSvedka">
					<LocalizedName StringName="nalezeni__vyslechnisvedka_udDm" Text="Vyslechni svědka požáru." />
					<Logs>
						<EnumLog Type="None" Name="None" />
						<EnumLog Type="Started" Name="VyslechniSvedka" Marker="loznice">
							<Log StringName="vyslechni_pvyslechni_sved_NhLJ" Text="Konvrš jménem Eliáš prý vytáhnul z hořící kůlny ta dvě těla. Měl bych si s ním promluvit a zjistit, jak se to celé semlelo." />
